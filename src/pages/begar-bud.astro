---
import Layout from '../components/Layout.astro';

// Pre-fill data from URL params (sent from valuation email link)
const url = Astro.url;
const namn = url.searchParams.get('namn') ?? '';
const email = url.searchParams.get('email') ?? '';
const regnr = url.searchParams.get('regnr') ?? '';
const brand = url.searchParams.get('brand') ?? '';
const model = url.searchParams.get('model') ?? '';
const year = url.searchParams.get('year') ?? '';
const miltal = url.searchParams.get('miltal') ?? '';
const skick = url.searchParams.get('skick') ?? '';
const estimate = url.searchParams.get('estimate') ?? '';

const carLine = [brand, model, year && `(${year})`].filter(Boolean).join(' ');
const firstName = namn.split(' ')[0] || '';
---

<Layout
  title="Begär konkret bud | Begbilnorr"
  description="Begär konkret bud på din bil."
  noindex={true}
>
  <section class="bud-section">
    <div class="bud-card" id="formCard">
      <div class="bud-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </div>

      <p class="bud-label">KONKRET BUD INOM 24H</p>
      <h1 class="bud-h1">{firstName ? `Hej ${firstName}!` : 'Hej!'}</h1>

      {carLine && (
        <p class="bud-intro">
          Ange ditt telefonnummer så ringer vi inom 24 timmar med ett konkret bud på din <strong>{carLine}</strong>.
        </p>
      )}
      {!carLine && (
        <p class="bud-intro">
          Ange ditt telefonnummer så ringer vi inom 24 timmar med ett konkret bud.
        </p>
      )}

      <form id="budForm" class="bud-form" novalidate>
        <!-- Hidden: pre-filled from URL, sent to backend -->
        <input type="hidden" id="bud-namn" value={namn} />
        <input type="hidden" id="bud-email" value={email} />

        <div class="phone-group">
          <label for="bud-phone">Telefonnummer</label>
          <input type="tel" id="bud-phone" class="phone-input" placeholder="070 123 45 67" required autocomplete="tel" autofocus />
        </div>

        <button type="submit" id="budSubmitBtn" class="btn-primary bud-btn">Begär bud →</button>

        <p class="form-error" id="budError" style="display:none;"></p>

        <p class="bud-meta">
          {email && <>Vi mejlar bekräftelse till <strong>{email}</strong>. </>}
          Genom att skicka godkänner du <a href="/integritetspolicy" target="_blank" rel="noopener">integritetspolicyn</a>.
        </p>
      </form>
    </div>

    <!-- Success state -->
    <div class="success-card" id="successCard" style="display:none;">
      <div class="success-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h2>Tack!</h2>
      <p>Vi ringer dig på <strong id="successPhone"></strong> inom 24 timmar.</p>
    </div>
  </section>
</Layout>

<style>
  .bud-section {
    background: var(--bg-dark-1);
    min-height: 100vh;
    padding: 40px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bud-card,
  .success-card {
    width: 100%;
    max-width: 440px;
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 36px 32px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
  }

  .bud-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(230, 46, 45, 0.12);
    color: var(--red);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }

  .bud-label {
    margin: 0 0 12px;
    font-size: 11px;
    letter-spacing: 2.5px;
    color: var(--red);
    text-transform: uppercase;
    font-weight: 700;
  }

  .bud-h1 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    color: var(--white);
    margin: 0 0 14px;
    letter-spacing: -0.3px;
  }

  .bud-intro {
    font-size: 15px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .bud-intro strong {
    color: var(--white);
    font-weight: 500;
  }

  .bud-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .phone-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .phone-group label {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .phone-input {
    background: var(--bg-dark-5);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 16px 18px;
    color: var(--white);
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.3px;
    color-scheme: dark;
    transition: border-color 0.2s, background 0.2s;
  }

  .phone-input::placeholder {
    color: rgba(255,255,255,0.25);
    font-weight: 400;
  }

  .phone-input:focus {
    outline: none;
    border-color: var(--red);
    background: var(--bg-dark-4);
  }

  .bud-btn {
    width: 100%;
    justify-content: center;
    padding: 16px 24px;
    font-size: 16px;
    margin-top: 4px;
  }

  .bud-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-error {
    background: rgba(230,46,45,0.1);
    border: 1px solid rgba(230,46,45,0.3);
    border-radius: 8px;
    padding: 10px 14px;
    color: #fda4a4;
    font-size: 13px;
    margin: 0;
  }

  .bud-meta {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    margin: 8px 0 0;
    text-align: center;
  }

  .bud-meta a {
    color: rgba(255,255,255,0.6);
  }

  .bud-meta strong {
    color: rgba(255,255,255,0.65);
    font-weight: 500;
  }

  .success-card {
    text-align: center;
    border-color: rgba(46, 204, 113, 0.3);
  }

  .success-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: rgba(46, 204, 113, 0.12);
    color: #2ecc71;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-card h2 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 32px;
    color: var(--white);
    margin: 0 0 12px;
  }

  .success-card p {
    font-size: 15px;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 480px) {
    .bud-card,
    .success-card {
      padding: 28px 24px;
    }
    .bud-h1 {
      font-size: 24px;
    }
  }
</style>

<script is:inline>
  (function() {
    var form = document.getElementById('budForm');
    var formCard = document.getElementById('formCard');
    var successCard = document.getElementById('successCard');
    var successPhone = document.getElementById('successPhone');
    var submitBtn = document.getElementById('budSubmitBtn');
    var errorBox = document.getElementById('budError');

    function showError(msg) {
      errorBox.textContent = msg;
      errorBox.style.display = 'block';
    }
    function hideError() {
      errorBox.style.display = 'none';
    }

    function carContext() {
      var p = new URLSearchParams(window.location.search);
      var bits = [];
      if (p.get('regnr')) bits.push('Regnr: ' + p.get('regnr'));
      if (p.get('brand') || p.get('model') || p.get('year')) {
        bits.push('Bil: ' + [p.get('brand'), p.get('model'), p.get('year')].filter(Boolean).join(' '));
      }
      if (p.get('miltal')) bits.push('Miltal: ' + p.get('miltal') + ' mil');
      if (p.get('skick')) bits.push('Skick (uppgivet): ' + p.get('skick'));
      if (p.get('estimate')) bits.push('Tidigare värdering: ' + p.get('estimate') + ' kr');
      return bits.join('\n');
    }

    function getUtmData() {
      try {
        var p = new URLSearchParams(window.location.search);
        return {
          utm_source: p.get('utm_source') || 'email',
          utm_medium: p.get('utm_medium') || 'vardering',
          utm_campaign: p.get('utm_campaign') || 'bud-request',
          referrer: document.referrer || null,
          landing_page: window.location.pathname,
        };
      } catch (e) {
        return {};
      }
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      hideError();

      var namn = document.getElementById('bud-namn').value.trim();
      var email = document.getElementById('bud-email').value.trim();
      var phone = document.getElementById('bud-phone').value.trim();

      if (!phone || phone.replace(/\D/g, '').length < 6) {
        showError('Ange ett giltigt telefonnummer.');
        return;
      }

      var ctx = carContext();
      var fullMessage = 'KUND BEGÄR KONKRET BUD INOM 24H\n\n' +
        (ctx ? ctx + '\n\n' : '') +
        'Kunden vill bli uppringd på ' + phone + '.';

      submitBtn.disabled = true;
      submitBtn.textContent = 'Skickar…';

      try {
        var res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: namn || 'Okänd',
            email: email || null,
            phone: phone,
            message: fullMessage,
            source: 'bud-request',
            utm_data: getUtmData(),
          }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(data.error || 'Något gick fel. Försök igen.');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Begär bud →';
          return;
        }
        successPhone.textContent = phone;
        formCard.style.display = 'none';
        successCard.style.display = 'block';
      } catch (err) {
        showError('Något gick fel. Kontrollera internetanslutningen.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Begär bud →';
      }
    });
  })();
</script>
