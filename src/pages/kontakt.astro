---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Kontakta oss — Begbilnorr Luleå | Bilhandlare Norrbotten"
  description="Kontakta Begbilnorr i Luleå. Ring 0920-999 86, WhatsApp eller maila oss. Öppet Man-Fre 09-18, Lör 10-15. Vi hjälper dig!"
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 0 1 9-9 9 9 0 0 1 9 9m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
        Vi finns här för dig
      </div>
      <h1>Kontakta oss</h1>
      <p>Vi hjälper dig gärna med frågor om bilar, finansiering, värdering eller någonting annat.</p>
      <div class="hero-line"></div>
    </div>
  </section>

  <!-- Quick Contact Cards -->
  <section class="quick-contact">
    <div class="container">
      <div class="quick-contact-grid">
        <a href="tel:0920-99986" class="quick-contact-card">
          <div class="qc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h4>Ring oss</h4>
          <p>Direktkontakt med våra säljare</p>
          <div class="qc-value">0920-999 86</div>
        </a>
        <a href="https://wa.me/46727448034" class="quick-contact-card" target="_blank" rel="noopener">
          <div class="qc-icon">
            <svg viewBox="0 0 448 512" width="24" height="24" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
          </div>
          <h4>WhatsApp</h4>
          <p>Snabbt svar via meddelanden</p>
          <div class="qc-value">0727 448 034</div>
        </a>
        <a href="mailto:info@begbilnorr.se" class="quick-contact-card">
          <div class="qc-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h4>E-post</h4>
          <p>Vi svarar inom 24 timmar</p>
          <div class="qc-value">info@begbilnorr.se</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Left: Contact Info -->
        <div class="contact-info">
          <h2>Kontaktuppgifter</h2>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Telefon</div>
              <div class="value"><a href="tel:+4692099986">0920-999 86</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg viewBox="0 0 448 512" width="22" height="22" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
            </div>
            <div class="info-text">
              <div class="label">WhatsApp</div>
              <div class="value"><a href="https://wa.me/46727448034" target="_blank" rel="noopener">0727 448 034</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div class="info-text">
              <div class="label">E-post</div>
              <div class="value"><a href="mailto:info@begbilnorr.se">info@begbilnorr.se</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Adress</div>
              <div class="value"><a href="https://maps.google.com/?q=Fabriksv%C3%A4gen+18,+972+54+Lule%C3%A5" target="_blank" rel="noopener">Fabriksvägen 18, 972 54 Luleå</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Öppettider</div>
              <div class="value">Man-Fre 09-18, Lör 10-15</div>
            </div>
          </div>

          <div class="contact-social">
            <h3>Följ oss</h3>
            <div class="social-links-row">
              <a href="https://facebook.com/begbilnorr" target="_blank" rel="noopener" title="Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
              <a href="https://instagram.com/begbilnorr" target="_blank" rel="noopener" title="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </a>
              <a href="https://www.tiktok.com/@begbilnorr" target="_blank" rel="noopener" title="TikTok">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="contact-form-card">
          <h2>Skicka ett meddelande</h2>
          <p class="form-subtitle">Fyll i formuläret så återkommer vi så snart som möjligt.</p>

          <form id="contactForm">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Namn *</label>
                <input type="text" id="name" name="name" placeholder="Ditt namn" required />
              </div>
              <div class="form-group">
                <label for="phone">Telefon</label>
                <input type="tel" id="phone" name="phone" placeholder="07X-XXX XX XX" />
              </div>
            </div>

            <div class="form-group">
              <label for="email">E-post *</label>
              <input type="email" id="email" name="email" placeholder="din@email.se" required />
            </div>

            <div class="form-group">
              <label for="subject">Ämne</label>
              <select id="subject" name="subject">
                <option value="">Välj ämne</option>
                <option value="Köpa bil">Köpa bil</option>
                <option value="Sälja bil">Sälja / byta in bil</option>
                <option value="Finansiering">Finansiering</option>
                <option value="Provkörning">Boka provkörning</option>
                <option value="Övrigt">Övrigt</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Meddelande *</label>
              <textarea id="message" name="message" placeholder="Skriv ditt meddelande här..." required rows="5"></textarea>
            </div>

            <div class="terms-group">
              <label class="terms-checkbox">
                <input type="checkbox" name="terms" required />
                <span class="checkmark"></span>
                <span class="terms-text">Jag godkänner <a href="/anvandarvillkor" target="_blank">användarvillkoren</a> och <a href="/integritetspolicy" target="_blank">integritetspolicyn</a></span>
              </label>
              <button type="button" class="terms-toggle" onclick="this.parentElement.querySelector('.terms-summary').classList.toggle('open')">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                Kort sammanfattning
              </button>
              <div class="terms-summary">
                <ul>
                  <li>Vi sparar namn, e-post och telefon för att hantera din förfrågan</li>
                  <li>Vi säljer aldrig dina uppgifter till tredje part</li>
                  <li>Du kan begära radering av dina uppgifter när som helst</li>
                  <li>Formuläret innebär inte ett bindande avtal</li>
                </ul>
              </div>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              Skicka meddelande
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="map-section">
    <div class="container">
      <div class="map-wrapper">
        <div class="map-header">
          <h3>Hitta hit</h3>
          <a href="https://maps.google.com/?q=Fabriksv%C3%A4gen+18,+972+54+Lule%C3%A5" target="_blank" rel="noopener">
            Öppna i Google Maps
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="map-embed">
          <iframe
            src="https://maps.google.com/maps?q=Fabriksv%C3%A4gen+18,+972+54+Lule%C3%A5,+Sweden&t=&z=15&ie=UTF8&iwloc=&output=embed"
            width="100%"
            height="400"
            style="border:0; border-radius: 8px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Quick Contact */
  .quick-contact {
    background: var(--bg-dark-2);
    padding: 60px 0;
  }

  .quick-contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .quick-contact-card {
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 32px 24px;
    text-align: center;
    transition: all 0.3s;
    display: block;
  }

  .quick-contact-card:hover {
    border-color: var(--red);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3);
  }

  .qc-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(230,46,45,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--red);
    transition: all 0.3s;
  }

  .quick-contact-card:hover .qc-icon {
    background: var(--red);
    color: var(--white);
  }

  .quick-contact-card h4 {
    font-size: 17px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
  }

  .quick-contact-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 12px;
  }

  .qc-value {
    font-size: 16px;
    font-weight: 700;
    color: var(--red);
  }

  /* Contact Section */
  .contact-section {
    background: var(--bg-dark-2);
    padding: 0 0 80px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 40px;
  }

  .contact-info {
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 36px;
  }

  .contact-info h2 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 28px;
  }

  .contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px;
    border-radius: 8px;
    transition: background 0.2s;
    margin-bottom: 4px;
  }

  .contact-info-item:hover {
    background: rgba(255,255,255,0.04);
  }

  .info-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(230,46,45,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--red);
  }

  .info-text .label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 4px;
    font-weight: 600;
  }

  .info-text .value {
    font-size: 15px;
    color: var(--white);
    font-weight: 500;
  }

  .info-text .value a {
    color: var(--white);
    transition: color 0.2s;
  }

  .info-text .value a:hover {
    color: var(--red);
  }

  .contact-social {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .contact-social h3 {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
  }

  .social-links-row {
    display: flex;
    gap: 12px;
  }

  .social-links-row a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.6);
    transition: all 0.2s;
  }

  .social-links-row a:hover {
    background: var(--red);
    color: var(--white);
  }

  /* Contact Form Card */
  .contact-form-card {
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 36px;
  }

  .contact-form-card h2 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 8px;
  }

  .form-subtitle {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 28px;
  }

  /* Map */
  .map-section {
    background: var(--bg-dark-2);
    padding: 0 0 80px;
  }

  .map-wrapper {
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    overflow: hidden;
    padding: 24px;
  }

  .map-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .map-header h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
  }

  .map-header a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--red);
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .map-header a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .quick-contact-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-info,
    .contact-form-card {
      padding: 28px 20px;
    }

    .map-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    const originalHTML = btn.innerHTML;
    btn.textContent = 'Skickar...';
    btn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.name,
          email: data.email,
          phone: data.phone,
          message: data.subject ? `[${data.subject}] ${data.message}` : data.message,
          source: 'kontakt',
          utm_data: (window as any).getUtmData?.(),
        }),
      });

      if (!res.ok) throw new Error('Någonting gick fel');

      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg> Tack! Vi återkommer snart.';
      btn.style.background = '#22C55E';

      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.style.background = '';
        btn.disabled = false;
        form.reset();
      }, 3000);
    } catch {
      btn.innerHTML = originalHTML;
      btn.disabled = false;
      alert('Någonting gick fel. Försök igen eller ring oss på 0920-999 86.');
    }
  });
</script>
