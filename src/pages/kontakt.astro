---
import Layout from '../components/Layout.astro';
import ContactForm from '../components/ContactForm';
---

<Layout
  title="Kontakta Begbilnorr – Bilhandlare i Luleå | Ring 0920-999 86"
  description="Kontakta Begbilnorr i Luleå. Ring 0920-999 86, WhatsApp 0727 448 034 eller maila info@begbilnorr.se. Öppet Mån-Fre 09-18, Lör 10-15."
>
  <div class="hero-contact">
    <h1>Kontakta oss</h1>
    <p>Vi finns här för dig — ring, maila eller besök oss</p>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Kontaktuppgifter</h2>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Telefon</div>
              <div class="value"><a href="tel:+4692099986">0920-999 86</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg viewBox="0 0 448 512" width="22" height="22" fill="#E62E2D"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
            </div>
            <div class="info-text">
              <div class="label">WhatsApp</div>
              <div class="value"><a href="https://wa.me/46727448034" target="_blank" rel="noopener">0727 448 034</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div class="info-text">
              <div class="label">E-post</div>
              <div class="value"><a href="mailto:info@begbilnorr.se">info@begbilnorr.se</a></div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Öppettider</div>
              <div class="value">Mån-Fre: 09-18<br/>Lör: 10-15</div>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="info-text">
              <div class="label">Adress</div>
              <div class="value">Luleå, Norrbotten</div>
            </div>
          </div>
        </div>

        <div class="contact-form-card">
          <h2>Skicka ett meddelande</h2>
          <p class="form-subtitle">Fyll i formuläret så återkommer vi inom kort.</p>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</Layout>
