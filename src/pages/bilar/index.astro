---
import Layout from '../../components/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { supabase } from '../../lib/supabase';
import type { Car } from '../../types/car';

const url = Astro.url;
const brand = url.searchParams.get('brand') || '';
const fuel = url.searchParams.get('fuel') || '';
const gearbox = url.searchParams.get('gearbox') || '';
const sort = url.searchParams.get('sort') || 'newest';
const search = url.searchParams.get('search') || '';

let query = supabase
  .from('cars')
  .select('*')
  .eq('is_active', true)
  .eq('is_sold', false);

if (brand) query = query.ilike('brand', brand);
if (fuel) query = query.ilike('fuel_type', `%${fuel}%`);
if (gearbox) query = query.ilike('gearbox', `%${gearbox}%`);
if (search) query = query.or(`full_name.ilike.%${search}%,brand.ilike.%${search}%,model.ilike.%${search}%`);

if (sort === 'price-asc') query = query.order('price', { ascending: true });
else if (sort === 'price-desc') query = query.order('price', { ascending: false });
else if (sort === 'year-desc') query = query.order('year', { ascending: false });
else if (sort === 'mileage-asc') query = query.order('mileage', { ascending: true });
else query = query.order('created_at', { ascending: false });

const { data: cars } = await query;
const allCars = (cars || []) as Car[];

const { data: brandData } = await supabase
  .from('cars')
  .select('brand')
  .eq('is_active', true)
  .eq('is_sold', false);

const brands = [...new Set((brandData || []).map((c: { brand: string }) => c.brand))].sort();
---

<Layout
  title="Alla begagnade bilar – Begbilnorr i Luleå | Köp bil med garanti"
  description="Se alla begagnade bilar hos Begbilnorr i Luleå. Filtrera på märke, modell, pris och årsmodell. Alla bilar kvalitetskontrollerade med garanti."
>
  <div class="page-header">
    <div class="container">
      <h1>Alla bilar</h1>
      <div class="breadcrumb">
        <a href="/">Hem</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <span class="current">Alla bilar</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="filter-section">
      <form class="filter-card" method="get" action="/bilar">
        <div class="filter-search">
          <span class="search-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </span>
          <input type="text" name="search" placeholder="Sök märke, modell..." value={search} />
        </div>
        <div class="filter-row">
          <div class="filter-select">
            <select name="brand">
              <option value="">Alla märken</option>
              {brands.map((b) => (
                <option value={b} selected={brand === b}>{b}</option>
              ))}
            </select>
          </div>
          <div class="filter-select">
            <select name="fuel">
              <option value="">Drivmedel</option>
              <option value="Bensin" selected={fuel === 'Bensin'}>Bensin</option>
              <option value="Diesel" selected={fuel === 'Diesel'}>Diesel</option>
              <option value="Hybrid" selected={fuel === 'Hybrid'}>Hybrid</option>
              <option value="El" selected={fuel === 'El'}>El</option>
            </select>
          </div>
          <div class="filter-select">
            <select name="gearbox">
              <option value="">Växellåda</option>
              <option value="Automat" selected={gearbox === 'Automat'}>Automat</option>
              <option value="Manuell" selected={gearbox === 'Manuell'}>Manuell</option>
            </select>
          </div>
          <div class="filter-select">
            <select name="sort">
              <option value="newest" selected={sort === 'newest'}>Senast inkomna</option>
              <option value="price-asc" selected={sort === 'price-asc'}>Pris: Lägst först</option>
              <option value="price-desc" selected={sort === 'price-desc'}>Pris: Högst först</option>
              <option value="year-desc" selected={sort === 'year-desc'}>Nyaste först</option>
              <option value="mileage-asc" selected={sort === 'mileage-asc'}>Lägst miltal</option>
            </select>
          </div>
        </div>
        <div class="filter-actions">
          <div style="display:flex;align-items:center;gap:16px;">
            <button type="submit" class="filter-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              Sök
            </button>
            <a href="/bilar" class="clear-filter">Rensa filter</a>
          </div>
          <span class="results-count"><strong>{allCars.length}</strong> bilar hittades</span>
        </div>
      </form>
    </div>

    <div class="car-grid">
      {allCars.map((car) => <CarCard car={car} />)}
    </div>

    {allCars.length === 0 && (
      <div style="text-align:center;padding:64px 0;">
        <p style="font-size:18px;color:var(--gray);">Inga bilar matchade din sökning.</p>
        <a href="/bilar" style="color:var(--red);font-weight:600;margin-top:12px;display:inline-block;">Visa alla bilar</a>
      </div>
    )}
  </div>
</Layout>
