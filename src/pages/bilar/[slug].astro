</style>

<script>
  document.getElementById('contactBtn')?.addEventListener('click', () => {
    const btn = document.getElementById('contactBtn') as HTMLElement;
    window.dispatchEvent(
      new CustomEvent('open-contact-modal', {
        detail: {
          carName: btn.dataset.carName || '',
          carSlug: btn.dataset.carSlug || '',
        },
      })
    );
  });

  // Gallery navigation
  const galleryMain = document.getElementById('galleryMain') as HTMLElement;
  const mainImg = document.querySelector('#mainImage') as HTMLImageElement;
  const galleryImages: string[] = galleryMain ? JSON.parse(galleryMain.dataset.images || '[]') : [];
  let currentIdx = 0;

  function goToImage(idx: number) {
    if (!mainImg || galleryImages.length === 0) return;
    currentIdx = (idx + galleryImages.length) % galleryImages.length;
    mainImg.src = galleryImages[currentIdx];
    document.querySelectorAll('.gallery-thumb').forEach((t) => t.classList.remove('active'));
    const activeThumb = document.querySelector(`.gallery-thumb[data-index="${currentIdx}"]`);
    activeThumb?.classList.add('active');
    activeThumb?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    const counter = document.getElementById('currentIndex');
    if (counter) counter.textContent = String(currentIdx + 1);
  }

  document.getElementById('galleryPrev')?.addEventListener('click', (e) => {
    e.preventDefault();
    goToImage(currentIdx - 1);
  });

  document.getElementById('galleryNext')?.addEventListener('click', (e) => {
    e.preventDefault();
    goToImage(currentIdx + 1);
  });

  document.querySelectorAll('.gallery-thumb').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const idx = parseInt((thumb as HTMLElement).dataset.index || '0', 10);
      goToImage(idx);
    });
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goToImage(currentIdx - 1);
    if (e.key === 'ArrowRight') goToImage(currentIdx + 1);
  });

  // Finance Modal
  const fmOpenBtn = document.getElementById('financeModalOpen') as HTMLElement;
  const fmOverlay = document.getElementById('financeModal') as HTMLElement;
  const fmCloseBtn = document.getElementById('financeModalClose');
  const fmDurationBtns = document.getElementById('fmDurationBtns');
  const fmEquitySlider = document.getElementById('fmEquitySlider') as HTMLInputElement;
  const fmEquityInput = document.getElementById('fmEquityInput') as HTMLInputElement;
  const fmSendBtn = document.getElementById('fmSendBtn');

  if (fmOpenBtn && fmOverlay) {
    const carPrice = parseInt(fmOpenBtn.dataset.price || '0', 10);
    const carName = fmOpenBtn.dataset.name || '';
    const RATE = 0.0895; // 8.95% fast ränta
    let selectedMonths = 60;
    let equityPercent = 20;

    function fmFormatSEK(n: number): string {
      return Math.round(n).toLocaleString('sv-SE') + ' kr';
    }

    function fmCalcMonthly(principal: number, months: number): number {
      if (principal <= 0) return 0;
      const mr = RATE / 12;
      if (mr === 0) return principal / months;
      return principal * (mr * Math.pow(1 + mr, months)) / (Math.pow(1 + mr, months) - 1);
    }

    function fmUpdate() {
      const downAmount = Math.round(carPrice * equityPercent / 100);
      const loanWith = carPrice - downAmount;
      const loanWithout = carPrice;

      const monthlyWith = fmCalcMonthly(loanWith, selectedMonths);
      const monthlyWithout = fmCalcMonthly(loanWithout, selectedMonths);
      const totalWith = monthlyWith * selectedMonths + downAmount;
      const totalWithout = monthlyWithout * selectedMonths;

      // Price display
      const priceEl = document.getElementById('fmPriceDisplay');
      if (priceEl) priceEl.textContent = fmFormatSEK(carPrice);

      // Equity displays
      const percentEl = document.getElementById('fmEquityPercent');
      const amountEl = document.getElementById('fmEquityAmount');
      if (percentEl) percentEl.textContent = equityPercent + '%';
      if (amountEl) amountEl.textContent = fmFormatSEK(downAmount);
      if (fmEquityInput) fmEquityInput.value = Math.round(downAmount).toLocaleString('sv-SE');

      // With down payment
      const mwEl = document.getElementById('fmMonthlyWith');
      const lwEl = document.getElementById('fmLoanWith');
      const dwEl = document.getElementById('fmDownDisplay');
      const twEl = document.getElementById('fmTotalWith');
      if (mwEl) mwEl.textContent = fmFormatSEK(monthlyWith) + '/mån';
      if (lwEl) lwEl.textContent = fmFormatSEK(loanWith);
      if (dwEl) dwEl.textContent = fmFormatSEK(downAmount) + ' (' + equityPercent + '%)';
      if (twEl) twEl.textContent = fmFormatSEK(totalWith);

      // Without down payment
      const mwoEl = document.getElementById('fmMonthlyWithout');
      const lwoEl = document.getElementById('fmLoanWithout');
      const twoEl = document.getElementById('fmTotalWithout');
      if (mwoEl) mwoEl.textContent = fmFormatSEK(monthlyWithout) + '/mån';
      if (lwoEl) lwoEl.textContent = fmFormatSEK(loanWithout);
      if (twoEl) twoEl.textContent = fmFormatSEK(totalWithout);

      // Summary
      const snEl = document.getElementById('fmSummaryName');
      const spEl = document.getElementById('fmSummaryPrice');
      const stEl = document.getElementById('fmSummaryTerm');
      if (snEl) snEl.textContent = carName;
      if (spEl) spEl.textContent = fmFormatSEK(carPrice);
      if (stEl) stEl.textContent = (selectedMonths / 12) + ' år';
    }

    // Open modal
    fmOpenBtn.addEventListener('click', () => {
      fmOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      fmUpdate();
    });

    // Close modal
    function fmClose() {
      fmOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }
    fmCloseBtn?.addEventListener('click', fmClose);
    fmOverlay.addEventListener('click', (e) => {
      if (e.target === fmOverlay) fmClose();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && fmOverlay.classList.contains('open')) fmClose();
    });

    // Duration buttons
    fmDurationBtns?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;
      selectedMonths = parseInt(btn.dataset.months || '60', 10);
      fmDurationBtns.querySelectorAll('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      fmUpdate();
    });

    // Equity slider
    fmEquitySlider?.addEventListener('input', () => {
      equityPercent = parseInt(fmEquitySlider.value, 10);
      fmUpdate();
    });

    // Equity input
    fmEquityInput?.addEventListener('input', () => {
      const raw = fmEquityInput.value.replace(/\s/g, '').replace(/[^0-9]/g, '');
      const val = parseInt(raw, 10) || 0;
      equityPercent = Math.min(100, Math.max(0, Math.round((val / carPrice) * 100)));
      fmEquitySlider.value = String(equityPercent);
      fmUpdate();
    });

    // Send button - opens contact modal with pre-filled info
    fmSendBtn?.addEventListener('click', () => {
      const phone = (document.getElementById('fmPhone') as HTMLInputElement)?.value || '';
      fmClose();
      window.dispatchEvent(
        new CustomEvent('open-contact-modal', {
          detail: { carName, carSlug: '' }
        })
      );
    });
  }

  // Request Details CTA
  const rdSendBtn = document.getElementById('rdSendBtn');
  rdSendBtn?.addEventListener('click', () => {
    const phone = (document.getElementById('rdPhone') as HTMLInputElement)?.value?.trim();
    if (!phone) {
      const input = document.getElementById('rdPhone') as HTMLInputElement;
      input?.focus();
      const wrap = input?.closest('.rd-input-wrap') as HTMLElement;
      if (wrap) {
        wrap.style.borderColor = '#E62E2D';
        setTimeout(() => { wrap.style.borderColor = ''; }, 2000);
      }
      return;
    }
    const carName = (rdSendBtn as HTMLElement).dataset.carName || '';
    window.dispatchEvent(
      new CustomEvent('open-contact-modal', {
        detail: { carName, carSlug: '' }
      })
    );
  });
</script>
