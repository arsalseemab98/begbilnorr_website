---
import Layout from '../../components/Layout.astro';
import StructuredData from '../../components/StructuredData.astro';
import CarCard from '../../components/CarCard.astro';
import { supabase } from '../../lib/supabase';
import { formatPrice, formatMileage, calculateMonthlyPayment } from '../../lib/utils';
import type { Car } from '../../types/car';

const { slug } = Astro.params;

let data: any = null;
let relatedCars: Car[] = [];

try {
  const result = await supabase
    .from('cars')
    .select('*')
    .eq('slug', slug)
    .single();
  data = result.data;

  if (data) {
    const { data: relatedData } = await supabase
      .from('cars')
      .select('*')
      .eq('is_active', true)
      .eq('is_sold', false)
      .neq('slug', slug)
      .limit(3);
    relatedCars = (relatedData || []) as Car[];
  }
} catch {
  // Supabase not configured
}

if (!data) {
  return Astro.redirect('/bilar');
}

const car = data as Car;
const monthly = car.monthly_payment || calculateMonthlyPayment(car.price);
const mainImage = car.images?.[0] || '';

const carSchema = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": car.full_name,
  "brand": { "@type": "Brand", "name": car.brand },
  "model": car.model,
  "vehicleModelDate": String(car.year),
  "mileageFromOdometer": { "@type": "QuantitativeValue", "value": car.mileage, "unitCode": "SMI" },
  "fuelType": car.fuel_type,
  "vehicleTransmission": car.gearbox,
  "offers": {
    "@type": "Offer",
    "price": car.price,
    "priceCurrency": "SEK",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "AutoDealer", "name": "Begbilnorr", "url": "https://begbilnorr.se" }
  },
  "image": mainImage,
  "url": `https://begbilnorr.se/bilar/${car.slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://begbilnorr.se/" },
    { "@type": "ListItem", "position": 2, "name": "Bilar", "item": "https://begbilnorr.se/bilar/" },
    { "@type": "ListItem", "position": 3, "name": car.full_name, "item": `https://begbilnorr.se/bilar/${car.slug}` }
  ]
};
---

<Layout
  title={`${car.full_name} -- ${formatPrice(car.price)} | Begbilnorr Luleå`}
  description={car.description || `Köp begagnad ${car.full_name} hos Begbilnorr i Luleå. ${formatPrice(car.price)}. Garanti och finansiering ingår.`}
  ogType="product"
  ogImage={mainImage}
  priceAmount={car.price}
>
  <Fragment slot="head">
    <StructuredData data={carSchema} />
    <StructuredData data={breadcrumbSchema} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Hem</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <a href="/bilar">Bilar</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <span class="current">{car.full_name}</span>
      </div>
    </div>
  </div>

  <!-- Detail Section -->
  <section class="detail-section">
    <div class="container">
      <div class="detail-grid">
        <!-- Gallery -->
        <div class="gallery">
          <div class="gallery-main" id="galleryMain" data-images={JSON.stringify(car.images || [])}>
            {mainImage ? (
              <img src={mainImage} alt={`Begagnad ${car.full_name} till salu Luleå`} id="mainImage" />
            ) : (
              <span style="font-size:80px;opacity:0.2;">&#128663;</span>
            )}
            <div class="watermark">Begbilnorr</div>
            {car.images?.length > 1 && (
              <button class="gallery-arrow gallery-arrow-left" id="galleryPrev" aria-label="Föregående bild">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              </button>
            )}
            {car.images?.length > 1 && (
              <button class="gallery-arrow gallery-arrow-right" id="galleryNext" aria-label="Nästa bild">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            )}
            {car.images?.length > 1 && (
              <div class="image-count" id="imageCounter">
                <span id="currentIndex">1</span> / {car.images.length}
              </div>
            )}
          </div>
          {car.images?.length > 1 && (
            <div class="gallery-thumbnails" id="galleryThumbnails">
              {car.images.map((img, i) => (
                <div class={`gallery-thumb ${i === 0 ? 'active' : ''}`} data-src={img} data-index={i}>
                  <img src={img} alt={`${car.full_name} bild ${i + 1}`} loading="lazy" />
                </div>
              ))}
            </div>
          )}

          <!-- Request Details CTA (under gallery) -->
          <div class="request-details-card">
            <div class="rd-glow"></div>
            <div class="rd-inner">
              <div class="rd-visual">
                <div class="rd-icon-stack">
                  <div class="rd-icon rd-icon-camera">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                  </div>
                  <div class="rd-icon rd-icon-doc">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 13H8"/><path d="M16 17H8"/><path d="M16 13h-2"/></svg>
                  </div>
                </div>
              </div>
              <div class="rd-content">
                <h3 class="rd-title">Vill du veta mer om denna bil?</h3>
                <p class="rd-subtitle">Få exklusiv information skickad direkt till dig</p>
                <div class="rd-checklist">
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Detaljbilder från alla vinklar
                  </div>
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Komplett servicehistorik
                  </div>
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Besiktningsprotokoll
                  </div>
                </div>
                <div class="rd-form">
                  <div class="rd-input-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <input type="tel" id="rdPhone" placeholder="Ditt mobilnummer" autocomplete="tel" />
                  </div>
                  <button type="button" class="rd-send-btn" id="rdSendBtn" data-car-name={car.full_name}>
                    Skicka till mig
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                  </button>
                </div>
                <p class="rd-privacy">Vi behandlar dina uppgifter enligt GDPR. Inga spam — bara det du bett om.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Car Info -->
        <div class="car-info">
          <div class="car-info-inner">
            <div class="badge-row">
              <span class="badge-stock">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                I lager
              </span>
              <span class="badge-location">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Begbilnorr Luleå
              </span>
            </div>

            <h1>{car.full_name}</h1>
            <div class="car-year">Årsmodell {car.year} &middot; {car.reg_no}</div>
            <div class="car-price">{formatPrice(car.price)}</div>
            <div class="car-monthly">från <span>{monthly}</span></div>

            <!-- Prisberäknare / Finansiering -->
            <button class="finance-modal-trigger" id="financeModalOpen" type="button" data-price={car.price} data-name={car.full_name}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>
              Beräkna månadskostnad
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>

            <div class="car-buttons">
              <button class="btn-primary" id="contactBtn" data-car-name={car.full_name} data-car-slug={car.slug}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Intresserad? Kontakta oss
              </button>
              <a href={`https://wa.me/46727448034?text=Hej! Jag är intresserad av ${car.full_name} (${car.reg_no})`} class="btn-outline" target="_blank" rel="noopener">
                <svg viewBox="0 0 448 512" width="18" height="18" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
                WhatsApp
              </a>
              <a href="tel:+4692099986" class="btn-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Ring 0920-999 86
              </a>
            </div>

            <div class="specs-grid">
              <div class="spec-item">
                <span class="spec-label">Miltal</span>
                <span class="spec-value">{formatMileage(car.mileage)}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Årsmodell</span>
                <span class="spec-value">{car.year}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Drivmedel</span>
                <span class="spec-value">{car.fuel_type}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Växellåda</span>
                <span class="spec-value">{car.gearbox}</span>
              </div>
              {car.body_type && (
                <div class="spec-item">
                  <span class="spec-label">Karosseri</span>
                  <span class="spec-value">{car.body_type}</span>
                </div>
              )}
              <div class="spec-item">
                <span class="spec-label">Reg.nr</span>
                <span class="spec-value">{car.reg_no}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Description -->
      {car.specifications && (
        <div class="specifications-section">
          <h2>Beskrivning</h2>
          <div class="specifications-text">{car.specifications}</div>
        </div>
      )}

      <!-- Equipment -->
      {car.equipment?.length > 0 && (
        <div class="equipment-section">
          <h2>Utrustning</h2>
          <div class="equipment-grid">
            {car.equipment.map((item) => (
              <div class="equipment-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Related Cars -->
      {relatedCars.length > 0 && (
        <div class="description-section" style="margin-top:64px;">
          <h2>Liknande bilar</h2>
          <div class="car-grid">
            {relatedCars.map((rc) => <CarCard car={rc} />)}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Finance Modal -->
  <div class="fm-overlay" id="financeModal">
    <div class="fm-wrapper">
      <div class="fm-top-border"></div>
      <div class="fm-header">
        <p><span>Räkna på månadskostnad</span></p>
        <button class="fm-close" id="financeModalClose" type="button" aria-label="Stäng">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="fm-divider"></div>
      <div class="fm-content">
        <section class="fm-section">
          <p class="fm-label fm-highlight">Bilpris</p>
          <div class="fm-price-display" id="fmPriceDisplay"></div>
        </section>
        <section class="fm-section">
          <p class="fm-label">Lånetid</p>
          <div class="fm-duration-btns" id="fmDurationBtns">
            <button type="button" data-months="96">8 år</button>
            <button type="button" data-months="84">7 år</button>
            <button type="button" data-months="72">6 år</button>
            <button type="button" data-months="60" class="active">5 år</button>
            <button type="button" data-months="48">4 år</button>
            <button type="button" data-months="36">3 år</button>
            <button type="button" data-months="24">2 år</button>
          </div>
        </section>
        <section class="fm-section">
          <p class="fm-label">Kontantinsats</p>
          <p class="fm-equity-hint">Minst 20%. Du kan även använda värdet på din inbytesbil som insats</p>
          <div class="fm-equity-input-row">
            <input type="text" id="fmEquityInput" autocomplete="off" />
            <span>kr</span>
          </div>
          <div class="fm-equity-marks">
            <span id="fmEquityPercent">20%</span>
            <span id="fmEquityAmount"></span>
          </div>
          <div class="fm-slider-wrap">
            <input type="range" id="fmEquitySlider" min="0" max="100" step="1" value="20" class="fm-slider" />
            <div class="fm-slider-labels">
              <span>0%</span>
              <span>20%</span>
              <span>50%</span>
              <span>100%</span>
            </div>
          </div>
        </section>
        <section class="fm-section fm-result-section">
          <p class="fm-label fm-highlight">Månadskostnad med kontantinsats</p>
          <div class="fm-result-big" id="fmMonthlyWith">0 kr/mån</div>
          <div class="fm-result-detail">
            <span>Lånebelopp</span>
            <span id="fmLoanWith">0 kr</span>
          </div>
          <div class="fm-result-detail">
            <span>Kontantinsats</span>
            <span id="fmDownDisplay">0 kr (20%)</span>
          </div>
          <div class="fm-result-detail">
            <span>Totalt att betala</span>
            <span id="fmTotalWith">0 kr</span>
          </div>
        </section>
        <section class="fm-section fm-result-section fm-result-alt">
          <p class="fm-label fm-highlight">Månadskostnad utan kontantinsats</p>
          <div class="fm-result-big" id="fmMonthlyWithout">0 kr/mån</div>
          <div class="fm-result-detail">
            <span>Lånebelopp</span>
            <span id="fmLoanWithout">0 kr</span>
          </div>
          <div class="fm-result-detail">
            <span>Totalt att betala</span>
            <span id="fmTotalWithout">0 kr</span>
          </div>
        </section>
        <section class="fm-section fm-summary">
          <p class="fm-label fm-highlight">Summering</p>
          <div class="fm-summary-row">
            <span id="fmSummaryName"></span>
            <span id="fmSummaryPrice"></span>
          </div>
          <div class="fm-summary-row fm-secondary">
            <span>Ränta (fast)</span>
            <span>8,95%</span>
          </div>
          <div class="fm-summary-row fm-secondary">
            <span>Lånetid</span>
            <span id="fmSummaryTerm">5 år</span>
          </div>
        </section>
        <section class="fm-section fm-warning">
          <div class="fm-warning-box">
            <p class="fm-disclaimer-calc">Månadskostnaden är ett exempel och baseras på vald löptid med 8,95% ränta. Uppläggnings- och aviavgift tillkommer. Den faktiska räntan kan bli både lägre och högre beroende på din individuella kreditbedömning.</p>
          </div>
          <div class="fm-warning-box fm-warning-important">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            <p><strong>Att låna kostar pengar!</strong> Om du inte kan betala tillbaka skulden i tid riskerar du en betalningsanmärkning. Det kan leda till svårigheter att få hyra bostad, teckna abonnemang och få nya lån.</p>
          </div>
        </section>
        <section class="fm-section fm-cta">
          <input type="tel" id="fmPhone" placeholder="Ditt mobilnummer" autocomplete="off" />
          <button type="button" class="fm-send-btn" id="fmSendBtn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Kontakta oss för offert
          </button>
          <p class="fm-policy">Beräkningen är uppskattad och inte bindande. Kontakta oss för exakt offert anpassad efter dig.</p>
        </section>
      </div>
    </div>
  </div>
</Layout>

<style>
  .breadcrumb-bar {
    padding: 16px 0;
    background: var(--bg-dark-3);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* Finance Modal Trigger Button */
  .finance-modal-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    margin-bottom: 24px;
    background: rgba(230,46,45,0.08);
    border: 1px solid rgba(230,46,45,0.15);
    border-radius: 8px;
    color: var(--red-light);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--sans);
  }
  .finance-modal-trigger:hover {
    background: rgba(230,46,45,0.14);
    border-color: rgba(230,46,45,0.3);
  }
  .finance-modal-trigger svg:last-child {
    margin-left: auto;
  }

  /* Finance Modal Overlay */
  .fm-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0,0,0,0.7);
