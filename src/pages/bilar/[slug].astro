---
import Layout from '../../components/Layout.astro';
import StructuredData from '../../components/StructuredData.astro';
import CarCard from '../../components/CarCard.astro';
import { supabase } from '../../lib/supabase';
import { formatPrice, formatMileage, calculateMonthlyPayment, formatPriceExVat } from '../../lib/utils';
import type { Car } from '../../types/car';

const { slug } = Astro.params;

let data: any = null;
let relatedCars: Car[] = [];

try {
  const result = await supabase
    .from('cars')
    .select('*')
    .eq('slug', slug)
    .single();
  data = result.data;

  if (data) {
    const { data: relatedData } = await supabase
      .from('cars')
      .select('*')
      .eq('is_active', true)
      .eq('is_sold', false)
      .neq('slug', slug)
      .limit(3);
    relatedCars = (relatedData || []) as Car[];
  }
} catch {
  // Supabase not configured
}

if (!data) {
  return Astro.redirect('/bilar');
}

const car = data as Car;
const monthly = car.monthly_payment || calculateMonthlyPayment(car.price);
const mainImage = car.images?.[0] || '';

const carSchema = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": car.full_name,
  "description": car.description?.split('\n')[0] || `Begagnad ${car.full_name} till salu hos Begbilnorr i Luleå`,
  "brand": { "@type": "Brand", "name": car.brand },
  "model": car.model,
  "vehicleModelDate": `${car.year}-01-01`,
  "vehicleConfiguration": "Used",
  "mileageFromOdometer": {
    "@type": "QuantitativeValue",
    "value": car.mileage,
    "unitCode": "KMT"
  },
  "fuelType": car.fuel_type,
  "vehicleTransmission": car.gearbox,
  ...(car.body_type ? { "bodyType": car.body_type } : {}),
  "vehicleIdentificationNumber": car.reg_no,
  "image": car.images?.length ? car.images : mainImage,
  "offers": {
    "@type": "Offer",
    "price": car.price,
    "priceCurrency": "SEK",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/UsedCondition",
    "seller": {
      "@type": "AutoDealer",
      "name": "Begbilnorr",
      "url": "https://begbilnorr.se"
    }
  },
  "url": `https://begbilnorr.se/bilar/${car.slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://begbilnorr.se/" },
    { "@type": "ListItem", "position": 2, "name": "Bilar", "item": "https://begbilnorr.se/bilar/" },
    { "@type": "ListItem", "position": 3, "name": car.full_name, "item": `https://begbilnorr.se/bilar/${car.slug}` }
  ]
};
---

<Layout
  title={`${car.full_name} ${car.year} — ${formatPrice(car.price)} | Begbilnorr Luleå`}
  description={car.description || `Köp begagnad ${car.full_name} hos Begbilnorr i Luleå. ${formatPrice(car.price)}. Garanti och finansiering ingår.`}
  ogType="product"
  ogImage={mainImage}
  priceAmount={car.price}
>
  <Fragment slot="head">
    <StructuredData data={carSchema} />
    <StructuredData data={breadcrumbSchema} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Hem</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <a href="/bilar">Bilar</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <span class="current">{car.full_name}</span>
      </div>
    </div>
  </div>

  <!-- Detail Section -->
  <section class="detail-section">
    <div class="container">
      <div class="detail-grid">
        <!-- Gallery -->
        <div class="gallery">
          <div class="gallery-main" id="galleryMain" data-images={JSON.stringify(car.images || [])} data-car-name={car.full_name}>
            {mainImage ? (
              <img src={mainImage} alt={`Begagnad ${car.full_name} ${car.year} till salu i Luleå — ${formatPrice(car.price)}`} id="mainImage" fetchpriority="high" />
            ) : (
              <span style="font-size:80px;opacity:0.2;">&#128663;</span>
            )}
            <div class="watermark">Begbilnorr</div>
            {car.images?.length > 1 && (
              <button class="gallery-arrow gallery-arrow-left" id="galleryPrev" aria-label="Föregående bild">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              </button>
            )}
            {car.images?.length > 1 && (
              <button class="gallery-arrow gallery-arrow-right" id="galleryNext" aria-label="Nästa bild">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            )}
            {car.images?.length > 1 && (
              <div class="image-count" id="imageCounter">
                <span id="currentIndex">1</span> / {car.images.length}
              </div>
            )}
          </div>
          {car.images?.length > 1 && (
            <div class="gallery-thumbnails" id="galleryThumbnails">
              {car.images.map((img, i) => (
                <div class={`gallery-thumb ${i === 0 ? 'active' : ''}`} data-src={img} data-index={i}>
                  <img src={img} alt={`${car.full_name} — bild ${i + 1} av ${car.images.length}`} loading="lazy" />
                </div>
              ))}
            </div>
          )}

          <!-- Request Details CTA (under gallery) -->
          <div class="request-details-card">
            <div class="rd-glow"></div>
            <div class="rd-inner">
              <div class="rd-visual">
                <div class="rd-icon-stack">
                  <div class="rd-icon rd-icon-camera">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                  </div>
                  <div class="rd-icon rd-icon-doc">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 13H8"/><path d="M16 17H8"/><path d="M16 13h-2"/></svg>
                  </div>
                </div>
              </div>
              <div class="rd-content">
                <h3 class="rd-title">Vill du veta mer om denna bil?</h3>
                <p class="rd-subtitle">Få exklusiv information skickad direkt till dig</p>
                <div class="rd-checklist">
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Detaljbilder från alla vinklar
                  </div>
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Komplett servicehistorik
                  </div>
                  <div class="rd-check-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    Besiktningsprotokoll
                  </div>
                </div>
                <div class="rd-form">
                  <div class="rd-input-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <input type="tel" id="rdPhone" placeholder="Ditt mobilnummer" autocomplete="tel" />
                  </div>
                  <button type="button" class="rd-send-btn" id="rdSendBtn" data-car-name={car.full_name}>
                    Skicka till mig
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                  </button>
                </div>
                <p class="rd-privacy">Vi behandlar dina uppgifter enligt GDPR. Inga spam — bara det du bett om.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Car Info -->
        <div class="car-info">
          <div class="car-info-inner">
            <div class="badge-row">
              <span class="badge-stock">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                I lager
              </span>
              <span class="badge-location">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Begbilnorr Luleå
              </span>
            </div>

            <h1>{car.full_name}</h1>
            <div class="car-year">Årsmodell {car.year} &middot; {car.reg_no}</div>
            {car.is_vat_deductible && (
              <div class="vat-line">Moms avdragsgill · {formatPriceExVat(car.price)} ex. moms</div>
            )}
            <div class="car-price">{formatPrice(car.price)}</div>
            <div class="car-monthly">från <span>{monthly}</span></div>

            <!-- Prisberäknare / Finansiering -->
            <button class="finance-modal-trigger" data-calc-trigger type="button" data-price={car.price} data-name={car.full_name}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>
              Beräkna månadskostnad
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>

            <div class="car-buttons">
              <button class="btn-primary" id="contactBtn" data-car-name={car.full_name} data-car-slug={car.slug}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Intresserad? Kontakta oss
              </button>
              <a href={`https://wa.me/46727448034?text=Hej! Jag är intresserad av ${car.full_name} (${car.reg_no})`} class="btn-outline" target="_blank" rel="noopener">
                <svg viewBox="0 0 448 512" width="18" height="18" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
                WhatsApp
              </a>
              <a href="tel:+4692099986" class="btn-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Ring 0920-999 86
              </a>
            </div>

            <div class="specs-grid">
              <div class="spec-item">
                <span class="spec-label">Miltal</span>
                <span class="spec-value">{formatMileage(car.mileage)}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Årsmodell</span>
                <span class="spec-value">{car.year}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Drivmedel</span>
                <span class="spec-value">{car.fuel_type}</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">Växellåda</span>
                <span class="spec-value">{car.gearbox}</span>
              </div>
              {car.body_type && (
                <div class="spec-item">
                  <span class="spec-label">Karosseri</span>
                  <span class="spec-value">{car.body_type}</span>
                </div>
              )}
              <div class="spec-item">
                <span class="spec-label">Reg.nr</span>
                <span class="spec-value">{car.reg_no}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Description -->
      {car.description && (
        <div class="specifications-section">
          <h2>Beskrivning</h2>
          <div class="specifications-text" set:html={car.description.replace(/\n/g, '<br />')} />
        </div>
      )}


      <!-- Equipment -->
      {car.equipment?.length > 0 && (
        <div class="equipment-section">
          <h2>Utrustning</h2>
          <div class="equipment-grid">
            {car.equipment.map((item) => (
              <div class="equipment-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Related Cars -->
      {relatedCars.length > 0 && (
        <div class="description-section" style="margin-top:64px;">
          <h2>Liknande bilar</h2>
          <div class="car-grid">
            {relatedCars.map((rc) => <CarCard car={rc} />)}
          </div>
        </div>
      )}
    </div>
  </section>

</Layout>

<style>
  .breadcrumb-bar {
    padding: 16px 0;
    background: var(--bg-dark-3);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* Finance Modal Trigger Button */
  .finance-modal-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    margin-bottom: 24px;
    background: rgba(230,46,45,0.08);
    border: 1px solid rgba(230,46,45,0.15);
    border-radius: 8px;
    color: var(--red-light);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--sans);
  }
  .finance-modal-trigger:hover {
    background: rgba(230,46,45,0.14);
    border-color: rgba(230,46,45,0.3);
  }
  .finance-modal-trigger svg:last-child {
    margin-left: auto;
  }

  /* Request Details CTA */
  .request-details-card {
    position: relative;
    margin-top: 24px;
    border-radius: 16px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(230,46,45,0.06) 0%, rgba(20,20,20,1) 50%, rgba(230,46,45,0.04) 100%);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .rd-glow {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--red), transparent);
    opacity: 0.8;
  }
  .rd-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    padding: 28px 24px;
  }
  .rd-visual {
    flex-shrink: 0;
  }
  .rd-icon-stack {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .rd-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
  }
  .rd-icon-camera {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--red), #ff5a59);
    color: #fff;
    box-shadow: 0 8px 24px rgba(230,46,45,0.35);
  }
  .rd-icon-doc {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.12);
  }
  .rd-content {
    flex: 1;
    min-width: 0;
  }
  .rd-title {
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .rd-subtitle {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    margin: 0 0 20px;
  }
  .rd-checklist {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
    margin-bottom: 24px;
  }
  .rd-check-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }
  .rd-check-item svg {
    color: var(--red-light);
    flex-shrink: 0;
  }
  .rd-form {
    display: flex;
    gap: 10px;
    max-width: 460px;
    width: 100%;
    margin: 0 auto;
  }
  .rd-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    transition: border-color 0.2s;
  }
  .rd-input-wrap:focus-within {
    border-color: var(--red);
    background: rgba(255,255,255,0.08);
  }
  .rd-input-wrap svg {
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }
  .rd-input-wrap input {
    flex: 1;
    background: none;
    border: none;
    color: #fff;
    font-size: 14px;
    padding: 13px 0;
    outline: none;
    font-family: var(--sans);
  }
  .rd-input-wrap input::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .rd-send-btn {
    padding: 13px 24px;
    background: var(--red);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
    font-family: var(--sans);
  }
  .rd-send-btn:hover {
    background: var(--red-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(230,46,45,0.3);
  }
  .rd-send-btn svg {
    transform: rotate(90deg);
  }
  .rd-privacy {
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    margin: 12px 0 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .rd-inner {
      padding: 28px 20px;
    }
    .rd-title {
      font-size: 18px;
    }
    .rd-form {
      flex-direction: column;
    }
    .rd-send-btn {
      justify-content: center;
    }
  }
</style>

<script>
  document.getElementById('contactBtn')?.addEventListener('click', () => {
    const btn = document.getElementById('contactBtn') as HTMLElement;
    window.dispatchEvent(
      new CustomEvent('open-contact-modal', {
        detail: {
          carName: btn.dataset.carName || '',
          carSlug: btn.dataset.carSlug || '',
        },
      })
    );
  });

  // Gallery navigation
  const galleryMain = document.getElementById('galleryMain') as HTMLElement;
  const mainImg = document.querySelector('#mainImage') as HTMLImageElement;
  const galleryImages: string[] = galleryMain ? JSON.parse(galleryMain.dataset.images || '[]') : [];
  let currentIdx = 0;

  function goToImage(idx: number) {
    if (!mainImg || galleryImages.length === 0) return;
    currentIdx = (idx + galleryImages.length) % galleryImages.length;
    mainImg.src = galleryImages[currentIdx];
    const carName = galleryMain?.dataset.carName || '';
    mainImg.alt = `${carName} — bild ${currentIdx + 1} av ${galleryImages.length}`;
    document.querySelectorAll('.gallery-thumb').forEach((t) => t.classList.remove('active'));
    const activeThumb = document.querySelector(`.gallery-thumb[data-index="${currentIdx}"]`);
    activeThumb?.classList.add('active');
    activeThumb?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    const counter = document.getElementById('currentIndex');
    if (counter) counter.textContent = String(currentIdx + 1);
  }

  document.getElementById('galleryPrev')?.addEventListener('click', (e) => {
    e.preventDefault();
    goToImage(currentIdx - 1);
  });

  document.getElementById('galleryNext')?.addEventListener('click', (e) => {
    e.preventDefault();
    goToImage(currentIdx + 1);
  });

  document.querySelectorAll('.gallery-thumb').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const idx = parseInt((thumb as HTMLElement).dataset.index || '0', 10);
      goToImage(idx);
    });
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goToImage(currentIdx - 1);
    if (e.key === 'ArrowRight') goToImage(currentIdx + 1);
  });

  // Request Details CTA
  const rdSendBtn = document.getElementById('rdSendBtn');
  rdSendBtn?.addEventListener('click', () => {
    const phone = (document.getElementById('rdPhone') as HTMLInputElement)?.value?.trim();
    if (!phone) {
      const input = document.getElementById('rdPhone') as HTMLInputElement;
      input?.focus();
      const wrap = input?.closest('.rd-input-wrap') as HTMLElement;
      if (wrap) {
        wrap.style.borderColor = '#E62E2D';
        setTimeout(() => { wrap.style.borderColor = ''; }, 2000);
      }
      return;
    }
    const carName = (rdSendBtn as HTMLElement).dataset.carName || '';
    window.dispatchEvent(
      new CustomEvent('open-contact-modal', {
        detail: { carName, carSlug: '' }
      })
    );
  });
</script>
