---
import Layout from '../components/Layout.astro';
import CityCarPage from '../components/CityCarPage.astro';

const city = {
  name: 'Piteå',
  slug: 'pitea',
  distance: '55 km',
  driveTime: 'ca 45 min',
  description: 'Piteå ligger bara 55 kilometer från Luleå och vi levererar bilar hem till dig regelbundet. Du behöver inte ta ledigt från jobbet för att åka och titta på bil — vi kommer till dig i Piteå med bilen så du kan provköra den i lugn och ro. Många kunder i Piteå har köpt bil hos oss helt digitalt med hemleverans.',
  seoIntro: 'Letar du efter en begagnad bil i Piteå? Begbilnorr levererar kvalitetskontrollerade begagnade bilar med garanti direkt hem till dig i Piteå. Du behöver inte åka till Luleå — vi kommer till dig med provkörning, finansiering och personlig service. 55 km bort men vi kör gärna ut till dig.',
  deliveryText: 'Bor du i Piteå? Vi kör ut bilen till dig för provkörning — cirka 45 minuter bort. Prova bilen hemma i lugn och ro, och vi levererar sedan i hela Sverige.',
  localText: 'Begbilnorr har många nöjda kunder i Piteå som köpt bil med hemleverans. Piteå är en av de kommuner vi betjänar mest — med regelbundna leveranser hela året. Oavsett om du bor centralt i Piteå eller i någon av kommunens mindre orter så levererar vi gärna din bil hem till dig.',
};
---

<Layout
  title="Begagnade bilar i Piteå — Hemleverans från Begbilnorr"
  description="Köp begagnad bil i Piteå — provkör hemma hos dig! Begbilnorr kör ut bilen till Piteå för provkörning. Garanti, finansiering och leverans i hela Sverige."
>
  <CityCarPage city={city} />
</Layout>
