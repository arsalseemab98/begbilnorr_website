---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Besiktnings-kollare | När ska bilen besiktas? — Begbilnorr"
  description="När ska din bil besiktas? Räkna ut nästa besiktningsdatum baserat på registreringsdatum och bilens ålder. Gäller personbilar i Sverige."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
        BESIKTNING-KOLLARE
      </div>
      <h1>När ska bilen besiktas?</h1>
      <p>Räkna ut besiktningsperioden baserat på registreringsdatum. Gäller personbilar (klass I) i Sverige.</p>
      <div class="hero-line"></div>
    </div>
  </section>

  <section class="tool-section">
    <div class="container">
      <div class="tool-card">
        <div class="tool-grid">
          <div class="tool-inputs">
            <h2 class="tool-h2">Din bil</h2>

            <div class="input-group">
              <label for="regDate">Datum för första registrering</label>
              <input type="date" id="regDate" class="tool-input" />
              <small class="input-hint">Står på registreringsbeviset. Påverkar besiktningsperioden.</small>
            </div>

            <div class="input-group">
              <label for="lastInspection">Senaste besiktningsdatum (valfritt)</label>
              <input type="date" id="lastInspection" class="tool-input" />
              <small class="input-hint">Om du nyligen besiktat — ange för exakt nästa datum.</small>
            </div>

            <button id="calculateBtn" class="btn-primary tool-btn">Räkna ut besiktningsperiod</button>
          </div>

          <div class="tool-results" id="results">
            <div class="result-placeholder" id="placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <p>Fyll i registreringsdatum för att se besiktningsperioden</p>
            </div>

            <div class="result-content" id="resultContent" style="display:none;">
              <div class="result-label">Nästa besiktningsperiod</div>
              <div class="result-main" id="periodMain">—</div>
              <div class="result-suffix" id="periodSuffix">—</div>

              <div class="result-divider"></div>

              <div class="result-row">
                <span class="row-label">Bilens ålder</span>
                <span class="row-value" id="ageValue">—</span>
              </div>
              <div class="result-row">
                <span class="row-label">Besiktningsintervall</span>
                <span class="row-value" id="intervalValue">—</span>
              </div>
              <div class="result-row">
                <span class="row-label">Sista besiktningsdag</span>
                <span class="row-value" id="deadlineValue">—</span>
              </div>

              <div class="flex-tip" id="tipBox">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <div id="tipText">
                  <strong>Tips:</strong> Besikta tidigt — om du missar perioden får bilen körförbud.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="disclaimer">
        <p>⚠️ Estimat baserat på generella regler för personbil klass I. För exakt datum — kolla Transportstyrelsens "Mina sidor" eller besiktningsbevis. A-traktorer, släp, taxi m.fl. har egna regler.</p>
      </div>
    </div>
  </section>

  <section class="info-section">
    <div class="container">
      <h2 class="section-heading" style="text-align:center;margin-bottom:48px;">Så fungerar besiktningsreglerna</h2>
      <div class="info-grid">
        <div class="info-card">
          <div class="step-number">1</div>
          <h3>Första besiktningen</h3>
          <p>Senast 3 år efter första registrering. Nya bilar slipper besikta år 1–3.</p>
        </div>
        <div class="info-card">
          <div class="step-number">2</div>
          <h3>Andra besiktningen</h3>
          <p>2 år efter första besiktningen. Bilar 3–5 år gamla besiktas vartannat år.</p>
        </div>
        <div class="info-card">
          <div class="step-number">3</div>
          <h3>Årlig besiktning</h3>
          <p>När bilen är 5+ år gammal: besiktning varje år. Perioden bestäms av registreringsdatumets sista siffra.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container" style="text-align:center;">
      <h2>Letar du bil med fräsch besiktning?</h2>
      <p>Alla våra bilar är besiktigade och godkända — så slipper du oroa dig första året.</p>
      <div class="cta-buttons">
        <a href="/bilar" class="btn-primary">Se våra bilar</a>
        <a href="/kontakt" class="btn-outline">Kontakta oss</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tool-section {
    background: var(--bg-dark-3);
    padding: 80px 0 40px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .tool-card {
    max-width: 980px;
    margin: 0 auto;
    background: var(--bg-dark-4);
    border-radius: 12px;
    padding: 48px 40px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .tool-h2 {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 24px;
  }

  .tool-inputs {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .input-group label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .input-hint {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin-top: 2px;
  }

  .tool-input {
    background: var(--bg-dark-5);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 12px 14px;
    color: var(--white);
    font-family: var(--sans);
    font-size: 15px;
    color-scheme: dark;
    transition: border-color 0.2s;
  }

  .tool-input:focus {
    outline: none;
    border-color: var(--red);
  }

  .tool-btn {
    margin-top: 8px;
    width: 100%;
    justify-content: center;
  }

  .tool-results {
    background: var(--bg-dark-5);
    border-radius: 12px;
    padding: 36px 32px;
    border: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .result-placeholder {
    text-align: center;
    color: rgba(255,255,255,0.3);
    padding: 40px 0;
  }

  .result-placeholder svg {
    margin: 0 auto 16px;
    display: block;
  }

  .result-placeholder p {
    font-size: 15px;
  }

  .result-label {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .result-main {
    font-size: 32px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.5px;
    line-height: 1.2;
  }

  .result-suffix {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
    margin-bottom: 24px;
  }

  .result-divider {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-bottom: 20px;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .result-row .row-label {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
  }

  .result-row .row-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
  }

  .flex-tip {
    display: flex;
    gap: 12px;
    background: rgba(46, 204, 113, 0.08);
    border: 1px solid rgba(46, 204, 113, 0.2);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 20px;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
  }

  .flex-tip svg {
    flex-shrink: 0;
    color: #2ecc71;
    margin-top: 2px;
  }

  .flex-tip strong {
    color: #2ecc71;
  }

  .disclaimer {
    max-width: 820px;
    margin: 24px auto 0;
    padding: 16px 20px;
    background: rgba(255,255,255,0.03);
    border-left: 3px solid rgba(255,255,255,0.2);
    border-radius: 4px;
  }

  .disclaimer p {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin: 0;
  }

  .info-section {
    background: var(--bg-dark-2);
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .info-card {
    background: var(--bg-dark-4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 40px 28px 32px;
    position: relative;
    text-align: center;
  }

  .step-number {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 32px;
    background: var(--red);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
  }

  .info-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 14px;
  }

  .info-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  .cta-section {
    background: var(--bg-dark-3);
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .cta-section h2 {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 12px;
  }

  .cta-section p {
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
    .tool-card {
      padding: 32px 20px;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script is:inline>
  (function() {
    var MONTHS_SV = ['januari','februari','mars','april','maj','juni','juli','augusti','september','oktober','november','december'];

    function formatDate(d) {
      return d.getDate() + ' ' + MONTHS_SV[d.getMonth()] + ' ' + d.getFullYear();
    }

    function addYears(d, years) {
      var nd = new Date(d.getTime());
      nd.setFullYear(nd.getFullYear() + years);
      return nd;
    }

    function addMonths(d, months) {
      var nd = new Date(d.getTime());
      nd.setMonth(nd.getMonth() + months);
      return nd;
    }

    function diffYears(d1, d2) {
      var diff = (d2 - d1) / (1000 * 60 * 60 * 24 * 365.25);
      return diff;
    }

    function calculate() {
      var regDateStr = document.getElementById('regDate').value;
      var lastStr = document.getElementById('lastInspection').value;

      if (!regDateStr) {
        alert('Fyll i registreringsdatum');
        return;
      }

      var regDate = new Date(regDateStr);
      var now = new Date();
      var age = diffYears(regDate, now);

      var firstInspectionDate = addYears(regDate, 3);
      var nextDate, intervalText, tip;
      var deadlineDate;

      if (lastStr) {
        // Använd senaste besiktning som bas
        var lastDate = new Date(lastStr);
        var ageAtLast = diffYears(regDate, lastDate);
        if (ageAtLast >= 5) {
          nextDate = addYears(lastDate, 1);
          intervalText = 'Varje år';
        } else if (ageAtLast >= 3) {
          nextDate = addYears(lastDate, 2);
          intervalText = 'Vartannat år';
        } else {
          nextDate = firstInspectionDate;
          intervalText = 'Första besiktning vid 3 år';
        }
      } else if (age < 3) {
        nextDate = firstInspectionDate;
        intervalText = 'Första besiktning vid 3 år';
      } else if (age < 5) {
        nextDate = addYears(firstInspectionDate, 2);
        intervalText = 'Vartannat år';
      } else {
        // 5+ år: årlig besiktning baserat på sista siffran i regnr
        nextDate = addYears(now, 0);
        nextDate.setMonth(now.getMonth() + 1);
        intervalText = 'Varje år';
      }

      // Period: 6 månader bakåt + 2 månader framåt från slutmånaden ger besiktningsperioden
      var periodStart = addMonths(nextDate, -5);
      var periodEnd = nextDate;
      deadlineDate = addMonths(nextDate, 1); // sista dag i månaden + 1
      deadlineDate.setDate(0); // sätt till sista dagen i månaden innan

      var inPeriodNow = now >= periodStart && now <= deadlineDate;

      // Display
      document.getElementById('placeholder').style.display = 'none';
      document.getElementById('resultContent').style.display = 'block';

      document.getElementById('periodMain').textContent = formatDate(periodStart) + ' – ' + formatDate(deadlineDate);
      document.getElementById('periodSuffix').textContent = inPeriodNow ? 'Besiktningsperioden pågår NU' : 'Nästa besiktningsperiod';

      var ageStr = Math.floor(age) + ' år';
      if (age < 1) ageStr = Math.floor(age * 12) + ' månader';
      document.getElementById('ageValue').textContent = ageStr;
      document.getElementById('intervalValue').textContent = intervalText;
      document.getElementById('deadlineValue').textContent = formatDate(deadlineDate);

      if (inPeriodNow) {
        tip = '<strong>Boka besiktning nu!</strong> Du är inne i besiktningsperioden. Senaste dag är ' + formatDate(deadlineDate) + '. Efter det får bilen körförbud.';
      } else if (age < 3) {
        tip = '<strong>Ny bil:</strong> Du behöver inte besikta förrän vid 3 års ålder. Första besiktning: ' + formatDate(firstInspectionDate) + '.';
      } else {
        tip = '<strong>Tips:</strong> Boka senast 2 veckor innan slutdatumet — verkstäderna är ofta fullbokade i slutet av perioden.';
      }
      document.getElementById('tipText').innerHTML = tip;
    }

    document.getElementById('calculateBtn').addEventListener('click', calculate);
  })();
</script>
