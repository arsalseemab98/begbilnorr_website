---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import StructuredData from '../components/StructuredData.astro';
import CarCard from '../components/CarCard.astro';
import { supabase } from '../lib/supabase';
import type { Car } from '../types/car';

const { data: cars } = await supabase
  .from('cars')
  .select('*')
  .eq('is_active', true)
  .eq('is_sold', false)
  .order('created_at', { ascending: false })
  .limit(6);

const latestCars = (cars || []) as Car[];

const dealerSchema = {
  "@context": "https://schema.org",
  "@type": ["AutoDealer", "LocalBusiness"],
  "name": "Begbilnorr",
  "description": "Begbilnorr erbjuder kvalitetskontrollerade begagnade bilar med garanti i Luleå.",
  "url": "https://begbilnorr.se",
  "logo": "https://begbilnorr.se/wp-content/uploads/2024/11/cropped-begbilnorr_Logo_-_E-2__1_-removebg-preview.png",
  "telephone": "+46920-99986",
  "email": "info@begbilnorr.se",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Luleå",
    "addressRegion": "Norrbotten",
    "addressCountry": "SE"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 65.5848, "longitude": 22.1547 },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "15:00" }
  ],
  "priceRange": "$$",
  "currenciesAccepted": "SEK",
  "sameAs": ["https://www.facebook.com/begbilnorr", "https://www.instagram.com/begbilnorr"]
};
---

<Layout
  title="Begbilnorr – Begagnade bilar i Luleå | Tryggt bilköp med garanti"
  description="Köp begagnade bilar i Luleå hos Begbilnorr. Kvalitetskontrollerade bilar med garanti, finansiering och hemleverans. Din trygga bilhandlare i Norrbotten."
>
  <Fragment slot="head">
    <StructuredData data={dealerSchema} />
  </Fragment>

  <Hero />

  <section class="action-section">
    <div class="container">
      <h2>Hur kan vi hjälpa dig?</h2>
      <div class="action-buttons">
        <a href="/bilar" class="action-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          Köpa bil
        </a>
        <a href="/salj-bil" class="action-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
          Sälja bil
        </a>
        <a href="/kontakt" class="action-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
          Boka provkörning
        </a>
      </div>
    </div>
  </section>

  <section class="carousel-section">
    <div class="container">
      <div class="carousel-header">
        <h2>Våra senast inkomna bilar</h2>
      </div>
      <div class="car-grid" style="padding-bottom: 0;">
        {latestCars.map((car) => <CarCard car={car} />)}
      </div>
    </div>
  </section>

  <div class="full-inventory">
    <div class="container">
      <a href="/bilar" class="outline-btn">
        Hela sortimentet
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <section class="services-section">
    <div class="container">
      <h2>Våra tjänster</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
          </div>
          <h3>Finansiering</h3>
          <p>Förmånlig finansiering med snabbt lånebesked. Vi samarbetar med flera banker för att hitta den bästa lösningen för dig.</p>
        </div>
        <div class="service-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          </div>
          <h3>Inbytesvärdering</h3>
          <p>Få rättvist pris för din nuvarande bil. Vi ger dig ett snabbt och ärligt bud direkt på plats eller digitalt.</p>
        </div>
        <div class="service-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          </div>
          <h3>Hemleverans</h3>
          <p>Vi levererar bilen hem till dig. Köp tryggt på distans och få din nya bil levererad till dörren, i hela Sverige.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:var(--gray-light)"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
        <div class="about-content">
          <h2>Om Begbilnorr</h2>
          <p>Vi är en lokal bilhandlare i Luleå med passion för att leverera kvalitetsbilar till rättvisa priser. Sedan 2010 har vi hjälpt kunder i hela Norrbotten att hitta sin nästa bil — med trygghet, garanti och personlig service.</p>
          <div class="about-facts">
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div class="fact-text">14 års erfarenhet av bilförsäljning</div>
            </div>
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
              </div>
              <div class="fact-text">150+ bilar sålda per år</div>
            </div>
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div class="fact-text">Garanti på alla fordon</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
