---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import StructuredData from '../components/StructuredData.astro';
import CarCard from '../components/CarCard.astro';
import { supabase } from '../lib/supabase';
import type { Car } from '../types/car';

let latestCars: Car[] = [];
try {
  const { data: cars } = await supabase
    .from('cars')
    .select('*')
    .eq('is_active', true)
    .eq('is_sold', false)
    .order('created_at', { ascending: false })
    .limit(6);
  latestCars = (cars || []) as Car[];
} catch {
  // Supabase not configured — show empty
}

const dealerSchema = {
  "@context": "https://schema.org",
  "@type": ["AutoDealer", "LocalBusiness"],
  "name": "Begbilnorr",
  "alternateName": "Begbilnorr AB",
  "description": "Begbilnorr erbjuder kvalitetskontrollerade begagnade bilar med garanti i Luleå. Din trygga bilhandlare i Norrbotten sedan 2010.",
  "url": "https://begbilnorr.se",
  "logo": "https://begbilnorr.se/images/begbilnorr-logo.webp",
  "image": "https://begbilnorr.se/images/og-hero.png",
  "telephone": "+46920-99986",
  "email": "info@begbilnorr.se",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Luleå",
    "addressLocality": "Luleå",
    "addressRegion": "Norrbotten",
    "postalCode": "97232",
    "addressCountry": "SE"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 65.5848, "longitude": 22.1547 },
  "areaServed": [
    { "@type": "City", "name": "Luleå" },
    { "@type": "City", "name": "Boden" },
    { "@type": "City", "name": "Piteå" },
    { "@type": "City", "name": "Älvsbyn" },
    { "@type": "City", "name": "Kalix" },
    { "@type": "AdministrativeArea", "name": "Norrbotten" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "15:00" }
  ],
  "priceRange": "$$",
  "currenciesAccepted": "SEK",
  "paymentAccepted": "Kontant, Swish, Bankgiro, Finansiering",
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 3 },
  "foundingDate": "2010",
  "slogan": "Luleås tryggaste bilhandlare",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Begagnade bilar",
    "itemListElement": latestCars.slice(0, 3).map((car) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Car",
        "name": car.full_name,
        "brand": { "@type": "Brand", "name": car.brand },
        "vehicleModelDate": String(car.year),
        "mileageFromOdometer": { "@type": "QuantitativeValue", "value": car.mileage, "unitCode": "SMI" },
        "url": `https://begbilnorr.se/bilar/${car.slug}`
      },
      "price": car.price,
      "priceCurrency": "SEK"
    }))
  },
  "sameAs": ["https://www.facebook.com/begbilnorr", "https://www.instagram.com/begbilnorr", "https://www.tiktok.com/@begbilnorr"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Har ni garanti på begagnade bilar?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, alla bilar vi säljer på Begbilnorr i Luleå levereras med garanti. Vi kvalitetskontrollerar varje fordon noggrant innan försäljning för att säkerställa att du får en trygg och pålitlig bil." }
    },
    {
      "@type": "Question",
      "name": "Kan jag finansiera mitt bilköp?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolut! Vi samarbetar med flera banker och erbjuder flexibla finansieringslösningar med snabbt lånebesked. Du kan beräkna din månadskostnad direkt på varje bilsida." }
    },
    {
      "@type": "Question",
      "name": "Erbjuder ni hemleverans av bilar?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, vi levererar bilar till hela Sverige. Oavsett var du bor kan du köpa din bil på distans och få den levererad hem till dörren." }
    },
    {
      "@type": "Question",
      "name": "Kan jag byta in min nuvarande bil?",
      "acceptedAnswer": { "@type": "Answer", "text": "Självklart! Vi erbjuder kostnadsfri värdering och inbyte av din nuvarande bil. Kontakta oss för en snabb och rättvis värdering." }
    },
    {
      "@type": "Question",
      "name": "Var ligger Begbilnorr?",
      "acceptedAnswer": { "@type": "Answer", "text": "Vi finns i Luleå, Norrbotten. Vi betjänar kunder i hela Norrbottens län inklusive Boden, Piteå, Kalix och Älvsbyn. Välkommen att besöka oss eller ring 0920-999 86." }
    }
  ]
};
---

<Layout
  title="Begbilnorr – Begagnade bilar i Luleå | Tryggt bilköp med garanti"
  description="Köp begagnade bilar i Luleå hos Begbilnorr. Kvalitetskontrollerade bilar med garanti, finansiering och hemleverans. Din trygga bilhandlare i Norrbotten."
>
  <Fragment slot="head">
    <StructuredData data={dealerSchema} />
    <StructuredData data={faqSchema} />
    <script is:inline>
      (function(){var s=document.createElement('script');s.src='https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';s.async=true;s.onload=function(){document.dispatchEvent(new Event('three-loaded'));};document.head.appendChild(s);})();
    </script>
  </Fragment>

  <Hero />

  <!-- SENAST INKOMNA BILAR -->
  <section class="cars-section">
    <div class="container">
      <div class="section-label fade-up">VÅRT LAGER</div>
      <h2 class="section-heading fade-up">Senast inkomna bilar</h2>

      <!-- Desktop: show all 6, Mobile: show 3 -->
      <div class="car-grid">
        {latestCars.map((car, i) => (
          <div class:list={['car-grid-item', { 'mobile-hidden': i >= 3 }]}>
            <CarCard car={car} />
          </div>
        ))}
      </div>

      <div class="cars-section-footer fade-up">
        <a href="/bilar" class="see-all-btn">
          Se alla bilar
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/begagnade-bilar-lulea" class="see-all-link">Begagnade bilar i Luleå</a>
      </div>
    </div>
  </section>

  <!-- VARFÖR BEGBILNORR -->
  <section class="why-section">
    <div class="container">
      <div class="section-label fade-up" style="text-align:center;">VARFÖR VÄLJA OSS</div>
      <h2 class="section-heading fade-up" style="text-align:center;margin-bottom:16px;">Varför Begbilnorr?</h2>
      <p class="why-subtitle fade-up">Vi gör bilköpet enkelt, tryggt och personligt. Här är vad som skiljer oss från mängden.</p>

      <div class="why-grid">
        <div class="why-card fade-up">
          <div class="why-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3>Garanti på alla bilar</h3>
          <p>Varje bil säljs med garanti så att du kan köra med trygghet från dag ett.</p>
        </div>

        <div class="why-card fade-up">
          <div class="why-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
          </div>
          <h3>Enkel finansiering</h3>
          <p>Förmånliga vilkor genom våra bankpartners. Snabbt lånebesked och flexibla lösningar.</p>
        </div>

        <div class="why-card fade-up">
          <div class="why-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          </div>
          <h3>Hemleverans</h3>
          <p>Köp din bil på distans och få den levererad hem till dörren, var du än bor i Sverige.</p>
        </div>

        <div class="why-card fade-up">
          <div class="why-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          </div>
          <h3>Inbyte & värdering</h3>
          <p>Få en rättvis värdering på din nuvarande bil. Enkel inbytesprocess direkt hos oss.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OM BEGBILNORR — hidden on mobile, too much scroll -->
  <section class="about-cta-section">
    <div class="container">
      <div class="about-cta-grid">
        <div class="about-cta-content fade-up">
          <div class="section-label">OM BEGBILNORR</div>
          <h2>Lokalt förankrad, personligt engagerad</h2>
          <p>Vi är en lokal bilhandlare i Luleå med passion för att leverera kvalitetsbilar till rättvisa priser. Sedan 2010 har vi hjälpt kunder i hela Norrbotten att hitta sin nästa bil.</p>

          <div class="about-facts">
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div class="fact-text">10+ års erfarenhet av bilförsäljning</div>
            </div>
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
              </div>
              <div class="fact-text">300+ bilar sålda per år</div>
            </div>
            <div class="about-fact">
              <div class="fact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div class="fact-text">Garanti på alla fordon</div>
            </div>
          </div>

          <a href="/om-oss" class="about-cta-btn">
            Läs mer om oss
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="about-cta-image" style="overflow:hidden;">
          <img src="/images/showroom.webp" alt="Begbilnorr showroom med begagnade bilar i Luleå" width="900" height="1200" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-lg);" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION — show only 3 on mobile -->
  <section class="faq-section">
    <div class="container">
      <div class="section-label fade-up" style="text-align:center;">VANLIGA FRÅGOR</div>
      <h2 class="section-heading fade-up" style="text-align:center;margin-bottom:48px;">Vanliga frågor om att köpa begagnad bil</h2>
      <div class="faq-list">
        <details class="faq-item fade-up">
          <summary>Har ni garanti på begagnade bilar?</summary>
          <div class="faq-answer">Ja, alla bilar vi säljer på Begbilnorr i Luleå levereras med garanti. Vi kvalitetskontrollerar varje fordon noggrant innan försäljning för att säkerställa att du får en trygg och pålitlig bil.</div>
        </details>
        <details class="faq-item fade-up">
          <summary>Kan jag finansiera mitt bilköp?</summary>
          <div class="faq-answer">Absolut! Vi samarbetar med flera banker och erbjuder flexibla finansieringslösningar med snabbt lånebesked. Du kan beräkna din månadskostnad direkt på varje bilsida.</div>
        </details>
        <details class="faq-item fade-up">
          <summary>Erbjuder ni hemleverans av bilar?</summary>
          <div class="faq-answer">Ja, vi levererar bilar till hela Sverige. Oavsett var du bor kan du köpa din bil på distans och få den levererad hem till dörren.</div>
        </details>
        <details class="faq-item fade-up faq-extra">
          <summary>Kan jag byta in min nuvarande bil?</summary>
          <div class="faq-answer">Självklart! Vi erbjuder kostnadsfri värdering och inbyte av din nuvarande bil. Kontakta oss för en snabb och rättvis värdering.</div>
        </details>
        <details class="faq-item fade-up faq-extra">
          <summary>Var ligger Begbilnorr?</summary>
          <div class="faq-answer">Vi finns i Luleå, Norrbotten. Vi betjänar kunder i hela Norrbottens län inklusive Boden, Piteå, Kalix och Älvsbyn. Välkommen att besöka oss eller ring 0920-999 86.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- GOOGLE REVIEWS -->
  <section class="reviews-section">
    <div class="container">
      <div class="section-label fade-up" style="text-align:center;">KUNDRECENSIONER</div>
      <h2 class="section-heading fade-up" style="text-align:center;margin-bottom:16px;">Vad våra kunder säger</h2>
      <div class="reviews-rating fade-up">
        <div class="reviews-stars">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <span class="reviews-score">5.0 på Google</span>
      </div>

      <div class="reviews-grid fade-up">
        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">S</div>
            <div>
              <div class="review-name">Stefan L.</div>
              <div class="review-stars">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
            </div>
          </div>
          <p class="review-text">"Fantastisk service! Köpte en Volvo V60 och hela processen var smidig. Anton var professionell och hjälpsam. Rekommenderar starkt!"</p>
          <div class="review-source">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Google Review
          </div>
        </div>

        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">M</div>
            <div>
              <div class="review-name">Maria K.</div>
              <div class="review-stars">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
            </div>
          </div>
          <p class="review-text">"Bästa bilhandlaren i Luleå! Fick en rättvis värdering på min gamla bil och hittade en perfekt ersättare. Snabb och enkel process."</p>
          <div class="review-source">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Google Review
          </div>
        </div>

        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">J</div>
            <div>
              <div class="review-name">Jonas A.</div>
              <div class="review-stars">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
