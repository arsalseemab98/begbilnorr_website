---
import Layout from '../components/Layout.astro';
import CityCarPage from '../components/CityCarPage.astro';

const city = {
  name: 'Boden',
  slug: 'boden',
  distance: '35 km',
  driveTime: 'ca 30 min',
  description: 'Boden ligger bara 35 kilometer från Luleå, vilket gör det enkelt för oss att leverera bilar direkt hem till dig. Du slipper åka till Luleå — vi kommer till dig med bilen, redo för provkörning och leverans. Många av våra nöjdaste kunder bor i Boden och har köpt bil helt utan att lämna hemmet.',
  seoIntro: 'Letar du efter en begagnad bil i Boden? Du behöver inte åka till Luleå — Begbilnorr levererar kvalitetskontrollerade begagnade bilar med garanti direkt hem till dig i Boden. Vi erbjuder provkörning på plats, digital finansiering och personlig service. Bara 35 km bort men vi kör gärna till dig.',
  deliveryText: 'Bor du i Boden? Vi levererar din nya bil direkt hem till dörren. Bara 30 minuter bort — vi kör ut bilen för provkörning och leverans utan extra kostnad. Allt pappersarbete kan skötas digitalt.',
  localText: 'Begbilnorr har hjälpt hundratals kunder i Boden att hitta sin drömbil utan att behöva åka till Luleå. Vår hemleveransservice gör det enkelt att köpa bil från Boden — vi tar hand om allt från provkörning till leverans. Garnisonstaden Boden är en av våra största marknader, och vi har lång erfarenhet av att betjäna kunder i kommunen.',
};
---

<Layout
  title="Begagnade bilar i Boden — Hemleverans från Begbilnorr"
  description="Köp begagnad bil i Boden med hemleverans från Begbilnorr. Kvalitetskontrollerade bilar med garanti. Vi kommer till dig — du behöver inte åka till Luleå!"
>
  <CityCarPage city={city} />
</Layout>
