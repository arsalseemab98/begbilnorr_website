---
import Layout from '../components/Layout.astro';
import CityCarPage from '../components/CityCarPage.astro';

const city = {
  name: 'Kalix',
  slug: 'kalix',
  distance: '100 km',
  driveTime: 'ca 1 tim',
  description: 'Kalix ligger ungefär 100 kilometer från Luleå, men avståndet spelar ingen roll — vi levererar bilar hem till dig! Du slipper köra 2 timmar tur och retur för att titta på bil. Många kunder i Kalix uppskattar vår hemleveransservice och möjligheten att sköta hela bilköpet på distans.',
  seoIntro: 'Letar du efter en begagnad bil i Kalix? Begbilnorr levererar kvalitetskontrollerade begagnade bilar med garanti direkt hem till dig i Kalix. Du slipper köra till Luleå — vi kommer till dig med bilen. Provkörning hemma hos dig, digital finansiering och personlig service.',
  deliveryText: 'Bor du i Kalix? Ingen anledning att köra 100 km för att titta på bil. Vi kör ut bilen till dig för provkörning — prova den hemma utan press. Leverans i hela Sverige.',
  localText: 'Även om Kalix ligger 100 km från Luleå så betjänar vi regelbundet kunder i kommunen. Vår hemleveransservice gör det smidigt att köpa begagnad bil utan att behöva resa. Vi kan köra ut bilen till dig i Kalix för provkörning, och om du är nöjd slutför vi affären på plats. Många kunder i Kalix har valt oss just för att vi kommer till dem.',
};
---

<Layout
  title="Begagnade bilar i Kalix — Hemleverans från Begbilnorr"
  description="Köp begagnad bil i Kalix — provkör hemma hos dig! Begbilnorr kör ut bilen till Kalix för provkörning. Garanti, finansiering och leverans i hela Sverige."
>
  <CityCarPage city={city} />
</Layout>
