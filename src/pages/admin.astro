</style>

<script>
  // === AUTH ===
  const MAX_ATTEMPTS = 5;
  const LOCKOUT_MINUTES = 15;
  const LOCKOUT_KEY = 'admin_lockout';
  const ATTEMPTS_KEY = 'admin_attempts';
  const SESSION_KEY = 'admin_auth';
  const TOKEN_KEY = 'admin_token';

  function getAuthHeaders(extra: Record<string, string> = {}): Record<string, string> {
    const token = sessionStorage.getItem(TOKEN_KEY) || '';
    return { 'Authorization': `Basic ${token}`, ...extra };
  }
  function authJson(): Record<string, string> {
    return getAuthHeaders({ 'Content-Type': 'application/json' });
  }

  function getAttempts(): number { return parseInt(localStorage.getItem(ATTEMPTS_KEY) || '0', 10); }
  function getLockoutEnd(): number { return parseInt(localStorage.getItem(LOCKOUT_KEY) || '0', 10); }

  function isLockedOut(): boolean {
    const end = getLockoutEnd();
    if (end && Date.now() < end) return true;
    if (end && Date.now() >= end) { localStorage.removeItem(LOCKOUT_KEY); localStorage.removeItem(ATTEMPTS_KEY); }
    return false;
  }

  function lockoutRemaining(): string {
    return `${Math.ceil((getLockoutEnd() - Date.now()) / 60000)} min`;
  }

  const overlay = document.getElementById('loginOverlay')!;
  const adminContent = document.getElementById('adminContent')!;
  const loginForm = document.getElementById('loginForm') as HTMLFormElement;
  const loginError = document.getElementById('loginError')!;
  const loginLocked = document.getElementById('loginLocked')!;
  const loginBtn = document.getElementById('loginBtn') as HTMLButtonElement;

  if (sessionStorage.getItem(SESSION_KEY) === 'authenticated') {
    overlay.classList.add('hidden');
    adminContent.style.display = '';
  }

  function updateLockoutUI() {
    if (isLockedOut()) {
      loginBtn.disabled = true;
      loginLocked.textContent = `Kontot är låst. Försök igen om ${lockoutRemaining()}.`;
    } else {
      loginBtn.disabled = false;
      loginLocked.textContent = '';
    }
  }
  updateLockoutUI();

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.textContent = '';
    if (isLockedOut()) { updateLockoutUI(); return; }
    const user = (document.getElementById('loginUser') as HTMLInputElement).value.trim();
    const pass = (document.getElementById('loginPass') as HTMLInputElement).value;
    loginBtn.disabled = true; loginBtn.textContent = 'Loggar in...';
    try {
      const res = await fetch('/api/admin-auth', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: user, password: pass }),
      });
      if (res.ok) {
        sessionStorage.setItem(SESSION_KEY, 'authenticated');
        sessionStorage.setItem(TOKEN_KEY, btoa(user + ':' + pass));
        localStorage.removeItem(ATTEMPTS_KEY);
        localStorage.removeItem(LOCKOUT_KEY);
        overlay.classList.add('hidden');
        adminContent.style.display = '';
        initAdmin();
      } else {
        const attempts = getAttempts() + 1;
        localStorage.setItem(ATTEMPTS_KEY, String(attempts));
        if (attempts >= MAX_ATTEMPTS) {
          localStorage.setItem(LOCKOUT_KEY, String(Date.now() + LOCKOUT_MINUTES * 60 * 1000));
          updateLockoutUI();
          loginError.textContent = 'För många felaktiga försök.';
        } else {
        loginError.textContent = `Fel användarnamn eller lösenord. ${MAX_ATTEMPTS - attempts} försök kvar.`;
        }
      }
    } catch (_e) {
      loginError.textContent = 'Kunde inte ansluta till servern.';
    }
    loginBtn.disabled = false; loginBtn.textContent = 'Logga in';
  });

  // Logout
  function logout() { sessionStorage.removeItem(SESSION_KEY); sessionStorage.removeItem(TOKEN_KEY); window.location.reload(); }
  document.getElementById('logoutBtn')?.addEventListener('click', logout);
  document.getElementById('logoutBtnMobile')?.addEventListener('click', logout);

  // === SIDEBAR & TABS ===
  const sidebar = document.getElementById('adminSidebar')!;
  const sidebarOverlay = document.getElementById('sidebarOverlay')!;
  const topbarTitle = document.getElementById('topbarTitle')!;
  const tabLabels: Record<string, string> = { dashboard: 'Dashboard', cars: 'Bilar', submissions: 'Formulär', newsletter: 'Nyhetsbrev', redirects: 'Omdirigeringar', settings: 'Inställningar' };

  document.getElementById('sidebarToggle')?.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    sidebarOverlay.classList.toggle('open');
  });
  sidebarOverlay.addEventListener('click', () => {
    sidebar.classList.remove('open');
    sidebarOverlay.classList.remove('open');
  });

  document.querySelectorAll('.sidebar-link').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sidebar-link').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const tab = (btn as HTMLElement).dataset.tab!;
      document.getElementById(`tab-${tab}`)?.classList.add('active');
      topbarTitle.textContent = tabLabels[tab] || tab;
      sidebar.classList.remove('open');
      sidebarOverlay.classList.remove('open');
    });
  });

  // Sub-tabs
  document.querySelectorAll('.sub-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.tab-content')!;
      parent.querySelectorAll('.sub-tab').forEach(b => b.classList.remove('active'));
      parent.querySelectorAll('.sub-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      const id = (btn as HTMLElement).dataset.subtab!;
      document.getElementById(`subtab-${id}`)?.classList.add('active');
    });
  });

  // === HELPERS ===
  function formatDate(dateStr: string) {
    const d = new Date(dateStr);
    return d.toLocaleDateString('sv-SE', { day: 'numeric', month: 'short', year: 'numeric' })
      + ' ' + d.toLocaleTimeString('sv-SE', { hour: '2-digit', minute: '2-digit' });
  }
  function formatPrice(price: number) { return price?.toLocaleString('sv-SE') + ' kr'; }
  function formatMileage(m: number) { return m?.toLocaleString('sv-SE') + ' mil'; }

  // === ANNOUNCEMENT BAR ===
  const textInput = document.getElementById('ann-text') as HTMLInputElement;
  const linkInput = document.getElementById('ann-link') as HTMLInputElement;
  const visibleCheck = document.getElementById('ann-visible') as HTMLInputElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const statusMsg = document.getElementById('statusMsg') as HTMLParagraphElement;

  async function loadAnnouncement() {
    try {
      const res = await fetch('/api/announcement', { headers: getAuthHeaders() });
      const data = await res.json();
      textInput.value = data.text || '';
      linkInput.value = data.link || '';
      visibleCheck.checked = data.visible ?? true;
    } catch { statusMsg.textContent = 'Kunde inte ladda.'; }
  }

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true; saveBtn.textContent = 'Sparar...';
    try {
      const res = await fetch('/api/announcement', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ text: textInput.value, link: linkInput.value, visible: visibleCheck.checked }),
      });
      statusMsg.textContent = res.ok ? 'Sparat!' : 'Fel vid sparning.';
      statusMsg.style.color = res.ok ? '#22C55E' : '#EF4444';
    } catch { statusMsg.textContent = 'Nätverksfel.'; statusMsg.style.color = '#EF4444'; }
    saveBtn.disabled = false; saveBtn.textContent = 'Spara';
  });

  // === CARS ===
  const carFilter = document.getElementById('carFilter') as HTMLSelectElement;
  const carsList = document.getElementById('carsList') as HTMLDivElement;
  const carStats = document.getElementById('carStats') as HTMLDivElement;
  const carModal = document.getElementById('carModal') as HTMLDivElement;
  const carModalOverlay = document.getElementById('carModalOverlay') as HTMLDivElement;
  const carModalClose = document.getElementById('carModalClose') as HTMLButtonElement;
  const carModalTitle = document.getElementById('carModalTitle') as HTMLElement;
  const carModalBody = document.getElementById('carModalBody') as HTMLDivElement;

  let allCars: any[] = [];
  let uploadedImages: string[] = [];

  function closeCarModal() {
    carModal.classList.remove('open');
    carModalOverlay.classList.remove('open');
    uploadedImages = [];
  }
  carModalClose.addEventListener('click', closeCarModal);
  carModalOverlay.addEventListener('click', closeCarModal);

  async function updateCar(id: string, updates: Record<string, any>) {
    const res = await fetch('/api/cars', {
      method: 'POST', headers: authJson(),
      body: JSON.stringify({ id, ...updates }),
    });
    if (res.ok) { await loadCars(); closeCarModal(); }
  }

  // Upload single image via server-side API
  async function uploadSingleImage(file: File): Promise<string | null> {
    const formData = new FormData();
    formData.append('file', file);
    try {
      const res = await fetch('/api/upload', { method: 'POST', headers: getAuthHeaders(), body: formData });
      if (!res.ok) {
        const d = await res.json().catch(() => ({}));
        console.error('Upload failed:', d.error || res.status);
        return null;
      }
      const data = await res.json();
      return data.url || null;
    } catch (e) { console.error('Upload error:', e); return null; }
  }

  // Upload multiple images — each as separate request, all in parallel
  async function uploadImages(files: File[]): Promise<(string | null)[]> {
    return Promise.all(files.map(f => uploadSingleImage(f)));
  }

  // Render image previews with drag-to-sort and numbering
  function renderImagePreviews(container: HTMLElement, progressEl: HTMLElement) {
    container.innerHTML = '';
    uploadedImages.forEach((url, i) => {
      const div = document.createElement('div');
      div.className = 'img-preview';
      div.setAttribute('data-url', url);
      div.setAttribute('draggable', 'true');
      div.innerHTML = `
        <img src="${url}" loading="lazy" />
        <span class="img-number ${i === 0 ? 'img-cover' : ''}">${i + 1}</span>
        <button class="img-remove" type="button">&times;</button>
      `;
      // Remove
      div.querySelector('.img-remove')!.addEventListener('click', (e) => {
        e.stopPropagation();
        uploadedImages = uploadedImages.filter(u => u !== url);
        renderImagePreviews(container, progressEl);
      });
      // Drag sort
      div.addEventListener('dragstart', (e) => {
        div.classList.add('dragging');
        e.dataTransfer!.effectAllowed = 'move';
        e.dataTransfer!.setData('text/plain', String(i));
      });
      div.addEventListener('dragend', () => div.classList.remove('dragging'));
      div.addEventListener('dragover', (e) => { e.preventDefault(); div.classList.add('drag-over'); });
      div.addEventListener('dragleave', () => div.classList.remove('drag-over'));
      div.addEventListener('drop', (e) => {
        e.preventDefault();
        div.classList.remove('drag-over');
        const fromIdx = parseInt(e.dataTransfer!.getData('text/plain'));
        const toIdx = i;
        if (fromIdx !== toIdx) {
          const item = uploadedImages.splice(fromIdx, 1)[0];
          uploadedImages.splice(toIdx, 0, item);
          renderImagePreviews(container, progressEl);
        }
      });
      container.appendChild(div);
    });
    progressEl.textContent = uploadedImages.length
      ? `${uploadedImages.length} bild(er) — bild 1 = omslagsbild`
      : '';
  }

  // Handle file selection: show instant local preview, upload in background
  async function handleFileUpload(files: FileList | null | undefined, container: HTMLElement, progressEl: HTMLElement, zone?: HTMLElement) {
    if (!files?.length) return;
    const fileArr = Array.from(files);

    // Instant local previews
    const localUrls: string[] = [];
    fileArr.forEach(f => {
      const localUrl = URL.createObjectURL(f);
      localUrls.push(localUrl);
      uploadedImages.push(localUrl);
    });
    renderImagePreviews(container, progressEl);

    // Upload each file as separate request, all in parallel
    if (zone) zone.classList.add('uploading');
    progressEl.textContent = `Laddar upp ${fileArr.length} bild(er)...`;

    const results = await uploadImages(fileArr);

    // Replace local URLs with server URLs, remove failures
    let failCount = 0;
    results.forEach((serverUrl, idx) => {
      const localUrl = localUrls[idx];
      if (serverUrl && localUrl) {
        const localIdx = uploadedImages.indexOf(localUrl);
        if (localIdx >= 0) uploadedImages[localIdx] = serverUrl;
      } else if (localUrl) {
        uploadedImages = uploadedImages.filter(u => u !== localUrl);
        failCount++;
      }
      if (localUrl) URL.revokeObjectURL(localUrl);
    });

    if (failCount > 0) {
      progressEl.textContent = `${uploadedImages.length} bild(er) — ${failCount} misslyckades (max 4MB/bild)`;
      progressEl.classList.add('error');
    } else {
      progressEl.classList.remove('error');
    }

    if (zone) zone.classList.remove('uploading');
    renderImagePreviews(container, progressEl);
  }

  // Setup upload zone with drag/drop and click
  function setupUploadZone(zoneId: string, fileInputId: string, previewsId: string, progressId: string) {
    const zone = document.getElementById(zoneId)!;
    const fileInput = document.getElementById(fileInputId) as HTMLInputElement;
    const previews = document.getElementById(previewsId)!;
    const progress = document.getElementById(progressId)!;

    zone.addEventListener('click', () => fileInput.click());
    zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
    zone.addEventListener('drop', (e) => {
      e.preventDefault(); zone.classList.remove('dragover');
      handleFileUpload(e.dataTransfer?.files, previews, progress, zone);
    });
    fileInput.addEventListener('change', () => {
      handleFileUpload(fileInput.files, previews, progress, zone);
      fileInput.value = '';
    });

    return { previews, progress };
  }

