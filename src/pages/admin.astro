---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin – Begbilnorr</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="admin-body">
  <!-- LOGIN OVERLAY -->
  <div class="login-overlay" id="loginOverlay">
    <div class="login-card">
      <div class="login-logo">
        <img src="/images/begbilnorr-logo-nav.webp" alt="Begbilnorr" height="40" />
      </div>
      <h1 class="login-title">Adminpanel</h1>
      <p class="login-subtitle">Logga in for att hantera webbplatsen</p>
      <form id="loginForm" autocomplete="off">
        <div class="login-field">
          <label for="loginUser">Anvandarnamn</label>
          <input type="text" id="loginUser" name="username" required autocomplete="username" placeholder="Anvandarnamn" />
        </div>
        <div class="login-field">
          <label for="loginPass">Losenord</label>
          <input type="password" id="loginPass" name="password" required autocomplete="current-password" placeholder="Losenord" />
        </div>
        <button type="submit" class="login-btn" id="loginBtn">Logga in</button>
        <p class="login-error" id="loginError"></p>
        <p class="login-locked" id="loginLocked"></p>
      </form>
    </div>
  </div>

  <!-- ADMIN PANEL -->
  <div class="admin-shell" id="adminContent" style="display:none;">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
      <div class="sidebar-brand">
        <img src="/images/begbilnorr-logo-nav.webp" alt="Begbilnorr" height="28" />
        <span class="sidebar-badge">Admin</span>
      </div>
      <nav class="sidebar-nav">
        <button class="sidebar-link active" data-tab="dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          <span>Dashboard</span>
        </button>
        <button class="sidebar-link" data-tab="cars">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          <span>Bilar</span>
        </button>
        <button class="sidebar-link" data-tab="submissions">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
          <span>Formulär</span>
        </button>
        <button class="sidebar-link" data-tab="newsletter">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>Nyhetsbrev</span>
        </button>
        <button class="sidebar-link" data-tab="leads">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Leads</span>
        </button>
        <button class="sidebar-link" data-tab="redirects">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          <span>Omdirigeringar</span>
        </button>
        <button class="sidebar-link" data-tab="settings">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
          <span>Inställningar</span>
        </button>
      </nav>
      <div class="sidebar-footer">
        <button class="sidebar-logout" id="logoutBtn" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Logga ut</span>
        </button>
      </div>
    </aside>

    <!-- Mobile top bar -->
    <div class="admin-topbar" id="adminTopbar">
      <button class="topbar-menu" id="sidebarToggle" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
      <span class="topbar-title" id="topbarTitle">Dashboard</span>
      <button class="topbar-logout" id="logoutBtnMobile" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </button>
    </div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main content -->
    <main class="admin-main">
      <!-- Dashboard -->
      <div class="tab-content active" id="tab-dashboard">
        <div class="page-header">
          <h1>Dashboard</h1>
          <p class="page-desc">Översikt av begbilnorr.se</p>
        </div>
        <div class="stats-grid" id="dashboardStats">
          <div class="stat-card">
            <div class="stat-icon green"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg></div>
            <div class="stat-info">
              <span class="stat-value" id="statActiveCars">-</span>
              <span class="stat-label">Aktiva bilar</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon amber"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
            <div class="stat-info">
              <span class="stat-value" id="statSoldCars">-</span>
              <span class="stat-label">Sålda bilar</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon blue"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
            <div class="stat-info">
              <span class="stat-value" id="statSubscribers">-</span>
              <span class="stat-label">Prenumeranter</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon red"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg></div>
            <div class="stat-info">
              <span class="stat-value" id="statSubmissions">-</span>
              <span class="stat-label">Formulär</span>
            </div>
          </div>
        </div>
        <div class="dashboard-grid">
          <div class="card">
            <div class="card-header">
              <h3>Senaste inlämningar</h3>
            </div>
            <div class="card-body" id="dashRecentSubmissions">
              <p class="empty-text">Laddar...</p>
            </div>
          </div>
          <div class="card">
            <div class="card-header">
              <h3>Senaste bilar</h3>
            </div>
            <div class="card-body" id="dashRecentCars">
              <p class="empty-text">Laddar...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Cars -->
      <div class="tab-content" id="tab-cars">
        <div class="page-header">
          <div>
            <h1>Bilar</h1>
            <p class="page-desc">Hantera billagret</p>
          </div>
          <button class="btn btn-primary" id="addCarBtn" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Lägg till bil
          </button>
        </div>
        <div class="toolbar">
          <select id="carFilter" class="select">
            <option value="active">Aktiva</option>
            <option value="sold">Sålda</option>
            <option value="inactive">Inaktiva</option>
            <option value="all">Alla</option>
          </select>
          <div class="toolbar-right">
            <div class="car-stats-inline" id="carStats"></div>
            <button class="btn btn-ghost" id="refreshCarsBtn" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            </button>
          </div>
        </div>
        <div class="cars-grid" id="carsList">
          <p class="empty-text">Laddar bilar...</p>
        </div>
      </div>

      <!-- Submissions -->
      <div class="tab-content" id="tab-submissions">
        <div class="page-header">
          <div>
            <h1>Formulär</h1>
            <p class="page-desc">Kontaktformulär och inlämningar</p>
          </div>
        </div>
        <div class="toolbar">
          <select id="sourceFilter" class="select">
            <option value="alla">Alla källor</option>
            <option value="kontakt">Kontaktsidan</option>
            <option value="kontakt-footer">Kontakt (footer)</option>
            <option value="vardering">Värdering</option>
            <option value="salj-bil-footer">Sälj bil (footer)</option>
            <option value="bevakning">Bevakning</option>
            <option value="newsletter">Newsletter</option>
            <option value="newsletter-footer">Newsletter (footer)</option>
          </select>
          <button class="btn btn-ghost" id="refreshBtn" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
          </button>
        </div>
        <div class="submissions-stats" id="stats"></div>
        <div class="list-container" id="submissionsList">
          <p class="empty-text">Laddar...</p>
        </div>
      </div>

      <!-- Newsletter -->
      <div class="tab-content" id="tab-newsletter">
        <div class="page-header">
          <div>
            <h1>Nyhetsbrev</h1>
            <p class="page-desc">Hantera prenumeranter och skicka nyhetsbrev</p>
          </div>
        </div>

        <!-- Newsletter sub-tabs -->
        <div class="sub-tabs">
          <button class="sub-tab active" data-subtab="nl-subscribers">Prenumeranter</button>
          <button class="sub-tab" data-subtab="nl-send">Skicka nyhetsbrev</button>
        </div>

        <!-- Subscribers subtab -->
        <div class="sub-content active" id="subtab-nl-subscribers">
          <div class="card" style="margin-bottom:16px;">
            <div class="card-body">
              <h3 style="margin-bottom:12px;font-size:15px;font-weight:600;">Lägg till prenumerant</h3>
              <div class="inline-form">
                <input type="email" id="nlAddEmail" placeholder="E-postadress" class="input" />
                <input type="text" id="nlAddName" placeholder="Namn (valfritt)" class="input" />
                <button class="btn btn-primary" id="nlAddBtn" type="button">Lägg till</button>
              </div>
              <p id="nlAddMsg" class="form-msg"></p>
            </div>
          </div>

          <div class="toolbar">
            <select id="nlFilter" class="select">
              <option value="all">Alla</option>
              <option value="active">Aktiva</option>
              <option value="inactive">Avregistrerade</option>
            </select>
            <div class="toolbar-right">
              <button class="btn btn-ghost" id="nlExportBtn" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Exportera CSV
              </button>
              <button class="btn btn-ghost" id="refreshNlBtn" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
              </button>
            </div>
          </div>
          <div class="nl-stats" id="nlStats"></div>
          <div class="list-container" id="nlList">
            <p class="empty-text">Laddar...</p>
          </div>
        </div>

        <!-- Send newsletter subtab -->
        <div class="sub-content" id="subtab-nl-send">
          <div class="card">
            <div class="card-body">
              <h3 style="margin-bottom:16px;font-size:16px;font-weight:600;">Komponera nyhetsbrev</h3>
              <div class="form-group">
                <label for="nlSubject">Ämne</label>
                <input type="text" id="nlSubject" class="input" placeholder="t.ex. Nya bilar i lager!" />
              </div>
              <div class="form-group">
                <label for="nlContent">Innehåll (HTML)</label>
                <textarea id="nlContent" class="input textarea" rows="12" placeholder="Skriv ditt nyhetsbrev här..."></textarea>
              </div>
              <div class="form-group">
                <label>Mallar</label>
                <div class="template-btns">
                  <button class="btn btn-ghost" id="tplNewCars" type="button">Nya bilar</button>
                  <button class="btn btn-ghost" id="tplOffer" type="button">Erbjudande</button>
                  <button class="btn btn-ghost" id="tplGeneral" type="button">Allmänt</button>
                </div>
              </div>
              <div class="nl-actions">
                <div class="nl-test">
                  <input type="email" id="nlTestEmail" class="input" placeholder="Test-epost" style="max-width:240px;" />
                  <button class="btn btn-outline" id="nlTestBtn" type="button">Skicka test</button>
                </div>
                <button class="btn btn-primary btn-lg" id="nlSendBtn" type="button">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                  Skicka till alla prenumeranter
                </button>
              </div>
              <p id="nlSendMsg" class="form-msg"></p>
            </div>
          </div>
          <div class="card" style="margin-top:16px;">
            <div class="card-header"><h3>Förhandsvisning</h3></div>
            <div class="card-body">
              <div class="preview-frame" id="nlPreview">
                <p class="empty-text">Skriv innehåll ovan för att se förhandsvisning</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Leads -->
      <div class="tab-content" id="tab-leads">
        <div class="page-header">
          <div>
            <h1>Leads</h1>
            <p class="page-desc">Alla kontakter och intresseanmälningar</p>
          </div>
        </div>
        <div class="leads-filters">
          <button class="leads-filter-btn active" data-filter="all">Alla</button>
          <button class="leads-filter-btn" data-filter="kontakt">Kontakt</button>
          <button class="leads-filter-btn" data-filter="kontakt-footer">Kontaktmodal</button>
          <button class="leads-filter-btn" data-filter="vardering">Värdering</button>
          <button class="leads-filter-btn" data-filter="salj-bil-footer">Sälj bil</button>
          <button class="leads-filter-btn" data-filter="bevakning">Bevakning</button>
          <button class="leads-filter-btn" data-filter="newsletter">Nyhetsbrev</button>
        </div>
        <div class="leads-search">
          <input type="text" id="leadsSearch" placeholder="Sök namn, e-post, telefon..." class="admin-search-input" />
        </div>
        <div class="table-wrapper">
          <table class="admin-table" id="leadsTable">
            <thead>
              <tr>
                <th>Namn</th>
                <th>E-post</th>
                <th>Telefon</th>
                <th>Källa</th>
                <th>Labels</th>
                <th>Antal</th>
                <th>UTM</th>
                <th>Datum</th>
              </tr>
            </thead>
            <tbody id="leadsBody"></tbody>
          </table>
        </div>
        <p class="empty-state" id="leadsEmpty" style="display:none;">Inga leads hittades.</p>
      </div>

      <!-- Redirects -->
      <div class="tab-content" id="tab-redirects">
        <div class="page-header">
          <div>
            <h1>Omdirigeringar</h1>
            <p class="page-desc">Hantera korta marknadsföringslänkar</p>
          </div>
        </div>
        <div class="card" style="margin-bottom:16px;">
          <div class="card-body">
            <h3 style="margin-bottom:12px;font-size:15px;font-weight:600;">Lägg till omdirigering</h3>
            <div class="inline-form">
              <div style="position:relative;flex:1;">
                <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.3);font-size:13px;">begbilnorr.se/</span>
                <input type="text" id="rdSlug" placeholder="sm" class="input" style="padding-left:120px;" />
              </div>
              <div style="position:relative;flex:1;">
                <input type="text" id="rdTarget" placeholder="/salj-bil eller https://..." class="input" />
              </div>
              <button class="btn btn-primary" id="rdAddBtn" type="button">Lägg till</button>
            </div>
            <p id="rdAddMsg" class="form-msg"></p>
          </div>
        </div>
        <div class="toolbar">
          <div class="toolbar-right">
            <button class="btn btn-ghost" id="refreshRdBtn" type="button">
