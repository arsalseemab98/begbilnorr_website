    document.getElementById('cancelAddCar')?.addEventListener('click', closeCarModal);
    document.getElementById('saveNewCar')?.addEventListener('click', async () => {
      const btn = document.getElementById('saveNewCar') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Sparar...';

      const reg_no = (document.getElementById('newRegNo') as HTMLInputElement).value.trim();
      const brand = (document.getElementById('newBrand') as HTMLInputElement).value.trim();
      const model = (document.getElementById('newModel') as HTMLInputElement).value.trim();
      const variant = (document.getElementById('newVariant') as HTMLInputElement).value.trim();
      const year = (document.getElementById('newYear') as HTMLInputElement).value;
      const mileage = (document.getElementById('newMileage') as HTMLInputElement).value;
      const price = (document.getElementById('newPrice') as HTMLInputElement).value;
      const fuel_type = (document.getElementById('newFuel') as HTMLSelectElement).value;
      const gearbox = (document.getElementById('newGearbox') as HTMLSelectElement).value;
      const body_type = (document.getElementById('newBodyType') as HTMLSelectElement).value;
      const monthly_payment = (document.getElementById('newMonthly') as HTMLInputElement).value.trim();
      const is_vat_deductible = (document.getElementById('newVat') as HTMLInputElement).checked;
      const description = (document.getElementById('newDesc') as HTMLTextAreaElement).value.trim();
      const equipmentText = (document.getElementById('newEquipment') as HTMLTextAreaElement).value.trim();
      const equipment = equipmentText ? equipmentText.split('\n').map(s => s.trim()).filter(Boolean) : [];

      if (!reg_no || !brand || !model || !year || !price) {
        progress.textContent = 'Fyll i alla obligatoriska fält (*)';
        progress.style.color = '#EF4444';
        btn.disabled = false; btn.textContent = 'Spara bil';
        return;
      }

      // Filter out blob URLs (local previews that failed to upload)
      const validImages = uploadedImages.filter(u => !u.startsWith('blob:'));
      if (validImages.length === 0 && uploadedImages.length > 0) {
        progress.textContent = 'Bilderna laddades inte upp korrekt. Försök igen.';
        progress.style.color = '#EF4444';
        btn.disabled = false; btn.textContent = 'Spara bil';
        return;
      }

      try {
        const res = await fetch('/api/cars', {
          method: 'POST', headers: authJson(),
          body: JSON.stringify({
            action: 'create', reg_no, brand, model, variant, year, mileage, price,
            fuel_type, gearbox, body_type, monthly_payment, is_vat_deductible, description,
            equipment, images: validImages,
          }),
        });
        const data = await res.json();
        if (res.ok) {
          closeCarModal();
          await loadCars();
        } else {
          progress.textContent = data.error || 'Fel vid sparning.';
          progress.style.color = '#EF4444';
        }
      } catch {
        progress.textContent = 'Nätverksfel.';
        progress.style.color = '#EF4444';
      }
      btn.disabled = false; btn.textContent = 'Spara bil';
    });
  }

  document.getElementById('addCarBtn')?.addEventListener('click', openAddCarModal);

  function openEditModal(car: any) {
    carModalTitle.textContent = `Redigera: ${car.full_name}`;
    uploadedImages = [...(car.images || [])];
    carModalBody.innerHTML = `
      <div class="form-row">
        <div class="form-group"><label>Reg.nr</label><input type="text" id="editRegNo" class="input" value="${car.reg_no}" disabled /></div>
        <div class="form-group"><label>Märke</label><input type="text" id="editBrand" class="input" value="${car.brand || ''}" /></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Modell</label><input type="text" id="editModel" class="input" value="${car.model || ''}" /></div>
        <div class="form-group"><label>Variant</label><input type="text" id="editVariant" class="input" value="${car.variant || ''}" /></div>
      </div>
      <div class="form-row-3">
        <div class="form-group"><label>År</label><input type="number" id="editYear" class="input" value="${car.year || ''}" /></div>
        <div class="form-group"><label>Miltal</label><input type="number" id="editMileage" class="input" value="${car.mileage || ''}" /></div>
        <div class="form-group"><label>Pris (kr)</label><input type="number" id="editPrice" class="input" value="${car.price || ''}" /></div>
      </div>
      <div class="form-row-3">
        <div class="form-group">
          <label>Drivmedel</label>
          <select id="editFuel" class="input">
            ${['Bensin','Diesel','El','Hybrid','Laddhybrid'].map(f => `<option value="${f}" ${car.fuel_type === f ? 'selected' : ''}>${f}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label>Växellåda</label>
          <select id="editGearbox" class="input">
            ${['Automat','Manuell'].map(g => `<option value="${g}" ${car.gearbox === g ? 'selected' : ''}>${g}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label>Biltyp</label>
          <select id="editBodyType" class="input">
            ${['','Sedan','Kombi','SUV','Halvkombi','Cab','Coupé'].map(b => `<option value="${b}" ${car.body_type === b ? 'selected' : ''}>${b || 'Välj...'}</option>`).join('')}
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Månadsbetalning</label>
        <input type="text" id="editMonthly" class="input" value="${car.monthly_payment || ''}" />
      </div>
      <div class="form-group">
        <label class="checkbox-label"><input type="checkbox" id="editVat" ${car.is_vat_deductible ? 'checked' : ''} /><span>Moms avdragsgill</span></label>
      </div>
      <div class="form-group">
        <label>Beskrivning</label>
        <textarea id="editDesc" class="input textarea" rows="3">${car.description || ''}</textarea>
      </div>
      <div class="form-group">
        <label>Utrustning (en per rad)</label>
        <textarea id="editEquipment" class="input textarea" rows="4">${(car.equipment || []).join('\n')}</textarea>
      </div>
      <div class="form-group">
        <label>Status</label>
        <div style="display:flex;gap:16px;">
          <label class="checkbox-label"><input type="checkbox" id="editActive" ${car.is_active ? 'checked' : ''} /><span>Aktiv</span></label>
          <label class="checkbox-label"><input type="checkbox" id="editSold" ${car.is_sold ? 'checked' : ''} /><span>Såld</span></label>
        </div>
      </div>
      <div class="form-group">
        <label>Bilder</label>
        <div class="upload-zone" id="editUploadZone">
          <div class="upload-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          </div>
          <p class="upload-text"><strong>Lägg till fler bilder</strong></p>
          <input type="file" id="editFileInput" accept="image/jpeg,image/png,image/webp,image/avif" multiple style="display:none;" />
        </div>
        <div class="image-previews" id="editImagePreviews"></div>
        <p class="upload-progress" id="editUploadProgress"></p>
        <p class="sort-hint">Dra bilderna för att ändra ordning. Bild 1 = omslagsbild på hemsidan.</p>
      </div>
      <div style="display:flex;gap:8px;justify-content:space-between;padding-top:8px;border-top:1px solid rgba(255,255,255,0.06);">
        <button class="btn btn-danger btn-sm" id="deleteCar" type="button">Ta bort bil</button>
        <div style="display:flex;gap:8px;">
          <button class="btn btn-ghost" id="cancelEditCar" type="button">Avbryt</button>
          <button class="btn btn-primary" id="saveEditCar" type="button">Spara ändringar</button>
        </div>
      </div>
    `;

    carModal.classList.add('open');
    carModalOverlay.classList.add('open');

    // Render existing images with drag-sort
    const editPreviews = document.getElementById('editImagePreviews')!;
    const editProgress = document.getElementById('editUploadProgress')!;
    renderImagePreviews(editPreviews, editProgress);

    // Setup upload zone for adding more images
    setupUploadZone('editUploadZone', 'editFileInput', 'editImagePreviews', 'editUploadProgress');

    document.getElementById('cancelEditCar')?.addEventListener('click', closeCarModal);
    document.getElementById('deleteCar')?.addEventListener('click', async () => {
      if (!confirm('Är du säker på att du vill ta bort denna bil?')) return;
      const res = await fetch('/api/cars', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ action: 'delete', id: car.id }),
      });
      if (res.ok) { closeCarModal(); await loadCars(); }
    });

    document.getElementById('saveEditCar')?.addEventListener('click', async () => {
      const btn = document.getElementById('saveEditCar') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Sparar...';

      const brand = (document.getElementById('editBrand') as HTMLInputElement).value.trim();
      const model = (document.getElementById('editModel') as HTMLInputElement).value.trim();
      const variant = (document.getElementById('editVariant') as HTMLInputElement).value.trim();
      const year = parseInt((document.getElementById('editYear') as HTMLInputElement).value) || null;
      const price = parseInt((document.getElementById('editPrice') as HTMLInputElement).value) || null;
      const mileage = parseInt((document.getElementById('editMileage') as HTMLInputElement).value) || null;
      const fuel_type = (document.getElementById('editFuel') as HTMLSelectElement).value;
      const gearbox = (document.getElementById('editGearbox') as HTMLSelectElement).value;
      const body_type = (document.getElementById('editBodyType') as HTMLSelectElement).value;
      const monthly_payment = (document.getElementById('editMonthly') as HTMLInputElement).value.trim() || null;
      const is_vat_deductible = (document.getElementById('editVat') as HTMLInputElement).checked;
      const description = (document.getElementById('editDesc') as HTMLTextAreaElement).value.trim() || null;
      const equipmentText = (document.getElementById('editEquipment') as HTMLTextAreaElement).value.trim();
      const equipment = equipmentText ? equipmentText.split('\n').map(s => s.trim()).filter(Boolean) : [];
      const is_active = (document.getElementById('editActive') as HTMLInputElement).checked;
      const is_sold = (document.getElementById('editSold') as HTMLInputElement).checked;

      const validImages = uploadedImages.filter(u => !u.startsWith('blob:'));
      await updateCar(car.id, { brand, model, variant, year, price, mileage, fuel_type, gearbox, body_type, monthly_payment, is_vat_deductible, description, equipment, is_active, is_sold, images: validImages });
      btn.disabled = false; btn.textContent = 'Spara ändringar';
    });
  }

  function renderCars() {
    const filter = carFilter.value;
    let filtered = allCars;
    if (filter === 'active') filtered = allCars.filter(c => c.is_active && !c.is_sold);
    else if (filter === 'sold') filtered = allCars.filter(c => c.is_sold);
    else if (filter === 'inactive') filtered = allCars.filter(c => !c.is_active);

    const active = allCars.filter(c => c.is_active && !c.is_sold).length;
    const sold = allCars.filter(c => c.is_sold).length;
    const total = allCars.length;

    carStats.innerHTML = `
      <span class="badge badge-green">Aktiva: ${active}</span>
      <span class="badge badge-amber">Sålda: ${sold}</span>
      <span class="badge badge-gray">Totalt: ${total}</span>
    `;

    if (!filtered.length) { carsList.innerHTML = '<p class="empty-text">Inga bilar hittades.</p>'; return; }

    carsList.innerHTML = filtered.map(c => {
      const thumb = c.images?.[0];
      const statusBadge = c.is_sold
        ? '<span class="badge badge-amber">Såld</span>'
        : c.is_active
          ? '<span class="badge badge-green">Aktiv</span>'
          : '<span class="badge badge-gray">Inaktiv</span>';

      return `
        <div class="car-row" data-id="${c.id}">
          ${thumb ? `<img class="car-thumb" src="${thumb}" alt="${c.full_name}" loading="lazy" />` : '<div class="car-thumb-empty">&#128663;</div>'}
          <div class="car-info">
            <div class="car-name">${c.full_name}</div>
            <div class="car-meta">
              <span>${c.reg_no}</span>
              <span>${c.year}</span>
              <span>${formatMileage(c.mileage)}</span>
              <span>${c.fuel_type || '-'}</span>
              <span>${c.gearbox || '-'}</span>
              <span>${c.body_type || '-'}</span>
              <span class="price">${formatPrice(c.price)}</span>
              ${c.is_vat_deductible ? '<span class="badge badge-blue">Moms</span>' : ''}
              ${statusBadge}
            </div>
          </div>
          <div class="car-actions">
            ${!c.is_sold
              ? `<button class="btn btn-sm btn-outline" style="border-color:rgba(245,158,11,0.3);color:#F59E0B;" onclick="window.__markSold('${c.id}')">Markera såld</button>`
              : `<button class="btn btn-sm btn-outline" style="border-color:rgba(34,197,94,0.3);color:#22C55E;" onclick="window.__markUnsold('${c.id}')">Ångra</button>`}
            <button class="btn btn-sm btn-ghost" onclick="window.__editCar('${c.id}')">Redigera</button>
            <button class="btn btn-sm btn-outline" style="border-color:rgba(239,68,68,0.3);color:#EF4444;" onclick="window.__deleteCar('${c.id}','${c.full_name.replace(/'/g, "\\'")}')">Ta bort</button>
          </div>
        </div>
      `;
    }).join('');
  }

  async function loadCars() {
    carsList.innerHTML = '<p class="empty-text">Laddar bilar...</p>';
    try {
      const res = await fetch('/api/cars', { headers: getAuthHeaders() });
      allCars = await res.json();
      renderCars();
      updateDashboard();
    } catch { carsList.innerHTML = '<p class="empty-text" style="color:#EF4444;">Kunde inte ladda bilar.</p>'; }
  }

  carFilter.addEventListener('change', renderCars);
  document.getElementById('refreshCarsBtn')?.addEventListener('click', loadCars);

  (window as any).__editCar = (id: string) => { const car = allCars.find(c => c.id === id); if (car) openEditModal(car); };
  (window as any).__markSold = (id: string) => updateCar(id, { is_sold: true });
  (window as any).__markUnsold = (id: string) => updateCar(id, { is_sold: false });
  (window as any).__deleteCar = async (id: string, name: string) => {
    if (!confirm(`Är du säker på att du vill ta bort "${name}"? Detta går inte att ångra.`)) return;
    const res = await fetch('/api/cars', {
      method: 'POST', headers: authJson(),
      body: JSON.stringify({ action: 'delete', id }),
    });
    if (res.ok) await loadCars();
  };

  // === SUBMISSIONS ===
  const sourceFilter = document.getElementById('sourceFilter') as HTMLSelectElement;
  const refreshBtn = document.getElementById('refreshBtn') as HTMLButtonElement;
  const submissionsList = document.getElementById('submissionsList') as HTMLDivElement;
  const statsEl = document.getElementById('stats') as HTMLDivElement;
  let allSubmissions: any[] = [];

  const sourceLabels: Record<string, string> = {
    'kontakt': 'Kontakt', 'kontakt-footer': 'Footer', 'vardering': 'Värdering',
    'salj-bil-footer': 'Sälj bil', 'bevakning': 'Bevakning', 'newsletter': 'Newsletter', 'newsletter-footer': 'NL (footer)',
  };
  const sourceColors: Record<string, string> = {
    'kontakt': '#E62E2D', 'kontakt-footer': '#C72625', 'vardering': '#F59E0B',
    'salj-bil-footer': '#EF4444', 'bevakning': '#10B981', 'newsletter': '#3B82F6', 'newsletter-footer': '#6366F1',
  };

  function getSourceBadge(source: string | null) {
    const label = source ? (sourceLabels[source] || source) : 'okänd';
    const color = source ? (sourceColors[source] || '#6B7280') : '#6B7280';
    return `<span class="badge" style="background:${color}18;color:${color};border:1px solid ${color}33;">${label}</span>`;
  }

  async function loadSubmissions() {
    submissionsList.innerHTML = '<p class="empty-text">Laddar...</p>';
    const source = sourceFilter.value;
    try {
      const res = await fetch(`/api/submissions?source=${source}&limit=50`, { headers: getAuthHeaders() });
      allSubmissions = await res.json();
      if (!allSubmissions.length) { submissionsList.innerHTML = '<p class="empty-text">Inga inlämningar.</p>'; statsEl.innerHTML = ''; return; }

      const sourceCounts: Record<string, number> = {};
      allSubmissions.forEach((s: any) => { const src = s.source || 'okänd'; sourceCounts[src] = (sourceCounts[src] || 0) + 1; });

      statsEl.innerHTML = `
        <span class="badge badge-gray">Totalt: ${allSubmissions.length}</span>
        ${Object.entries(sourceCounts).map(([src, count]) => `${getSourceBadge(src)} <span style="font-size:12px;color:rgba(255,255,255,0.4);margin-right:4px;">${count}</span>`).join('')}
      `;

      submissionsList.innerHTML = allSubmissions.map((s: any) => `
        <div class="submission-card">
          <div class="submission-top">
            <div class="submission-badges">
              ${getSourceBadge(s.source)}
              ${s.car_name ? `<span class="badge badge-red">${s.car_name}</span>` : ''}
              ${s.sent_successfully ? '<span class="badge badge-green">Mejlat</span>' : '<span class="badge badge-gray">Ej mejlat</span>'}
            </div>
            <span class="submission-date">${formatDate(s.created_at)}</span>
          </div>
          <div class="submission-fields">
            ${s.name && s.name !== 'Okänd' ? `<span><strong>Namn:</strong> ${s.name}</span>` : ''}
            ${s.email ? `<span><strong>E-post:</strong> ${s.email}</span>` : ''}
            ${s.phone ? `<span><strong>Tel:</strong> ${s.phone}</span>` : ''}
          </div>
          <p class="submission-msg">${s.message}</p>
        </div>
      `).join('');
      updateDashboard();
    } catch { submissionsList.innerHTML = '<p class="empty-text" style="color:#EF4444;">Kunde inte ladda.</p>'; }
  }

  sourceFilter.addEventListener('change', loadSubmissions);
  refreshBtn.addEventListener('click', loadSubmissions);

  // === NEWSLETTER ===
  const nlList = document.getElementById('nlList') as HTMLDivElement;
  const nlStats = document.getElementById('nlStats') as HTMLDivElement;
  const nlFilter = document.getElementById('nlFilter') as HTMLSelectElement;
  const nlAddBtn = document.getElementById('nlAddBtn') as HTMLButtonElement;
  const nlAddEmail = document.getElementById('nlAddEmail') as HTMLInputElement;
  const nlAddName = document.getElementById('nlAddName') as HTMLInputElement;
  const nlAddMsg = document.getElementById('nlAddMsg') as HTMLParagraphElement;
  const nlExportBtn = document.getElementById('nlExportBtn') as HTMLButtonElement;

  let allSubscribers: any[] = [];

  function renderSubscribers() {
    const filter = nlFilter.value;
    let filtered = allSubscribers;
    if (filter === 'active') filtered = allSubscribers.filter(s => s.is_active);
    else if (filter === 'inactive') filtered = allSubscribers.filter(s => !s.is_active);

    const active = allSubscribers.filter(s => s.is_active).length;
    const inactive = allSubscribers.filter(s => !s.is_active).length;

    nlStats.innerHTML = `
      <span class="badge badge-gray">Totalt: ${allSubscribers.length}</span>
      <span class="badge badge-green">Aktiva: ${active}</span>
      ${inactive > 0 ? `<span class="badge badge-gray">Avregistrerade: ${inactive}</span>` : ''}
    `;

    if (!filtered.length) { nlList.innerHTML = '<p class="empty-text">Inga prenumeranter.</p>'; return; }

    nlList.innerHTML = filtered.map(s => `
      <div class="nl-row">
        <div class="nl-info">
          <div class="nl-badges">
            <span class="nl-email">${s.email}</span>
            ${s.is_active ? '<span class="badge badge-green">Aktiv</span>' : '<span class="badge badge-gray">Avregistrerad</span>'}
          </div>
          <div class="nl-detail">${s.name ? `${s.name} — ` : ''}${formatDate(s.created_at)}${s.source ? ` — ${s.source}` : ''}</div>
        </div>
        <div class="nl-actions">
          <button class="btn btn-sm btn-ghost" onclick="window.__toggleNl('${s.id}', ${!s.is_active})">${s.is_active ? 'Avregistrera' : 'Aktivera'}</button>
          <button class="btn btn-sm btn-danger" onclick="window.__deleteNl('${s.id}')">Ta bort</button>
        </div>
      </div>
    `).join('');
  }

  async function loadSubscribers() {
    nlList.innerHTML = '<p class="empty-text">Laddar...</p>';
    try {
      const res = await fetch('/api/newsletter', { headers: getAuthHeaders() });
      allSubscribers = await res.json();
      renderSubscribers();
      updateDashboard();
    } catch { nlList.innerHTML = '<p class="empty-text" style="color:#EF4444;">Kunde inte ladda.</p>'; }
  }

  nlFilter.addEventListener('change', renderSubscribers);
  document.getElementById('refreshNlBtn')?.addEventListener('click', loadSubscribers);

  nlAddBtn.addEventListener('click', async () => {
    const email = nlAddEmail.value.trim();
    if (!email) { nlAddMsg.textContent = 'Ange e-postadress.'; nlAddMsg.style.color = '#EF4444'; return; }
    nlAddBtn.disabled = true; nlAddBtn.textContent = 'Lägger till...';
    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ action: 'add', email, name: nlAddName.value.trim() || null }),
      });
      if (res.ok) {
        nlAddMsg.textContent = 'Tillagd!'; nlAddMsg.style.color = '#22C55E';
        nlAddEmail.value = ''; nlAddName.value = '';
        await loadSubscribers();
      } else { const d = await res.json(); nlAddMsg.textContent = d.error || 'Fel.'; nlAddMsg.style.color = '#EF4444'; }
    } catch { nlAddMsg.textContent = 'Nätverksfel.'; nlAddMsg.style.color = '#EF4444'; }
    nlAddBtn.disabled = false; nlAddBtn.textContent = 'Lägg till';
  });

  (window as any).__toggleNl = async (id: string, is_active: boolean) => {
    await fetch('/api/newsletter', { method: 'POST', headers: authJson(), body: JSON.stringify({ action: 'toggle', id, is_active }) });
    await loadSubscribers();
  };
  (window as any).__deleteNl = async (id: string) => {
    if (!confirm('Ta bort prenumerant?')) return;
    await fetch('/api/newsletter', { method: 'POST', headers: authJson(), body: JSON.stringify({ action: 'delete', id }) });
    await loadSubscribers();
  };

  nlExportBtn.addEventListener('click', () => {
    const active = allSubscribers.filter(s => s.is_active);
    const csv = 'E-post,Namn,Källa,Registrerad\n' + active.map(s => `${s.email},${s.name || ''},${s.source || ''},${s.created_at}`).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = `prenumeranter_${new Date().toISOString().slice(0, 10)}.csv`; a.click();
    URL.revokeObjectURL(url);
  });

  // === NEWSLETTER SEND ===
  const nlSubject = document.getElementById('nlSubject') as HTMLInputElement;
  const nlContent = document.getElementById('nlContent') as HTMLTextAreaElement;
  const nlPreview = document.getElementById('nlPreview') as HTMLDivElement;
  const nlSendMsg = document.getElementById('nlSendMsg') as HTMLParagraphElement;
  const nlTestBtn = document.getElementById('nlTestBtn') as HTMLButtonElement;
  const nlSendBtn = document.getElementById('nlSendBtn') as HTMLButtonElement;
  const nlTestEmail = document.getElementById('nlTestEmail') as HTMLInputElement;

  // Live preview
  nlContent.addEventListener('input', () => {
    const html = nlContent.value;
    if (html.trim()) {
      nlPreview.innerHTML = html;
    } else {
      nlPreview.innerHTML = '<p class="empty-text">Skriv innehåll ovan för att se förhandsvisning</p>';
    }
  });

  // Templates
  document.getElementById('tplNewCars')?.addEventListener('click', () => {
    nlSubject.value = 'Nya bilar i lager hos Begbilnorr!';
    nlContent.value = `<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
  <div style="text-align:center;padding:20px 0;">
    <h1 style="color:#1a1a1a;font-size:24px;margin-bottom:8px;">Nya bilar i lager!</h1>
    <p style="color:#666;font-size:16px;">Vi har precis fått in nya kvalitetsbilar.</p>
  </div>
  <div style="background:#f8f8f8;border-radius:8px;padding:20px;margin-bottom:20px;">
    <p style="color:#333;font-size:14px;line-height:1.7;">Hej!</p>
    <p style="color:#333;font-size:14px;line-height:1.7;">Vi vill meddela att vi har fått in nya bilar i vårt lager. Besök vår hemsida för att se hela utbudet.</p>
    <p style="text-align:center;margin:24px 0;">
      <a href="https://begbilnorr.se/bilar" style="background:#E62E2D;color:#fff;padding:12px 32px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:14px;">Se alla bilar</a>
    </p>
  </div>
  <p style="color:#999;font-size:12px;text-align:center;">Begbilnorr — Luleås tryggaste bilhandlare sedan 2018</p>
</div>`;
    nlContent.dispatchEvent(new Event('input'));
  });

  document.getElementById('tplOffer')?.addEventListener('click', () => {
    nlSubject.value = 'Specialerbjudande från Begbilnorr';
    nlContent.value = `<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
  <div style="text-align:center;padding:20px 0;">
    <h1 style="color:#E62E2D;font-size:28px;margin-bottom:8px;">Specialerbjudande!</h1>
    <p style="color:#666;font-size:16px;">Missa inte våra fantastiska erbjudanden</p>
  </div>
  <div style="background:#f8f8f8;border-radius:8px;padding:20px;margin-bottom:20px;">
    <p style="color:#333;font-size:14px;line-height:1.7;">Hej!</p>
    <p style="color:#333;font-size:14px;line-height:1.7;">Just nu har vi ett specialerbjudande som du inte vill missa. Kontakta oss för mer information!</p>
    <p style="text-align:center;margin:24px 0;">
      <a href="https://begbilnorr.se/kontakt" style="background:#E62E2D;color:#fff;padding:12px 32px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:14px;">Kontakta oss</a>
    </p>
  </div>
  <p style="color:#999;font-size:12px;text-align:center;">Begbilnorr — Luleås tryggaste bilhandlare sedan 2018</p>
</div>`;
    nlContent.dispatchEvent(new Event('input'));
  });

  document.getElementById('tplGeneral')?.addEventListener('click', () => {
    nlSubject.value = 'Nyheter från Begbilnorr';
    nlContent.value = `<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;">
  <div style="text-align:center;padding:20px 0;">
    <h1 style="color:#1a1a1a;font-size:24px;margin-bottom:8px;">Nyheter från Begbilnorr</h1>
  </div>
  <div style="background:#f8f8f8;border-radius:8px;padding:20px;margin-bottom:20px;">
    <p style="color:#333;font-size:14px;line-height:1.7;">Hej!</p>
    <p style="color:#333;font-size:14px;line-height:1.7;">Skriv ditt meddelande här...</p>
    <p style="text-align:center;margin:24px 0;">
      <a href="https://begbilnorr.se" style="background:#E62E2D;color:#fff;padding:12px 32px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:14px;">Besök hemsidan</a>
    </p>
  </div>
  <p style="color:#999;font-size:12px;text-align:center;">Begbilnorr — Luleås tryggaste bilhandlare sedan 2018</p>
</div>`;
    nlContent.dispatchEvent(new Event('input'));
  });

  // Send test
  nlTestBtn.addEventListener('click', async () => {
    const email = nlTestEmail.value.trim();
    if (!email) { nlSendMsg.textContent = 'Ange test-epost.'; nlSendMsg.style.color = '#EF4444'; return; }
    if (!nlSubject.value || !nlContent.value) { nlSendMsg.textContent = 'Fyll i ämne och innehåll.'; nlSendMsg.style.color = '#EF4444'; return; }
    nlTestBtn.disabled = true; nlTestBtn.textContent = 'Skickar...';
    try {
      const res = await fetch('/api/newsletter-send', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ subject: nlSubject.value, html: nlContent.value, testEmail: email }),
      });
      if (res.ok) { nlSendMsg.textContent = `Test skickat till ${email}!`; nlSendMsg.style.color = '#22C55E'; }
      else { const d = await res.json(); nlSendMsg.textContent = d.error || 'Fel.'; nlSendMsg.style.color = '#EF4444'; }
    } catch { nlSendMsg.textContent = 'Nätverksfel.'; nlSendMsg.style.color = '#EF4444'; }
    nlTestBtn.disabled = false; nlTestBtn.textContent = 'Skicka test';
  });

  // Send to all
  nlSendBtn.addEventListener('click', async () => {
    if (!nlSubject.value || !nlContent.value) { nlSendMsg.textContent = 'Fyll i ämne och innehåll.'; nlSendMsg.style.color = '#EF4444'; return; }
    const activeCount = allSubscribers.filter(s => s.is_active).length;
    if (!confirm(`Skicka nyhetsbrev till ${activeCount} prenumerant(er)?`)) return;
    nlSendBtn.disabled = true; nlSendBtn.textContent = 'Skickar...';
    try {
      const res = await fetch('/api/newsletter-send', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ subject: nlSubject.value, html: nlContent.value }),
      });
      const d = await res.json();
      if (res.ok) { nlSendMsg.textContent = `Skickat till ${d.sent} prenumerant(er)!${d.failed ? ` (${d.failed} misslyckades)` : ''}`; nlSendMsg.style.color = '#22C55E'; }
      else { nlSendMsg.textContent = d.error || 'Fel.'; nlSendMsg.style.color = '#EF4444'; }
    } catch { nlSendMsg.textContent = 'Nätverksfel.'; nlSendMsg.style.color = '#EF4444'; }
    nlSendBtn.disabled = false;
    nlSendBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg> Skicka till alla prenumeranter';
  });

  // === DASHBOARD ===
  function updateDashboard() {
    const activeCars = allCars.filter(c => c.is_active && !c.is_sold).length;
    const soldCars = allCars.filter(c => c.is_sold).length;
    const subs = allSubscribers.filter(s => s.is_active).length;
    const submissions = allSubmissions.length;

    document.getElementById('statActiveCars')!.textContent = String(activeCars);
    document.getElementById('statSoldCars')!.textContent = String(soldCars);
    document.getElementById('statSubscribers')!.textContent = String(subs);
    document.getElementById('statSubmissions')!.textContent = String(submissions);

    // Recent submissions
    const recentSubs = document.getElementById('dashRecentSubmissions')!;
    const latest = allSubmissions.slice(0, 5);
    if (latest.length) {
      recentSubs.innerHTML = latest.map(s => `
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <div>
            <span style="font-size:13px;font-weight:500;">${s.name || 'Okänd'}</span>
            ${getSourceBadge(s.source)}
          </div>
          <span style="font-size:12px;color:rgba(255,255,255,0.3);">${formatDate(s.created_at)}</span>
        </div>
      `).join('');
    } else {
      recentSubs.innerHTML = '<p class="empty-text">Inga inlämningar ännu.</p>';
    }

    // Recent cars
    const recentCarsEl = document.getElementById('dashRecentCars')!;
    const latestCars = allCars.slice(0, 5);
    if (latestCars.length) {
      recentCarsEl.innerHTML = latestCars.map(c => `
        <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          ${c.images?.[0] ? `<img src="${c.images[0]}" style="width:48px;height:32px;border-radius:4px;object-fit:cover;" />` : ''}
          <div style="flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.full_name}</div>
            <div style="font-size:12px;color:rgba(255,255,255,0.3);">${formatPrice(c.price)}</div>
          </div>
          ${c.is_sold ? '<span class="badge badge-amber">Såld</span>' : '<span class="badge badge-green">Aktiv</span>'}
        </div>
      `).join('');
    } else {
      recentCarsEl.innerHTML = '<p class="empty-text">Inga bilar ännu.</p>';
    }
  }

  // === INIT ===
  // === REDIRECTS ===
  const rdSlug = document.getElementById('rdSlug') as HTMLInputElement;
  const rdTarget = document.getElementById('rdTarget') as HTMLInputElement;
  const rdAddBtn = document.getElementById('rdAddBtn') as HTMLButtonElement;
  const rdAddMsg = document.getElementById('rdAddMsg') as HTMLParagraphElement;
  const redirectsList = document.getElementById('redirectsList')!;

  let allRedirects: any[] = [];

  async function loadRedirects() {
    try {
      const res = await fetch('/api/redirects', { headers: getAuthHeaders() });
      allRedirects = await res.json();
      renderRedirects();
    } catch { redirectsList.innerHTML = '<p class="empty-text">Kunde inte ladda omdirigeringar.</p>'; }
  }

  function renderRedirects() {
    if (!allRedirects.length) {
      redirectsList.innerHTML = '<p class="empty-text">Inga omdirigeringar ännu.</p>';
      return;
    }
    redirectsList.innerHTML = `<table class="data-table">
      <thead><tr><th>Slug</th><th>Mål</th><th>Klick</th><th>Status</th><th>Skapad</th><th></th></tr></thead>
      <tbody>${allRedirects.map(r => `<tr>
        <td><code style="background:rgba(255,255,255,0.06);padding:2px 8px;border-radius:4px;font-size:13px;">/${r.slug}</code></td>
        <td style="font-size:13px;color:rgba(255,255,255,0.7);">${r.target_url}</td>
        <td style="font-size:13px;text-align:center;">${r.click_count || 0}</td>
        <td><span class="badge ${r.is_active ? 'badge-green' : 'badge-gray'}">${r.is_active ? 'Aktiv' : 'Inaktiv'}</span></td>
        <td style="font-size:12px;color:rgba(255,255,255,0.4);">${formatDate(r.created_at)}</td>
        <td style="text-align:right;">
          <button class="btn btn-ghost btn-sm" onclick="window._toggleRedirect('${r.id}', ${!r.is_active})" title="${r.is_active ? 'Inaktivera' : 'Aktivera'}">${r.is_active ? 'Av' : 'På'}</button>
          <button class="btn btn-ghost btn-sm btn-danger" onclick="window._deleteRedirect('${r.id}', '${r.slug}')" title="Ta bort">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
        </td>
      </tr>`).join('')}</tbody>
    </table>`;
  }

  rdAddBtn?.addEventListener('click', async () => {
    const slug = rdSlug.value.trim();
    const target = rdTarget.value.trim();
    rdAddMsg.textContent = '';
    rdAddMsg.className = 'form-msg';

    if (!slug || !target) { rdAddMsg.textContent = 'Fyll i båda fälten.'; rdAddMsg.classList.add('error'); return; }

    rdAddBtn.disabled = true; rdAddBtn.textContent = 'Lägger till...';
    try {
      const res = await fetch('/api/redirects', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ action: 'create', slug, target_url: target }),
      });
      const data = await res.json();
      if (!res.ok) { rdAddMsg.textContent = data.error || 'Fel.'; rdAddMsg.classList.add('error'); }
      else {
        rdSlug.value = ''; rdTarget.value = '';
        rdAddMsg.textContent = 'Omdirigering skapad!'; rdAddMsg.classList.add('success');
        loadRedirects();
      }
    } catch { rdAddMsg.textContent = 'Kunde inte skapa.'; rdAddMsg.classList.add('error'); }
    rdAddBtn.disabled = false; rdAddBtn.textContent = 'Lägg till';
  });

  (window as any)._toggleRedirect = async (id: string, active: boolean) => {
    try {
      await fetch('/api/redirects', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ action: 'update', id, is_active: active }),
      });
      loadRedirects();
    } catch {}
  };

  (window as any)._deleteRedirect = async (id: string, slug: string) => {
    if (!confirm(`Ta bort omdirigering /${slug}?`)) return;
    try {
      await fetch('/api/redirects', {
        method: 'POST', headers: authJson(),
        body: JSON.stringify({ action: 'delete', id }),
      });
      loadRedirects();
    } catch {}
  };

  document.getElementById('refreshRdBtn')?.addEventListener('click', loadRedirects);

  // === LEADS ===
  let allLeads: any[] = [];
  let leadsFilter = 'all';
  const leadsBody = document.getElementById('leadsBody');
  const leadsEmpty = document.getElementById('leadsEmpty');
  const leadsSearch = document.getElementById('leadsSearch') as HTMLInputElement;

  function getLabelClass(label: string): string {
    if (label.includes('Kontakt')) return 'lead-label-kontakt';
    if (label.includes('Värdering')) return 'lead-label-vardering';
    if (label.includes('Sälj')) return 'lead-label-salj';
    if (label.includes('Bevakning') || label.includes('bevakning')) return 'lead-label-bevakning';
    if (label.includes('Nyhetsbrev') || label.includes('newsletter')) return 'lead-label-newsletter';
    return 'lead-label-default';
  }

  function renderLeads() {
    if (!leadsBody) return;
    const search = (leadsSearch?.value || '').toLowerCase();

    const filtered = allLeads.filter(l => {
      if (leadsFilter !== 'all') {
        const sources = l.sources || [];
        if (!sources.includes(leadsFilter)) return false;
      }
      if (search) {
        const haystack = `${l.name || ''} ${l.email || ''} ${l.phone || ''}`.toLowerCase();
        if (!haystack.includes(search)) return false;
      }
      return true;
    });

    if (!filtered.length) {
      leadsBody.innerHTML = '';
      if (leadsEmpty) leadsEmpty.style.display = 'block';
      return;
    }
    if (leadsEmpty) leadsEmpty.style.display = 'none';

    leadsBody.innerHTML = filtered.map(l => {
      const labels = (l.form_labels || []).map((lb: string) =>
        `<span class="lead-label ${getLabelClass(lb)}">${lb}</span>`
      ).join('');

      const utm = l.utm_data;
      const utmStr = utm
        ? `${utm.utm_source || ''}${utm.utm_medium ? ' / ' + utm.utm_medium : ''}${utm.utm_campaign ? ' / ' + utm.utm_campaign : ''}`
        : '-';

      return `<tr>
        <td>${l.name || '-'}</td>
        <td>${l.email ? `<a href="mailto:${l.email}" style="color:#60a5fa;">${l.email}</a>` : '-'}</td>
        <td>${l.phone ? `<a href="tel:${l.phone}" style="color:#60a5fa;">${l.phone}</a>` : '-'}</td>
        <td>${(l.sources || []).join(', ') || '-'}</td>
        <td>${labels || '-'}</td>
        <td><span class="lead-count">${l.submission_count || 1}</span></td>
        <td><span class="lead-utm">${utmStr}</span></td>
        <td style="white-space:nowrap;font-size:13px;color:rgba(255,255,255,0.5);">${formatDate(l.updated_at || l.created_at)}</td>
      </tr>`;
    }).join('');
  }

  async function loadLeads() {
    if (!leadsBody) return;
    leadsBody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:rgba(255,255,255,0.4);">Laddar...</td></tr>';
    try {
      const res = await fetch('/api/leads?source=all', { headers: getAuthHeaders() });
      allLeads = await res.json();
      renderLeads();
    } catch {
      leadsBody.innerHTML = '<tr><td colspan="8" style="color:#EF4444;">Kunde inte ladda leads.</td></tr>';
    }
  }

  // Filter buttons
  document.querySelectorAll('.leads-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.leads-filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      leadsFilter = (btn as HTMLElement).dataset.filter || 'all';
      renderLeads();
    });
  });

  // Search
  leadsSearch?.addEventListener('input', () => renderLeads());

  function initAdmin() {
    loadAnnouncement();
    loadCars();
    loadSubmissions();
    loadSubscribers();
    loadRedirects();
    loadLeads();
  }

  // Run init if already logged in
  if (sessionStorage.getItem(SESSION_KEY) === 'authenticated') {
    initAdmin();
  }
</script>
</body>
</html>
