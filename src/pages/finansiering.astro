---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Bilfinansiering Luleå — Billån snabbt besked | Begbilnorr"
  description="Finansiera ditt bilköp hos Begbilnorr i Luleå. Flexibla billån med snabbt besked och konkurrenskraftig ränta. Ansök idag!"
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
        FINANSIERING
      </div>
      <h1>Bilfinansiering</h1>
      <p>Flexibla billån med snabbt besked -- vi hittar den bästa lösningen för dig.</p>
      <div class="hero-line"></div>
    </div>
  </section>

  <!-- About Financing -->
  <section class="finance-about">
    <div class="container">
      <div class="finance-grid">
        <div class="finance-text">
          <h2>Enkel bilfinansiering</h2>
          <p>Vi samarbetar med flera banker och kreditinstitut för att hitta den bästa finansieringslösningen för dig. Oavsett om du vill betala hela beloppet direkt eller dela upp det i månatliga betalningar, har vi en lösning som passar.</p>
          <p>Ansök om billån enkelt och smidigt -- vi ger dig oftast besked samma dag.</p>

          <div class="finance-features">
            <div class="finance-feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Snabbt lånebesked -- oftast samma dag</span>
            </div>
            <div class="finance-feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Konkurrenskraftig ränta</span>
            </div>
            <div class="finance-feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Flexibla löptider</span>
            </div>
            <div class="finance-feature">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <span>Personlig rådgivning</span>
            </div>
          </div>
        </div>
        <div class="finance-image-placeholder" style="padding:0;overflow:hidden;">
          <img src="/images/finansiering.webp" alt="Finansieringsrådgivning hos Begbilnorr i Luleå" width="895" height="1200" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Loan Calculator -->
  <section class="calculator-section" id="kalkylator">
    <div class="container">
      <div class="section-label" style="text-align:center;">LÅNEKALKYLATOR</div>
      <h2 class="section-heading" style="text-align:center;margin-bottom:8px;">Beräkna din månadskostnad</h2>
      <p class="calculator-subtitle">Justera belopp, insats och löptid för att se vad det kostar per månad</p>

      <div class="calculator-card">
        <div class="calc-grid">
          <!-- Inputs -->
          <div class="calc-inputs">
            <div class="slider-group">
              <div class="slider-label">
                <label>Bilpris</label>
                <span class="slider-value" id="priceDisplay">150 000 kr</span>
              </div>
              <input type="range" id="priceSlider" min="50000" max="500000" step="5000" value="150000">
            </div>

            <div class="slider-group">
              <div class="slider-label">
                <label>Kontantinsats</label>
                <span class="slider-value" id="downDisplay">20% (30 000 kr)</span>
              </div>
              <input type="range" id="downSlider" min="0" max="50" step="5" value="20">
            </div>

            <div class="slider-group">
              <div class="slider-label">
                <label>Löptid</label>
                <span class="slider-value" id="termDisplay">12 år</span>
              </div>
              <input type="range" id="termSlider" min="12" max="144" step="12" value="144">
            </div>

            <div class="rate-display">
              <label>Ränta (rörlig)</label>
              <span class="rate-value">8,95%</span>
            </div>
          </div>

          <!-- Results -->
          <div class="calc-results">
            <div class="result-label">Månadskostnad</div>
            <div class="result-main" id="monthlyPayment">2 374 kr</div>
            <div class="result-suffix">per månad</div>

            <div class="result-divider"></div>

            <div class="result-row">
              <span class="row-label">Lånebelopp</span>
              <span class="row-value" id="loanAmount">120 000 kr</span>
            </div>
            <div class="result-row">
              <span class="row-label">Kontantinsats</span>
              <span class="row-value" id="downPayment">30 000 kr</span>
            </div>
            <div class="result-row">
              <span class="row-label">Total kostnad</span>
              <span class="row-value" id="totalCost">142 463 kr</span>
            </div>
            <div class="result-row">
              <span class="row-label">Varav ränta</span>
              <span class="row-value" id="totalInterest">22 463 kr</span>
            </div>
          </div>

          <div class="flex-tip">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <div>
              <strong>Flexibel betalning</strong> — De flesta väljer att betala mer än minimibeloppet varje månad och blir snabbare färdiga med lånet. Har du en tuff månad? Betala bara minibeloppet. Nästa månad kan du betala extra och korta ner lånetiden.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="steps-section">
    <div class="container">
      <div class="section-label" style="text-align:center;">SÅ FUNGERAR DET</div>
      <h2 class="section-heading" style="text-align:center;margin-bottom:48px;">Tre enkla steg</h2>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <div class="step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3>Hitta din bil</h3>
          <p>Bläddra bland våra bilar och hitta den som passar dig. Alla bilar kan finansieras.</p>
        </div>
        <div class="step-card">
          <div class="step-number">2</div>
          <div class="step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3>Ansök om lån</h3>
          <p>Kontakta oss så hjälper vi dig med ansökan. Vi behöver bara grundläggande uppgifter.</p>
        </div>
        <div class="step-card">
          <div class="step-number">3</div>
          <div class="step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          </div>
          <h3>Hämta bilen</h3>
          <p>När lånet är klart hämtar du bilen -- eller så levererar vi den hem till dig!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <div class="section-label" style="text-align:center;">VANLIGA FRÅGOR</div>
      <h2 class="section-heading" style="text-align:center;margin-bottom:48px;">Frågor om finansiering</h2>
      <div class="faq-container">
        <div class="faq-item">
          <button class="faq-question" data-faq-toggle>
            <span>Vilka krav finns för att få bilfinansiering?</span>
            <div class="faq-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Du behöver vara minst 18 år, ha en fast inkomst och vara folkbokförd i Sverige. Vi gör en kreditbedömning för att säkerställa att lånet passar din ekonomi. Kontakta oss om du har frågor kring dina möjligheter.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" data-faq-toggle>
            <span>Kan jag lösa lånet i förtid?</span>
            <div class="faq-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Ja, du kan alltid lösa ditt billån i förtid utan extra kostnad. Du betalar då bara kvarvarande kapital plus eventuell upplupen ränta fram till inlösendagen. Kontakta oss så hjälper vi dig med detaljerna.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" data-faq-toggle>
            <span>Vad händer om jag missar en betalning?</span>
            <div class="faq-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Om du missar en betalning skickas en påminnelse med en liten avgift. Det är viktigt att betala i tid för att undvika ytterligare kostnader. Kontakta oss eller långivaren direkt om du har svårt att betala så hittar vi en lösning tillsammans.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" data-faq-toggle>
            <span>Kan jag finansiera även om jag har betalningsanmärkning?</span>
            <div class="faq-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Det beror på anmärkningens art och ålder. I vissa fall kan finansiering godkännas med en högre insats eller kortare löptid. Kontakta oss så gör vi en bedömning av just din situation helt utan förpliktelser.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" data-faq-toggle>
            <span>Ingår försäkring i finansieringen?</span>
            <div class="faq-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Nej, försäkring ingår inte i finansieringen men vi erbjuder 1 månads kostnadsfri helförsäkring vid köp. Därefter behöver du teckna egen bilförsäkring. Vi kan hjälpa dig jämföra alternativ från olika försäkringsbolag.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container" style="text-align:center;">
      <h2>Redo att komma igång?</h2>
      <p>Kontakta oss idag för att diskutera finansieringsmöjligheter.</p>
      <div class="cta-buttons">
        <a href="/kontakt" class="btn-primary">Kontakta oss</a>
        <a href="/bilar" class="btn-outline">Se våra bilar</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .finance-about {
    background: var(--bg-dark-2);
    padding: 80px 0;
  }

  .finance-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .finance-text h2 {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 24px;
  }

  .finance-text p {
    font-size: 16px;
    color: rgba(255,255,255,0.65);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .finance-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 28px;
  }

  .finance-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255,255,255,0.85);
    font-size: 15px;
    font-weight: 500;
  }

  .finance-feature svg {
    color: var(--red);
    flex-shrink: 0;
  }

  .finance-image-placeholder {
    background: linear-gradient(135deg, var(--bg-dark-5) 0%, var(--bg-dark-4) 100%);
    border-radius: 8px;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.1);
    position: relative;
  }

  .finance-image-placeholder::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--red);
  }

  /* ========== LOAN CALCULATOR ========== */
  .calculator-section {
    background: var(--bg-dark-3);
    padding: 80px 0 88px;
    border-top: 1px solid rgba(255,255,255,0.06);
    scroll-margin-top: 100px;
  }

  .calculator-subtitle {
    text-align: center;
    font-size: 15px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 48px;
  }

  .calculator-card {
    max-width: 820px;
    margin: 0 auto;
    background: var(--bg-dark-4);
    border-radius: 12px;
    padding: 48px 40px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .slider-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .slider-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .slider-label label {
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
  }

  .slider-label .slider-value {
    font-size: 15px;
    font-weight: 700;
    color: var(--red);
  }

  /* Custom range slider */
  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: rgba(255,255,255,0.1);
    outline: none;
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--red);
    cursor: pointer;
    border: 3px solid var(--bg-dark-4);
    box-shadow: 0 2px 8px rgba(230, 46, 45, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 3px 12px rgba(230, 46, 45, 0.5);
  }

  input[type="range"]::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--red);
    cursor: pointer;
    border: 3px solid var(--bg-dark-4);
    box-shadow: 0 2px 8px rgba(230, 46, 45, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  input[type="range"]::-moz-range-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 3px 12px rgba(230, 46, 45, 0.5);
  }

  .rate-display {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    background: rgba(230, 46, 45, 0.08);
    border-radius: 8px;
    border: 1px solid rgba(230, 46, 45, 0.15);
  }

  .rate-display label {
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
  }

  .rate-display .rate-value {
    font-size: 16px;
    font-weight: 700;
    color: var(--red);
  }

  /* Results panel */
  .calc-results {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--bg-dark-5);
    border-radius: 12px;
    padding: 36px 32px;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .calc-results .result-label {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .calc-results .result-main {
    font-size: 40px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -1px;
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .calc-results .result-suffix {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 28px;
  }

  .calc-results .result-divider {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-bottom: 24px;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .result-row:last-child {
    margin-bottom: 0;
  }

  .result-row .row-label {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
  }

  .result-row .row-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
  }

  .flex-tip {
    display: flex;
    gap: 12px;
    background: rgba(46, 204, 113, 0.08);
    border: 1px solid rgba(46, 204, 113, 0.2);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 20px;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
  }

  .flex-tip svg {
    flex-shrink: 0;
    color: #2ecc71;
    margin-top: 2px;
  }

  .flex-tip strong {
    color: #2ecc71;
  }

  /* ========== STEPS ========== */
  .steps-section {
    background: var(--bg-dark-2);
    padding: 100px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .step-card {
    background: var(--bg-dark-4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 40px 28px;
    text-align: center;
    position: relative;
    transition: all 0.3s;
  }

  .step-card:hover {
    border-color: rgba(230,46,45,0.3);
    transform: translateY(-4px);
  }

  .step-number {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 32px;
    background: var(--red);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
  }

  .step-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(230,46,45,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 8px auto 20px;
    color: var(--red);
  }

  .step-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }

  .step-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  /* ========== FAQ ========== */
  .faq-section {
    background: var(--bg-dark-3);
    padding: 80px 0 88px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .faq-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-dark-4);
    border-radius: 12px;
    margin-bottom: 12px;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .faq-item:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .faq-item.active {
    border-color: rgba(230, 46, 45, 0.3);
