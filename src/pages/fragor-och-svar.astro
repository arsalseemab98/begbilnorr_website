---
import Layout from '../components/Layout.astro';
import StructuredData from '../components/StructuredData.astro';

const categories = [
  {
    title: 'Om Begbilnorr',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
    items: [
      { question: 'Var ligger Begbilnorr?', answer: 'Vi finns på Fabriksvägen 18 i Luleå, Norrbotten. Välkommen att besöka oss på plats eller kontakta oss via telefon, e-post eller WhatsApp för mer information.' },
      { question: 'Vilka öppettider har ni?', answer: 'Vi har öppet måndag–fredag 09:00–18:00 och lördag–söndag 10:00–18:00. På helger rekommenderar vi att boka tid i förväg. Ring oss på 0920-999 86 eller maila info@begbilnorr.se.' },
      { question: 'Kan jag provköra en bil innan köp?', answer: 'Ja, självklart! Vi erbjuder provkörning på alla våra bilar. Kontakta oss för att boka en tid som passar dig.' },
      { question: 'Erbjuder ni hemleverans?', answer: 'Ja, vi kan leverera bilen hem till dig inom Norrbotten. Kontakta oss för att diskutera leveransalternativ och eventuella kostnader.' },
    ]
  },
  {
    title: 'Bilköp & Garanti',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    items: [
      { question: 'Har ni garanti på begagnade bilar?', answer: 'Ja! Alla våra bilar säljs med garanti. Vi kvalitetskontrollerar varje fordon innan försäljning för att säkerställa att du får en pålitlig bil.' },
      { question: 'Hur kontrolleras bilarna innan försäljning?', answer: 'Varje bil genomgår en grundlig kontroll som inkluderar motor, bromsar, chassi, elektronik och övriga viktiga komponenter. Vi åtgärdar eventuella brister innan bilen läggs ut till försäljning.' },
      { question: 'Kan jag byta in min nuvarande bil?', answer: 'Ja, vi tar emot inbyten. Kontakta oss med uppgifter om din bil så ger vi dig ett värderingserbjudande. Vi hanterar hela processen smidigt.' },
      { question: 'Vad ingår i priset?', answer: 'Priset som visas på hemsidan är det totala priset inklusive moms (VMB). Inga dolda avgifter tillkommer.' },
      { question: 'Kan jag reservera en bil?', answer: 'Ja, du kan reservera en bil genom att kontakta oss. Vi håller bilen reserverad under en överenskommen tid medan du ordnar betalning eller finansiering.' },
    ]
  },
  {
    title: 'Betalning & Swish',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>',
    items: [
      { question: 'Vilka betalningsmetoder accepterar ni?', answer: 'Vi accepterar Swish, banköverföring och kontant betalning. Vi erbjuder även finansiering genom våra samarbetspartners.' },
      { question: 'Kan jag betala hela bilen med Swish?', answer: 'Ja, om din Swish-gräns är tillräckligt hög. De flesta banker tillåter att du höjer gränsen till 150 000 kr eller mer. Kontakta din bank för att höja gränsen innan köpet.' },
      { question: 'Kostar det något extra att betala med Swish?', answer: 'Nej, vi tar inga extra avgifter för Swish-betalning. Det är helt kostnadsfritt för dig som köpare.' },
      { question: 'Hur snabbt går en Swish-betalning?', answer: 'Swish-betalningar är i regel klara inom några sekunder. Du får en bekräftelse direkt i appen och vi ser pengarna omedelbart.' },
      { question: 'Kan jag dela upp betalningen i flera Swish-överföringar?', answer: 'Ja, om din Swish-gräns inte räcker för hela beloppet kan du göra flera överföringar. Vi kan även kombinera Swish med andra betalningsmetoder.' },
      { question: 'Hur höjer jag min Swish-gräns?', answer: 'Varje bank har sitt eget sätt att höja gränsen — oftast via internetbanken eller appen. Se vår detaljerade guide per bank på sidan "Höja Swish-gräns".' },
    ]
  },
  {
    title: 'Finansiering',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
    items: [
      { question: 'Vilka krav finns för att få bilfinansiering?', answer: 'Grundkraven är att du är minst 18 år, har fast inkomst och inte har allvarliga betalningsanmärkningar. Varje ansökan bedöms individuellt.' },
      { question: 'Hur lång avbetalningstid kan jag välja?', answer: 'Du kan vanligtvis välja avbetalningstid mellan 12 och 84 månader beroende på bilens värde och din ekonomiska situation.' },
      { question: 'Kan jag lösa lånet i förtid?', answer: 'Ja, du kan alltid lösa ditt billån i förtid utan extra kostnader. Kontakta långivaren för att få en slutbetalningssumma.' },
      { question: 'Vad händer om jag missar en betalning?', answer: 'Om du missar en betalning bör du kontakta långivaren snarast. De kan ofta hjälpa till med en lösning, som en betalningsplan eller en kortare uppskovstid.' },
      { question: 'Kan jag finansiera även om jag har betalningsanmärkning?', answer: 'Det beror på anmärkningens art och ålder. Vissa finansbolag kan godkänna ansökningar med äldre eller mindre anmärkningar. Kontakta oss så hjälper vi dig.' },
    ]
  },
  {
    title: 'Sälj din bil',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>',
    items: [
      { question: 'Hur gör jag om jag vill sälja min bil?', answer: 'Kontakta oss med uppgifter om din bil — märke, modell, årsmodell, miltal och skick. Du kan ringa, maila eller använda formuläret på vår sida "Sälj din bil". Vi ger dig ett värderings­erbjudande snabbt.' },
      { question: 'Hur snabbt kan jag sälja min bil?', answer: 'Vi kan ofta ge dig ett bud samma dag och genomföra affären inom ett par dagar. Betalning sker direkt via Swish eller banköverföring.' },
      { question: 'Behöver bilen vara besiktigad?', answer: 'Nej, bilen behöver inte vara besiktigad för att vi ska köpa den. Vi gör en egen bedömning av bilens skick och värde.' },
      { question: 'Köper ni bilar med lån kvar?', answer: 'Ja, vi kan köpa bilar med kvarvarande lån. Vi hjälper till att lösa lånet som en del av affären.' },
    ]
  },
];

const totalQuestions = categories.reduce((sum, cat) => sum + cat.items.length, 0);

const allFaqItems = categories.flatMap(cat => cat.items);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": allFaqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Vanliga frågor — FAQ om bilköp, Swish & finansiering | Begbilnorr"
  description="Svar på vanliga frågor om att köpa begagnad bil hos Begbilnorr i Luleå. Läs om garanti, betalning med Swish, finansiering, inbyte och mer."
>
  <StructuredData data={faqSchema} />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
        VANLIGA FRÅGOR
      </div>
      <h1>Frågor och svar</h1>
      <p>Hitta svar på de vanligaste frågorna om att köpa bil, betalning, finansiering och mer hos Begbilnorr i Luleå.</p>
      <div class="hero-line"></div>
    </div>
  </section>

  <!-- Category Cards -->
  <section class="faq-categories">
    <div class="container">
      <div class="faq-cat-grid">
        {categories.map((cat, i) => (
          <a href={`#kategori-${i}`} class="faq-cat-card">
            <div class="faq-cat-icon" set:html={cat.icon} />
            <div class="faq-cat-info">
              <h3>{cat.title}</h3>
              <span>{cat.items.length} frågor</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Sections -->
  {categories.map((cat, catIndex) => (
    <section class="faq-section" id={`kategori-${catIndex}`}>
      <div class="container">
        <div class="faq-section-header">
          <div class="section-label">{cat.title.toUpperCase()}</div>
          <h2 class="section-heading">{cat.title}</h2>
        </div>
        <div class="faq-list">
          {cat.items.map((item, itemIndex) => (
            <div class="faq-item">
              <button class="faq-question" data-faq-toggle>
                <div class="faq-q-left">
                  <span class="faq-num">{String(itemIndex + 1).padStart(2, '0')}</span>
                  <span>{item.question}</span>
                </div>
                <div class="faq-chevron">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </div>
              </button>
              <div class="faq-answer">
                <div class="faq-answer-inner">
                  <p>{item.answer}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA Section -->
  <section class="faq-cta">
    <div class="container">
      <div class="faq-cta-card">
        <div class="faq-cta-content">
          <div class="section-label">BEHÖVER DU HJÄLP?</div>
          <h2>Hittar du inte svaret?</h2>
          <p>Kontakta oss direkt så hjälper vi dig med alla dina frågor. Vi svarar snabbt via telefon, WhatsApp eller e-post.</p>
          <div class="faq-cta-buttons">
            <a href="/kontakt" class="btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Kontakta oss
            </a>
            <a href="tel:0920-99986" class="btn-outline">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Ring 0920-999 86
            </a>
          </div>
        </div>
        <div class="faq-cta-contact">
          <div class="faq-contact-row">
            <div class="faq-contact-item">
              <div class="faq-contact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <div class="faq-contact-label">Telefon</div>
                <a href="tel:0920-99986" class="faq-contact-value">0920-999 86</a>
              </div>
            </div>
            <div class="faq-contact-item">
              <div class="faq-contact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <div class="faq-contact-label">E-post</div>
                <a href="mailto:info@begbilnorr.se" class="faq-contact-value">info@begbilnorr.se</a>
              </div>
            </div>
            <div class="faq-contact-item">
              <div class="faq-contact-icon">
                <svg viewBox="0 0 448 512" width="20" height="20" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
              </div>
              <div>
                <div class="faq-contact-label">WhatsApp</div>
                <a href="https://wa.me/46727448034" target="_blank" rel="noopener" class="faq-contact-value">0727 448 034</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ========== CATEGORY CARDS ========== */
  .faq-categories {
    background: var(--bg-dark-2);
    padding: 48px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .faq-cat-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .faq-cat-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px;
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.3s;
  }

  .faq-cat-card:hover {
    border-color: rgba(230,46,45,0.3);
    background: rgba(230,46,45,0.04);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .faq-cat-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(230,46,45,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--red);
    flex-shrink: 0;
  }

  .faq-cat-info h3 {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 2px;
  }

  .faq-cat-info span {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }

  /* ========== FAQ SECTIONS ========== */
  .faq-section {
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .faq-section:nth-child(odd) {
    background: var(--bg-dark-2);
  }

  .faq-section:nth-child(even) {
    background: var(--bg-dark-3);
  }

  .faq-section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .faq-section-header .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .faq-section-header .section-heading {
    margin-bottom: 0;
  }

  /* ========== FAQ ITEMS ========== */
  .faq-list {
    max-width: 780px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-dark-4);
    border-radius: var(--radius-lg);
    margin-bottom: 12px;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .faq-item:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .faq-item.active {
    border-color: rgba(230,46,45,0.3);
    box-shadow: 0 4px 20px rgba(230,46,45,0.06);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    text-align: left;
    transition: color 0.2s;
    gap: 16px;
  }

  .faq-question:hover { color: var(--red); }
  .faq-item.active .faq-question { color: var(--red); }

  .faq-q-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .faq-num {
    font-size: 12px;
    font-weight: 700;
    color: var(--red);
    opacity: 0.5;
    font-family: var(--sans);
    min-width: 20px;
  }

  .faq-item.active .faq-num {
    opacity: 1;
  }

  .faq-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    flex-shrink: 0;
    transition: transform 0.3s, background 0.3s, color 0.3s;
    color: rgba(255,255,255,0.4);
  }

  .faq-item.active .faq-chevron {
    transform: rotate(180deg);
    background: var(--red);
    color: var(--white);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .faq-item.active .faq-answer {
    max-height: 300px;
  }

  .faq-answer-inner {
    padding: 0 24px 24px 60px;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .faq-answer-inner p {
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    padding-top: 20px;
  }

  /* ========== CTA ========== */
  .faq-cta {
    background: var(--bg-dark-2);
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .faq-cta-card {
    background: var(--bg-dark-3);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .faq-cta-content {
    padding: 48px;
    text-align: center;
  }

  .faq-cta-content .section-label {
    display: inline-flex;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .faq-cta-content h2 {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 12px;
  }

  .faq-cta-content p {
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    max-width: 500px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .faq-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .faq-cta-buttons .btn-primary,
  .faq-cta-buttons .btn-outline {
    gap: 8px;
  }

  .faq-cta-contact {
    background: var(--bg-dark-4);
    padding: 28px 48px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .faq-contact-row {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .faq-contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .faq-contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(230,46,45,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--red);
    flex-shrink: 0;
  }

  .faq-contact-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2px;
  }

  .faq-contact-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--red);
    text-decoration: none;
    transition: color 0.2s;
  }

  .faq-contact-value:hover {
    color: var(--red-light);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .faq-cat-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .faq-categories {
      padding: 32px 0;
    }

    .faq-cat-grid {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .faq-cat-card {
      padding: 14px;
      gap: 10px;
    }

    .faq-cat-icon {
      width: 36px;
      height: 36px;
    }

    .faq-cat-icon :global(svg) {
      width: 16px;
      height: 16px;
    }

    .faq-cat-info h3 {
