---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Bilskatt-kollare 2026 | Räkna ut fordonsskatten — Begbilnorr"
  description="Räkna ut din bils fordonsskatt 2026. Bonus-malus, viktbaserad skatt, miljöbilar — fyll i uppgifterna och få en uppskattad årlig skatt."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11h-6"/><path d="M19 8v6"/></svg>
        BILSKATT-KOLLARE
      </div>
      <h1>Räkna ut din bilskatt</h1>
      <p>Ange grunduppgifter om din bil — vi räknar ut den årliga fordonsskatten enligt 2026 års regler.</p>
      <div class="hero-line"></div>
    </div>
  </section>

  <section class="tool-section">
    <div class="container">
      <div class="tool-card">
        <div class="tool-grid">
          <div class="tool-inputs">
            <h2 class="tool-h2">Din bil</h2>

            <div class="input-group">
              <label for="regYear">Registreringsår</label>
              <input type="number" id="regYear" class="tool-input" placeholder="2020" min="1990" max="2026" value="2020" />
              <small class="input-hint">Bilar reg. efter 2018-07-01 = bonus-malus</small>
            </div>

            <div class="input-group">
              <label for="fuel">Drivmedel</label>
              <select id="fuel" class="tool-input">
                <option value="petrol">Bensin</option>
                <option value="diesel">Diesel</option>
                <option value="hybrid">Hybrid</option>
                <option value="electric">El</option>
                <option value="ethanol">Etanol/E85</option>
                <option value="gas">Gas</option>
              </select>
            </div>

            <div class="input-group">
              <label for="co2">CO₂-utsläpp (g/km)</label>
              <input type="number" id="co2" class="tool-input" placeholder="120" min="0" max="500" value="120" />
              <small class="input-hint">Står i registreringsbeviset (WLTP eller NEDC). 0 för elbil.</small>
            </div>

            <div class="input-group">
              <label for="weight">Tjänstevikt (kg)</label>
              <input type="number" id="weight" class="tool-input" placeholder="1500" min="500" max="5000" value="1500" />
              <small class="input-hint">Används för bilar reg. innan 2018-07-01.</small>
            </div>

            <button id="calculateBtn" class="btn-primary tool-btn">Räkna ut skatten</button>
          </div>

          <div class="tool-results" id="results">
            <div class="result-placeholder" id="placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <p>Fyll i uppgifterna och klicka på "Räkna ut skatten"</p>
            </div>

            <div class="result-content" id="resultContent" style="display:none;">
              <div class="result-label">Årlig fordonsskatt</div>
              <div class="result-main" id="annualTax">— kr</div>
              <div class="result-suffix" id="taxSystem">per år</div>

              <div class="result-divider"></div>

              <div class="result-row">
                <span class="row-label">Per månad</span>
                <span class="row-value" id="monthlyTax">—</span>
              </div>
              <div class="result-row" id="malusRow" style="display:none;">
                <span class="row-label">Förhöjt malus år 1–3</span>
                <span class="row-value" id="malusValue">—</span>
              </div>
              <div class="result-row" id="bonusRow" style="display:none;">
                <span class="row-label">Klimatbonus (engångs)</span>
                <span class="row-value" id="bonusValue">—</span>
              </div>
              <div class="result-row">
                <span class="row-label">Skattesystem</span>
                <span class="row-value" id="systemValue">—</span>
              </div>

              <div class="flex-tip" id="tipBox">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <div id="tipText">
                  <strong>Tips:</strong> Bilskatten betalas årligen till Transportstyrelsen. För exakt belopp — se ditt registreringsbevis eller logga in på Mina sidor.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="disclaimer">
        <p>⚠️ Denna kalkyl är ett estimat. Exakt skatt avgörs av Transportstyrelsen och beror även på dieselbilars förbrukning, friår, kommun m.m. Klimatbonus för elbilar avskaffades 2022-11-08. Bonus-malus systemet justerades 2025.</p>
      </div>
    </div>
  </section>

  <section class="info-section">
    <div class="container">
      <h2 class="section-heading" style="text-align:center;margin-bottom:48px;">Bilskatt i Sverige — så funkar det</h2>
      <div class="info-grid">
        <div class="info-card">
          <h3>📅 Bilar reg. före 2018-07-01</h3>
          <p>Viktbaserad fordonsskatt. Grundskatt 360 kr + tilläggsskatt per 100 kg över 900 kg. Dieselbilar har ett bränsletillägg.</p>
        </div>
        <div class="info-card">
          <h3>🚗 Bilar reg. efter 2018-07-01</h3>
          <p>Bonus-malus. Förhöjd skatt (malus) första 3 åren baserat på CO₂. Sedan år 4: 360 kr + 22 kr/g CO₂ över 75 g.</p>
        </div>
        <div class="info-card">
          <h3>⚡ Elbilar &amp; hybrider</h3>
          <p>Elbilar och laddhybrider betalar lägre skatt. Klimatbonus för nybilsköp avskaffades 2022. Begagnade elbilar har låg eller ingen skatt.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container" style="text-align:center;">
      <h2>Letar du efter en låg-skatt-bil?</h2>
      <p>Se våra hybrid- och elbilar i Luleå — många med under 2 000 kr i årlig skatt.</p>
      <div class="cta-buttons">
        <a href="/bilar" class="btn-primary">Se våra bilar</a>
        <a href="/kontakt" class="btn-outline">Kontakta oss</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tool-section {
    background: var(--bg-dark-3);
    padding: 80px 0 40px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .tool-card {
    max-width: 980px;
    margin: 0 auto;
    background: var(--bg-dark-4);
    border-radius: 12px;
    padding: 48px 40px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .tool-h2 {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 24px;
  }

  .tool-inputs {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .input-group label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .input-hint {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin-top: 2px;
  }

  .tool-input {
    background: var(--bg-dark-5);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 12px 14px;
    color: var(--white);
    font-family: var(--sans);
    font-size: 15px;
    transition: border-color 0.2s;
  }

  .tool-input:focus {
    outline: none;
    border-color: var(--red);
  }

  select.tool-input {
    cursor: pointer;
  }

  .tool-btn {
    margin-top: 8px;
    width: 100%;
    justify-content: center;
  }

  .tool-results {
    background: var(--bg-dark-5);
    border-radius: 12px;
    padding: 36px 32px;
    border: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .result-placeholder {
    text-align: center;
    color: rgba(255,255,255,0.3);
    padding: 40px 0;
  }

  .result-placeholder svg {
    margin: 0 auto 16px;
    display: block;
  }

  .result-placeholder p {
    font-size: 15px;
  }

  .result-label {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .result-main {
    font-size: 40px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -1px;
    line-height: 1.2;
  }

  .result-suffix {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
    margin-bottom: 24px;
  }

  .result-divider {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-bottom: 20px;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .result-row .row-label {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
  }

  .result-row .row-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
  }

  .flex-tip {
    display: flex;
    gap: 12px;
    background: rgba(46, 204, 113, 0.08);
    border: 1px solid rgba(46, 204, 113, 0.2);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 20px;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
  }

  .flex-tip svg {
    flex-shrink: 0;
    color: #2ecc71;
    margin-top: 2px;
  }

  .flex-tip strong {
    color: #2ecc71;
  }

  .disclaimer {
    max-width: 820px;
    margin: 24px auto 0;
    padding: 16px 20px;
    background: rgba(255,255,255,0.03);
    border-left: 3px solid rgba(255,255,255,0.2);
    border-radius: 4px;
  }

  .disclaimer p {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin: 0;
  }

  .info-section {
    background: var(--bg-dark-2);
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .info-card {
    background: var(--bg-dark-4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 32px 24px;
  }

  .info-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 14px;
  }

  .info-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  .cta-section {
    background: var(--bg-dark-3);
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .cta-section h2 {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    margin-bottom: 12px;
  }

  .cta-section p {
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
    .tool-card {
      padding: 32px 20px;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script is:inline>
  (function() {
    function formatNumber(num) {
      return Math.round(num).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
    }

    function calculate() {
      var regYear = parseInt(document.getElementById('regYear').value);
      var fuel = document.getElementById('fuel').value;
      var co2 = parseInt(document.getElementById('co2').value) || 0;
      var weight = parseInt(document.getElementById('weight').value) || 1500;

      if (!regYear || regYear < 1990 || regYear > 2026) {
        alert('Fyll i ett giltigt registreringsår');
        return;
      }

      var annualTax = 0;
      var system = '';
      var malus = 0;
      var bonus = 0;
      var tipText = '';

      // Bonus-malus gäller bilar reg. fr.o.m. 2018-07-01
      var bonusMalus = regYear >= 2019 || (regYear === 2018 && false); // Förenkling: anta att 2018+ kan vara bonus-malus

      if (fuel === 'electric') {
        // Elbilar: 360 kr grundskatt
        annualTax = 360;
        system = 'Elbil — schablon';
        tipText = '<strong>Elbil:</strong> Schablonskatt 360 kr/år. Klimatbonus avskaffades 2022-11-08.';
      } else if (bonusMalus) {
        // Bonus-malus (förenklad 2026-modell)
        // Förhöjd skatt år 1-3: 107 kr/g CO2 över 75 g + 132 kr/g över 125 g
        // År 4+: 360 kr + 22 kr/g CO2 över 75 g
        system = 'Bonus-malus (2018-07-01+)';

        var co2Excess1 = Math.max(0, co2 - 75);
        var co2Excess2 = Math.max(0, co2 - 125);

        // Standardskatt år 4+
        annualTax = 360 + (co2Excess1 * 22);

        // Malus år 1-3 (förhöjd skatt)
        if (regYear >= new Date().getFullYear() - 2) {
          malus = 360 + (co2Excess1 * 107) + (co2Excess2 * 132);
          tipText = '<strong>Malus aktivt:</strong> Förhöjd skatt under de första 3 åren från registrering. Efter år 3 sänks skatten till ' + formatNumber(annualTax) + ' kr/år.';
        } else {
          tipText = '<strong>Efter malus-perioden:</strong> Skatten beräknas på 360 kr + 22 kr/g CO₂ över 75 g.';
        }

        // Dieseltillägg
        if (fuel === 'diesel') {
          annualTax += 250; // förenkling
          if (malus > 0) malus += 250;
          tipText += ' Dieseltillägg: +250 kr (förenkling — beror på förbrukning).';
        }
      } else {
        // Viktbaserad (gamla regler, bilar före 2018-07-01)
        system = 'Viktbaserad (före 2018-07-01)';
        var weightExcess = Math.max(0, Math.ceil((weight - 900) / 100));
        annualTax = 360 + (weightExcess * 36);

        if (fuel === 'diesel') {
          annualTax = annualTax * 2.2 + 250; // diesel-multiplikator (förenkling)
        }
        tipText = '<strong>Viktbaserad skatt:</strong> Beräknas på tjänstevikten. Diesel har ett bränsletillägg.';
      }

      if (fuel === 'hybrid' && annualTax > 360) {
        annualTax = annualTax * 0.85; // hybrid-rabatt (förenkling)
        tipText += ' Hybrid: rabatterad skatt.';
      }

      // Display
      document.getElementById('placeholder').style.display = 'none';
      document.getElementById('resultContent').style.display = 'block';

      document.getElementById('annualTax').textContent = formatNumber(annualTax) + ' kr';
      document.getElementById('monthlyTax').textContent = formatNumber(annualTax / 12) + ' kr';
      document.getElementById('systemValue').textContent = system;
      document.getElementById('tipText').innerHTML = tipText;

      if (malus > 0 && malus !== annualTax) {
        document.getElementById('malusRow').style.display = 'flex';
        document.getElementById('malusValue').textContent = formatNumber(malus) + ' kr/år';
      } else {
        document.getElementById('malusRow').style.display = 'none';
      }

      document.getElementById('bonusRow').style.display = 'none';
    }

    document.getElementById('calculateBtn').addEventListener('click', calculate);
  })();
</script>
