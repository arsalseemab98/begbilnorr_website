---
import Layout from '../components/Layout.astro';
import StructuredData from '../components/StructuredData.astro';
import CarCard from '../components/CarCard.astro';
import { supabase } from '../lib/supabase';
import type { Car } from '../types/car';

let allCars: Car[] = [];
let brands: string[] = [];

try {
  const { data: cars } = await supabase
    .from('cars')
    .select('*')
    .eq('is_active', true)
    .eq('is_sold', false)
    .order('created_at', { ascending: false });

  allCars = (cars || []) as Car[];

  const { data: brandData } = await supabase
    .from('cars')
    .select('brand')
    .eq('is_active', true)
    .eq('is_sold', false);

  brands = [...new Set((brandData || []).map((c: { brand: string }) => c.brand))].sort();
} catch {
  // Supabase not configured
}

const faqItems = [
  {
    question: 'Har ni garanti på begagnade bilar?',
    answer: 'Ja, alla begagnade bilar hos Begbilnorr säljs med garanti. Vi kvalitetskontrollerar varje fordon noggrant innan det läggs ut till försäljning. Garantin ger dig trygghet och skydd mot oväntade kostnader efter köpet.'
  },
  {
    question: 'Kan jag finansiera mitt bilköp?',
    answer: 'Absolut! Vi erbjuder flexibla finansieringslösningar i samarbete med ledande kreditgivare. Du kan enkelt ansöka om billån direkt hos oss, och vi hjälper dig att hitta den bästa räntan och de mest förmånliga villkoren för just din situation.'
  },
  {
    question: 'Erbjuder ni hemleverans?',
    answer: 'Ja, vi levererar bilar hem till dig i hela Norrbotten och övriga Sverige. Oavsett om du bor i Luleå, Boden, Piteå eller längre bort kan vi ordna transport av din nya bil direkt till dörren.'
  },
  {
    question: 'Hur gör jag om jag vill sälja min bil?',
    answer: 'Kontakta oss så gör vi en kostnadsfri värdering av din bil. Vi köper begagnade bilar i alla prisklasser och kan ge dig ett konkurrenskraftigt bud snabbt. Besök oss i Luleå eller ring för en första bedömning.'
  },
  {
    question: 'Kan jag byta in min nuvarande bil?',
    answer: 'Ja, vi erbjuder inbytesvärdering på alla bilmärken. Att byta in din gamla bil mot en nyare modell är ett smidigt sätt att uppgradera — vi tar hand om hela processen åt dig.'
  },
  {
    question: 'Var ligger Begbilnorr?',
    answer: 'Begbilnorr finns i Luleå, Norrbotten. Besök oss för att provköra din drömbil eller kontakta oss via telefon på 0920-999 86 eller e-post info@begbilnorr.se för mer information.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Hem',
      item: 'https://begbilnorr.se/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Begagnade bilar i Luleå',
      item: 'https://begbilnorr.se/begagnade-bilar-lulea'
    }
  ]
};
---

<Layout
  title="Begagnade bilar i Luleå — Köp bil med garanti | Begbilnorr"
  description="Hitta begagnade bilar i Luleå hos Begbilnorr. Kvalitetskontrollerade bilar med garanti, finansiering och hemleverans. Luleås tryggaste bilhandlare."
>
  <Fragment slot="head">
    <StructuredData data={faqSchema} />
    <StructuredData data={breadcrumbSchema} />
  </Fragment>

  <!-- Page Hero -->
  <section class="seo-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Hem</a>
        <span class="separator">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <span class="current">Begagnade bilar i Luleå</span>
      </div>
      <h1>Begagnade bilar i Luleå</h1>
      <p class="hero-intro">
        Letar du efter en begagnad bil i Luleå? Hos Begbilnorr hittar du ett brett utbud av kvalitetskontrollerade begagnade bilar med garanti.
        Som Luleås tryggaste bilhandlare erbjuder vi personlig service, finansiering och hemleverans i hela Norrbotten.
        Varje bil i vårt lager har genomgått en noggrann kontroll så att du kan känna dig trygg med ditt köp.
        Oavsett om du söker en familjevänlig SUV, en bränslesnål hybrid eller en sportbil — vi har bilen för dig.
        Välkommen att bläddra bland våra bilar nedan eller besöka oss i Luleå för en provkörning.
      </p>
    </div>
  </section>

  <!-- Car Grid Section -->
  <section class="seo-cars-section">
    <div class="container">
      <div class="cars-header">
        <span class="section-label">VÅRT LAGER</span>
        <p class="cars-count">Visar <strong>{allCars.length}</strong> begagnade bilar i Luleå</p>
      </div>
      <div class="car-grid">
        {allCars.map((car) => <CarCard car={car} />)}
      </div>

      {allCars.length === 0 && (
        <div class="empty-state">
          <p>Inga bilar tillgängliga just nu.</p>
          <a href="/bilar">Visa alla bilar</a>
        </div>
      )}
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="benefits-section">
    <div class="container">
      <h2>Varför köpa begagnad bil hos Begbilnorr i Luleå?</h2>
      <p class="benefits-intro">
        Att köpa en begagnad bil är ett smart val, men det är viktigt att välja rätt bilhandlare.
        Begbilnorr i Luleå har sedan 2018 hjälpt tusentals kunder i Norrbotten att hitta sin drömbil.
        Vi skiljer oss från andra bilhandlare genom att alltid sätta kundens trygghet först.
      </p>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3>Garanti på alla bilar</h3>
          <p>Samtliga begagnade bilar i vårt sortiment säljs med garanti. Vi kvalitetskontrollerar varje fordon noggrant innan det erbjuds till försäljning, så att du som kund alltid kan känna dig trygg med ditt bilköp i Luleå.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
          </div>
          <h3>Flexibel finansiering</h3>
          <p>Vi samarbetar med flera kreditgivare för att erbjuda dig de bästa finansieringsvillkoren. Ansök om billån direkt hos oss och få snabbt besked. Vi hjälper dig att hitta en avbetalningsplan som passar din ekonomi.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
          </div>
          <h3>Hemleverans i Norrbotten</h3>
          <p>Bor du utanför Luleå? Inga problem! Vi levererar begagnade bilar hem till dig i hela Norrbotten och övriga Sverige. Från Boden och Piteå till Gällivare och Kiruna — vi ser till att din bil kommer hem till dig.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/><path d="m15 9 6-6"/></svg>
          </div>
          <h3>Inbyte av din gamla bil</h3>
          <p>Vill du byta in din nuvarande bil? Vi erbjuder rättvisa inbytespriser på alla bilmärken. Att byta in din gamla bil gör det enkelt och smidigt att uppgradera till en nyare modell hos Begbilnorr i Luleå.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Brands Section -->
  <section class="brands-section">
    <div class="container">
      <h2>Populära bilmärken i Luleå</h2>
      <p class="brands-intro">
        Utforska begagnade bilar efter märke. Vi har ett varierat utbud av bilmärken från välkända tillverkare.
        Klicka på ett märke nedan för att se alla tillgängliga begagnade bilar av det märket i Luleå.
      </p>
      <div class="brands-grid">
        {brands.map((b) => (
          <a href={`/begagnade-bilar-lulea/${b.toLowerCase()}`} class="brand-card">
            <span class="brand-name">{b}</span>
            <span class="brand-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </a>
        ))}
      </div>
      {brands.length === 0 && (
        <p class="no-brands">Inga bilmärken tillgängliga just nu.</p>
      )}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <h2>Vanliga frågor om begagnade bilar i Luleå</h2>
      <p class="faq-intro">
        Här svarar vi på de vanligaste frågorna vi får från kunder som letar efter begagnade bilar i Luleå och Norrbotten.
        Hittar du inte svaret på din fråga? Tveka inte att kontakta oss direkt.
      </p>
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              <span>{item.question}</span>
              <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`}>
              <p>{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="seo-content-section">
    <div class="container">
      <div class="seo-content">
        <h2>Din bilhandlare i Luleå</h2>
        <p>
          Begbilnorr är en av de mest etablerade bilhandlarna i Luleå och har verkat i Norrbotten sedan 2018.
          Vi har byggt vårt rykte genom att alltid leverera kvalitetskontrollerade begagnade bilar med garanti och utmärkt kundservice.
          Vår filosofi är enkel: varje kund ska känna sig trygg genom hela köpprocessen, från första besöket till långt efter leveransen.
        </p>
        <p>
          I vårt lager hittar du ett brett utbud av begagnade bilar från alla ledande bilmärken.
          Vi erbjuder allt från ekonomiska småbilar och familjevänliga kombibilar till kraftfulla SUV:ar och premium-modeller.
          Alla bilar har genomgått en grundlig teknisk kontroll och levereras med garanti för din trygghet.
        </p>
        <p>
          Som bilhandlare i Luleå förstår vi de speciella krav som det norrbottniska klimatet ställer på fordon.
          Därför ser vi extra noga till att våra begagnade bilar är redo för nordsvenska förhållanden —
          med kontrollerat underrede, fungerande uppvärmning och däck anpassade för säsongen.
          Köper du en begagnad bil hos oss kan du lita på att den klarar av både vintervägar och sommarens fjällturer.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container" style="text-align:center;">
      <h2>Hitta din drömbil idag</h2>
      <p>Bläddra bland våra kvalitetskontrollerade begagnade bilar i Luleå eller kontakta oss för personlig rådgivning. Vi hjälper dig hitta rätt bil till rätt pris.</p>
      <div class="cta-buttons">
        <a href="/bilar" class="btn-primary">Se alla bilar</a>
        <a href="/kontakt" class="btn-outline">Kontakta oss</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initFaqAccordion() {
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item') as HTMLElement;
        const isOpen = item.classList.contains('open');

        // Close all other items
        document.querySelectorAll('.faq-item.open').forEach((openItem) => {
          openItem.classList.remove('open');
          const openBtn = openItem.querySelector('.faq-question');
          if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
        });

        // Toggle current item
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaqAccordion();
  document.addEventListener('astro:after-swap', initFaqAccordion);
</script>

