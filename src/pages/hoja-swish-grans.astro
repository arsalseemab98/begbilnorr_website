<script is:inline>
  (function() {
    // Bank selector
    var bankBtns = document.querySelectorAll('[data-bank-id]');
    var bankDetails = document.querySelectorAll('[data-bank-detail]');
    var emptyState = document.querySelector('.bank-detail-empty');

    bankBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var bankId = this.getAttribute('data-bank-id');
        var isActive = this.classList.contains('active');

        // Reset all
        bankBtns.forEach(function(b) {
          b.classList.remove('active');
          b.setAttribute('aria-expanded', 'false');
        });
        bankDetails.forEach(function(d) { d.style.display = 'none'; });

        if (isActive) {
          // Deselect — show empty state
          emptyState.style.display = '';
        } else {
          // Select bank
          this.classList.add('active');
          this.setAttribute('aria-expanded', 'true');
          emptyState.style.display = 'none';
          var detail = document.querySelector('[data-bank-detail="' + bankId + '"]');
          if (detail) {
            detail.style.display = 'block';
          }
          // Scroll to detail panel smoothly
          var panel = document.getElementById('bank-detail-panel');
          if (panel) {
            setTimeout(function() {
              panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 100);
          }
        }
      });
    });

    // Check URL hash for direct bank link
    var hash = window.location.hash.replace('#', '');
    if (hash) {
      var targetBtn = document.querySelector('[data-bank-id="' + hash + '"]');
      if (targetBtn) {
        targetBtn.click();
      }
    }

    // FAQ accordion
    var faqButtons = document.querySelectorAll('[data-faq-toggle]');
    faqButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        var item = this.parentElement;
        var isActive = item.classList.contains('active');
        var allItems = document.querySelectorAll('.faq-item');
        allItems.forEach(function(faqItem) {
          faqItem.classList.remove('active');
        });
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });
  })();
</script>
