---
import { supabase } from '../lib/supabase';

interface AnnouncementData {
  text: string;
  link: string;
  visible: boolean;
}

let announcement: AnnouncementData | null = null;

try {
  const { data } = await supabase
    .from('settings')
    .select('value')
    .eq('key', 'announcement_bar')
    .single();

  if (data?.value) {
    announcement = data.value as AnnouncementData;
  }
} catch {
  // Supabase error — use fallback
}

// Fallback when Supabase not configured or no data
if (!announcement) {
  announcement = {
    text: 'NYHET — Garanti på alla våra bilar. Kontakta oss för mer information.',
    link: '/kontakt',
    visible: true,
  };
}
---

{announcement?.visible && (
  <div class="announcement-bar">
    <a href={announcement.link}><span>NYHET</span> — Garanti på alla våra bilar. Kontakta oss för mer information.</a>
  </div>
)}

