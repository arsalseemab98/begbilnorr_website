---
import SEOHead from './SEOHead.astro';
import AnnouncementBar from './AnnouncementBar.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import FinanceCalcModal from './FinanceCalcModal.astro';
import CookieConsent from './CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  noindex?: boolean;
  priceAmount?: number;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <SEOHead {...props} />
  <slot name="head" />
</head>
<body>
  <a href="#main-content" class="skip-link">Hoppa till innehåll</a>
  <AnnouncementBar />
  <Navbar />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <FinanceCalcModal />
  <CookieConsent />
  <script>
    // Capture UTM parameters and referrer on first visit
    (function() {
      const params = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid'];
      const utm: Record<string, string> = {};

      utmKeys.forEach(key => {
        const val = params.get(key);
        if (val) utm[key] = val;
      });

      // Auto-detect source if no utm_source
      if (!utm.utm_source) {
        const ref = document.referrer;
        if (ref) {
          try {
            const host = new URL(ref).hostname;
            if (host.includes('google')) utm.utm_source = 'google';
            else if (host.includes('facebook') || host.includes('fb.')) utm.utm_source = 'facebook';
            else if (host.includes('instagram')) utm.utm_source = 'instagram';
            else if (host.includes('tiktok')) utm.utm_source = 'tiktok';
            else if (host.includes('blocket')) utm.utm_source = 'blocket';
            else utm.utm_source = host;
            if (!utm.utm_medium) utm.utm_medium = 'referral';
          } catch {}
        } else {
          utm.utm_source = 'direct';
          utm.utm_medium = 'none';
        }
      }

      // If gclid present, it's Google Ads
      if (utm.gclid && !utm.utm_medium) {
        utm.utm_source = 'google';
        utm.utm_medium = 'cpc';
      }

      // If fbclid present, it's Facebook
      if (utm.fbclid && !utm.utm_medium) {
        utm.utm_source = 'facebook';
        utm.utm_medium = 'cpc';
      }

      utm.landing_page = window.location.pathname;

      // Only store on first visit in session
      if (!sessionStorage.getItem('utm_data')) {
        sessionStorage.setItem('utm_data', JSON.stringify(utm));
      }
    })();

    // Global helper to get UTM data
    (window as any).getUtmData = function() {
      try {
        return JSON.parse(sessionStorage.getItem('utm_data') || '{}');
      } catch { return {}; }
    };

    // Meta Pixel — delegated click tracking for tel:/mailto:/WhatsApp
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const anchor = target?.closest?.('a[href]') as HTMLAnchorElement | null;
      if (!anchor) return;
      const href = anchor.getAttribute('href') || '';
      const fbq = (window as any).fbq;
      if (typeof fbq !== 'function') return;

      if (href.startsWith('tel:')) {
        fbq('track', 'Contact', { content_name: 'Phone click', method: 'phone' });
      } else if (href.startsWith('mailto:')) {
        fbq('track', 'Contact', { content_name: 'Email click', method: 'email' });
      } else if (/(^https?:\/\/)?(api\.)?(wa\.me|whatsapp\.com)/i.test(href)) {
        const carMatch = decodeURIComponent(href).match(/intresserad av ([^(]+)\(/i);
        const carName = carMatch ? carMatch[1].trim() : '';
        fbq('track', 'Lead', {
          content_name: carName ? 'WhatsApp: ' + carName : 'WhatsApp click',
          method: 'whatsapp',
        });
      }
    }, { capture: true });
  </script>

  <script>
    (function autoRefresh() {
      let currentVersion: string | null = null;
      const INTERVAL = 60_000; // check every 60s

      async function check() {
        try {
          const res = await fetch('/api/version', { cache: 'no-store' });
          if (!res.ok) return;
          const { v } = await res.json();
          if (!currentVersion) {
            currentVersion = v;
            return;
          }
          if (v !== currentVersion) {
            window.location.reload();
          }
        } catch {}
      }

      // Only run in production
      if (window.location.hostname !== 'localhost') {
        check();
        setInterval(check, INTERVAL);
      }

      // Re-init after Astro page transitions
      document.addEventListener('astro:after-swap', () => {
        currentVersion = null;
        check();
      });
    })();
  </script>
</body>
</html>
