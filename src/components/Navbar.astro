---
const pathname = Astro.url.pathname;

const links = [
  { href: '/bilar', label: 'Bilar' },
  { href: '/salj-bil', label: 'Sälj din bil' },
  { href: '/finansiering', label: 'Finansiering' },
  { href: '/om-oss', label: 'Om oss' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<nav class="navbar">
  <div class="container">
    <a href="/" class="navbar-brand">
      <img
        src="https://begbilnorr.se/wp-content/uploads/2024/11/cropped-begbilnorr_Logo_-_E-2__1_-removebg-preview.png"
        alt="Begbilnorr - Begagnade bilar i Luleå"
        class="brand-logo"
        width="120"
        height="45"
      />
    </a>

    <div class="navbar-links">
      {links.map((link) => (
        <a href={link.href} class={pathname.startsWith(link.href) ? 'active' : ''}>
          {link.label}
        </a>
      ))}
    </div>

    <div class="navbar-icons">
      <a href="tel:+4692099986" title="Ring oss">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
      <button class="hamburger" id="hamburgerBtn" aria-label="Meny">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  {links.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
</div>

<script>
  const btn = document.getElementById('hamburgerBtn');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('active');
  });
</script>
