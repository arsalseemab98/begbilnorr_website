---
const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
};
---

<!-- ========== NAVBAR ========== -->
<nav class="navbar">
  <div class="container">
    <a href="/" class="navbar-brand">
      <img
        src="/images/begbilnorr-logo-nav.webp"
        alt="Begbilnorr - Begagnade bilar i Luleå"
        class="brand-logo"
        width="150"
        height="90"
      />
    </a>

    <div class="navbar-links">
      <a href="/bilar" class={isActive('/bilar') ? 'active' : ''}>Bilar</a>
      <a href="/salj-bil" class={isActive('/salj-bil') ? 'active' : ''}>Sälj din bil</a>
      <a href="/finansiering" class={isActive('/finansiering') ? 'active' : ''}>Finansiering</a>
      <a href="/swish" class={isActive('/swish') ? 'active' : ''}>Swish</a>
      <a href="/om-oss" class={isActive('/om-oss') ? 'active' : ''}>Om oss</a>
      <a href="/kontakt" class={isActive('/kontakt') ? 'active' : ''}>Kontakt</a>
    </div>

    <div class="navbar-icons">
      <a href="#" title="Sparade bilar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      </a>
      <a href="/bilar" title="Sök">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <button class="hamburger" id="hamburgerBtn" aria-label="Meny">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

