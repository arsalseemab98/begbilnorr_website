---
import type { Car } from '../types/car';
import { formatPrice, formatMileage, calculateMonthlyPayment } from '../lib/utils';

interface Props {
  car: Car;
}

const { car } = Astro.props;
const images = car.images?.slice(0, 8) || [];
const mainImage = images[0];
const hasMultiple = images.length > 1;
const monthly = car.monthly_payment || calculateMonthlyPayment(car.price);
---

<div class="car-card" data-href={`/bilar/${car.slug}`}>
  <a href={`/bilar/${car.slug}`} class="car-card-link" aria-label={`Visa ${car.full_name}`}></a>
  <div class="car-card-image" data-images={hasMultiple ? JSON.stringify(images) : undefined}>
    {mainImage ? (
      <img src={mainImage} alt={`Begagnad ${car.full_name} till salu Luleå`} loading="lazy" width="400" height="220" class="carousel-img" />
    ) : (
      <span style="font-size:64px;opacity:0.2;">&#128663;</span>
    )}
    <div class="watermark">Begbilnorr</div>
    <span class="badge-fuel">{car.fuel_type}</span>
    {hasMultiple && (
      <>
        <button class="carousel-arrow carousel-prev" aria-label="Föregående bild" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="carousel-arrow carousel-next" aria-label="Nästa bild" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <div class="carousel-dots">
          {images.map((_, i) => (
            <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={i}></span>
          ))}
        </div>
        <span class="carousel-count">1 / {images.length}</span>
      </>
    )}
  </div>
  <div class="car-card-body">
    <div class="car-specs">{car.year} &nbsp;/&nbsp; {formatMileage(car.mileage).toUpperCase()} &nbsp;/&nbsp; LULEÅ</div>
    <div class="car-name">{car.full_name}</div>
    <div class="car-card-footer">
      <div>
        <div class="car-price">{formatPrice(car.price)}</div>
        <span class="car-monthly">fr. {monthly}</span>
      </div>
      <div class="card-actions">
        <a href={`https://wa.me/46727448034?text=Hej! Jag är intresserad av ${car.full_name} (${car.reg_no})`} class="contact-icon whatsapp" title="WhatsApp" target="_blank" rel="noopener">
          <svg viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
        </a>
        <a href="tel:+4692099986" class="contact-icon phone-icon" title="Ring oss">
          <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
        <button
          class="contact-icon watch-icon"
          data-car-name={car.full_name}
          data-car-slug={car.slug}
          data-car-reg={car.reg_no}
          title="Bevaka denna bil"
        >
          <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </button>
        <button
          class="interested-btn"
          data-car-name={car.full_name}
          data-car-slug={car.slug}
          title="Skicka intresseanmälan"
        >
          <svg viewBox="0 0 24 24"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Intresserad?
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initCarousels() {
    document.querySelectorAll('.car-card-image[data-images]').forEach((container) => {
      const el = container as HTMLElement;
      if (el.dataset.carouselInit) return;
      el.dataset.carouselInit = '1';

      const images: string[] = JSON.parse(el.dataset.images || '[]');
      if (images.length < 2) return;

      const img = el.querySelector('.carousel-img') as HTMLImageElement;
      const dots = el.querySelectorAll('.carousel-dot');
      const countEl = el.querySelector('.carousel-count');
      const prevBtn = el.querySelector('.carousel-prev');
      const nextBtn = el.querySelector('.carousel-next');
      let idx = 0;

      function go(newIdx: number) {
        idx = (newIdx + images.length) % images.length;
        img.src = images[idx];
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        if (countEl) countEl.textContent = `${idx + 1} / ${images.length}`;
      }

      prevBtn?.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); go(idx - 1); });
      nextBtn?.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); go(idx + 1); });
      dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault(); e.stopPropagation();
          go(Number((dot as HTMLElement).dataset.index));
        });
      });

      // Click on image navigates to detail page
      img?.addEventListener('click', () => {
        const card = el.closest('.car-card') as HTMLElement;
        const href = card?.dataset.href;
        if (href) window.location.href = href;
      });

      // Touch swipe
      let startX = 0;
      let startY = 0;
      let swiping = false;

      el.addEventListener('touchstart', (e) => {
        const te = e as TouchEvent;
        startX = te.touches[0].clientX;
        startY = te.touches[0].clientY;
        swiping = true;
      }, { passive: true });

      el.addEventListener('touchmove', (e) => {
        if (!swiping) return;
        const te = e as TouchEvent;
        const dx = te.touches[0].clientX - startX;
        const dy = te.touches[0].clientY - startY;
        // If horizontal swipe is dominant, prevent page scroll
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
          e.preventDefault();
        }
      }, { passive: false });

      el.addEventListener('touchend', (e) => {
        if (!swiping) return;
        swiping = false;
        const te = e as TouchEvent;
        const dx = te.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) {
          e.preventDefault();
          e.stopPropagation();
          go(dx < 0 ? idx + 1 : idx - 1);
        }
      });
    });
  }

  // Init + handle Astro view transitions
  initCarousels();
  document.addEventListener('astro:after-swap', initCarousels);

  // Existing button handlers
  document.querySelectorAll('.interested-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const target = e.currentTarget as HTMLElement;
      const carName = target.dataset.carName || '';
      const carSlug = target.dataset.carSlug || '';
      window.dispatchEvent(
        new CustomEvent('open-contact-modal', {
          detail: { carName, carSlug },
        })
      );
    });
  });

  document.querySelectorAll('.watch-icon').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const target = e.currentTarget as HTMLElement;
      const carName = target.dataset.carName || '';
      const carSlug = target.dataset.carSlug || '';
      const regNo = target.dataset.carReg || '';
      window.dispatchEvent(
        new CustomEvent('open-bevakning-modal', {
          detail: { carName, carSlug, regNo },
        })
      );
    });
  });
</script>
