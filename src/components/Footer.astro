  <div class="contact-modal" id="contactModal">
    <div class="cm-header">
      <button class="cm-close" id="cmClose">&times;</button>
      <div class="cm-photo-wrapper">
        <img src="/images/anton-nobg-small.webp" alt="Anton från Begbilnorr — kontakta oss i Luleå" width="333" height="500" loading="lazy" />
      </div>
      <div class="cm-red-glow"></div>
      <div class="cm-header-content">
        <div class="cm-badge"><span class="cm-badge-dot"></span> Tillgänglig nu</div>
        <h3 class="cm-title" id="cmTitle">Kontakta oss</h3>
        <p class="cm-subtitle" id="cmSubtitle">Fyll i formuläret så återkommer vi</p>
      </div>
    </div>
