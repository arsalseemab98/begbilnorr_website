          </a>
          <a href="https://www.tiktok.com/@begbilnorr" target="_blank" rel="noopener" title="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.71a8.19 8.19 0 004.76 1.52V6.79a4.84 4.84 0 01-1-.1z"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Bilar & Tjänster -->
      <div class="footer-col">
        <h3>Bilar & Tjänster</h3>
        <a href="/bilar">Alla bilar</a>
        <a href="/salj-bil">Sälj din bil</a>
        <a href="/finansiering">Finansiering</a>
        <a href="/swish">Betala med Swish</a>
        <a href="/hoja-swish-grans">Höja Swish-gräns</a>
        <h3 style="margin-top:20px;">Provkör i din stad</h3>
        <a href="/begagnade-bilar-lulea">Luleå</a>
        <a href="/begagnade-bilar-boden">Boden</a>
        <a href="/begagnade-bilar-pitea">Piteå</a>
        <a href="/begagnade-bilar-kalix">Kalix</a>
        <a href="/begagnade-bilar-alvsbyn">Älvsbyn</a>
        <a href="/begagnade-bilar-gallivare">Gällivare</a>
        <a href="/begagnade-bilar-kiruna">Kiruna</a>
        <a href="/begagnade-bilar-haparanda">Haparanda</a>
        <a href="/begagnade-bilar-skelleftea">Skellefteå</a>
        <a href="/begagnade-bilar-umea">Umeå</a>
      </div>

      <!-- Col 3: Öppettider -->
      <div class="footer-col">
        <h3>Öppettider</h3>
        <p>Måndag - Fredag</p>
        <p><strong style="color: var(--white);">09:00 - 18:00</strong></p>
        <p style="margin-top: 8px;">Lördag</p>
        <p><strong style="color: var(--white);">10:00 - 15:00</strong></p>
        <p style="margin-top: 8px;">Söndag</p>
        <p><strong style="color: var(--white);">Stängt</strong></p>
      </div>

      <!-- Col 4: Kontakt -->
      <div class="footer-col">
        <h3>Kontakt</h3>
        <div class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <a href="https://maps.google.com/?q=Fabriksv%C3%A4gen+18,+972+54+Lule%C3%A5" target="_blank" rel="noopener">Fabriksvägen 18, 972 54 Luleå</a>
        </div>
        <div class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href="tel:0920-99986">0920-999 86</a>
        </div>
        <div class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <a href="mailto:info@begbilnorr.se">info@begbilnorr.se</a>
        </div>
        <div class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <a href="https://begbilnorr.se" target="_blank" rel="noopener">begbilnorr.se</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Begbilnorr. Alla rättigheter förbehållna.</p>
      <p class="footer-credit">Skapat av <a href="https://swiftcore.se" target="_blank" rel="noopener"><img src="/images/swiftcore-favicon.png" alt="SwiftCore" class="swiftcore-icon" width="16" height="16" loading="lazy" /> swiftcore.se</a></p>
    </div>
  </div>

  <!-- ========== FLOATING CONTACT BUTTON ========== -->
  <div class="fab-contact">
    <div class="fab-menu" id="fabMenu">
      <a href="tel:0920-99986" class="fab-item">
        <span class="fab-item-label">Ring oss</span>
