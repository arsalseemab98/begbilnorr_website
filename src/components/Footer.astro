          E-post
        </a>
      </div>
    </div>
  </div>

  <!-- Bevakning Modal -->
  <div class="contact-modal-overlay" id="bmOverlay"></div>
  <div class="contact-modal" id="bevakningModal">
    <div class="cm-header" style="background: radial-gradient(ellipse at bottom right, rgba(230,46,45,0.15) 0%, transparent 60%); border-bottom: 1px solid rgba(255,255,255,0.06);">
      <button class="cm-close" id="bmClose">&times;</button>
      <div class="cm-header-content">
        <div class="cm-badge" style="background:rgba(230,46,45,0.12);border-color:rgba(230,46,45,0.25);color:#E62E2D;"><span class="cm-badge-dot" style="background:#E62E2D;"></span> Prisbevakning</div>
        <h3 class="cm-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:6px;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Bevaka denna bil
        </h3>
        <p class="cm-subtitle" id="bmCarLabel"></p>
      </div>
    </div>
    <div class="cm-body" id="bmBody">
      <form id="bmForm">
        <input type="email" class="cm-input" name="email" placeholder="Din e-postadress" required />
        <input type="tel" class="cm-input" name="phone" placeholder="Telefonnummer (valfritt)" />
        <input type="hidden" name="carName" id="bmCarName" />
        <input type="hidden" name="carSlug" id="bmCarSlug" />
        <input type="hidden" name="regNo" id="bmRegNo" />
        <button type="submit" class="cm-submit" style="background:linear-gradient(135deg,#E62E2D,#C72625);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Bevaka
        </button>
      </form>
    </div>
  </div>

  <!-- Sell Car Modal -->
  <div class="contact-modal-overlay" id="smOverlay"></div>
  <div class="contact-modal" id="sellModal">
    <div class="cm-header">
      <button class="cm-close" id="smClose">&times;</button>
      <div class="cm-photo-wrapper">
        <img src="/images/anton-nobg-small.webp" alt="Anton från Begbilnorr — kontakta oss i Luleå" width="333" height="500" loading="lazy" />
      </div>
      <div class="cm-red-glow"></div>
      <div class="cm-header-content">
        <div class="cm-badge" style="background:rgba(230,46,45,0.12);border-color:rgba(230,46,45,0.25);color:#E62E2D;"><span class="cm-badge-dot" style="background:#E62E2D;"></span> Snabb värdering</div>
        <h3 class="cm-title">Sälj din bil</h3>
        <p class="cm-subtitle">Få ett prisförslag inom 24h</p>
      </div>
    </div>
    <div class="cm-body" id="smBody">
      <form id="smForm">
        <input type="text" class="cm-input" name="reg" placeholder="Registreringsnummer (ABC 123)" maxlength="7" style="text-transform:uppercase;letter-spacing:1px;font-weight:600;" required />
        <select class="cm-input cm-select" name="miltal" required>
          <option value="" disabled selected>Miltal</option>
          <option value="0-1000">0 -- 1 000 mil</option>
          <option value="1000-3000">1 000 -- 3 000 mil</option>
          <option value="3000-5000">3 000 -- 5 000 mil</option>
          <option value="5000-10000">5 000 -- 10 000 mil</option>
          <option value="10000-15000">10 000 -- 15 000 mil</option>
          <option value="15000-20000">15 000 -- 20 000 mil</option>
          <option value="20000+">20 000+ mil</option>
        </select>
        <input type="text" class="cm-input" name="name" placeholder="Ditt namn" required />
        <input type="tel" class="cm-input" name="phone" placeholder="Telefonnummer" required />
        <button type="submit" class="cm-submit">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Få gratis värdering
        </button>
      </form>
    </div>
  </div>
</footer>

<script>
  // FAB toggle
  const fabBtn = document.getElementById('fabBtn');
  const fabMenu = document.getElementById('fabMenu');

  fabBtn?.addEventListener('click', () => {
    fabMenu?.classList.toggle('open');
    fabBtn?.classList.toggle('active');
  });

  // Contact Modal (single source of truth)
  const cmOverlay = document.getElementById('cmOverlay');
  const contactModal = document.getElementById('contactModal');
  const cmClose = document.getElementById('cmClose');
  const fabContactBtn = document.getElementById('fabContactBtn');
  const cmTitle = document.getElementById('cmTitle');
  const cmSubtitle = document.getElementById('cmSubtitle');
  const cmCarName = document.getElementById('cmCarName') as HTMLInputElement;
  const cmCarSlug = document.getElementById('cmCarSlug') as HTMLInputElement;
  const cmMessage = document.getElementById('cmMessage') as HTMLTextAreaElement;
  const cmWhatsApp = document.getElementById('cmWhatsApp') as HTMLAnchorElement;

  function openContactModal(carName?: string, carSlug?: string) {
    fabMenu?.classList.remove('open');
    fabBtn?.classList.remove('active');

    if (carName) {
      if (cmTitle) cmTitle.textContent = 'Intresserad?';
      if (cmSubtitle) cmSubtitle.textContent = carName;
      if (cmCarName) cmCarName.value = carName;
      if (cmCarSlug) cmCarSlug.value = carSlug || '';
      if (cmMessage) cmMessage.placeholder = `Hej! Jag är intresserad av ${carName}...`;
      if (cmWhatsApp) {
        cmWhatsApp.href = `https://wa.me/46727448034?text=${encodeURIComponent(`Hej! Jag är intresserad av ${carName}`)}`;
      }
    } else {
      if (cmTitle) cmTitle.textContent = 'Kontakta oss';
      if (cmSubtitle) cmSubtitle.textContent = 'Fyll i formuläret så återkommer vi';
      if (cmCarName) cmCarName.value = '';
      if (cmCarSlug) cmCarSlug.value = '';
      if (cmMessage) cmMessage.placeholder = 'Meddelande (valfritt)';
      if (cmWhatsApp) {
        cmWhatsApp.href = 'https://wa.me/46727448034?text=Hej!';
      }
    }

    cmOverlay?.classList.add('open');
    contactModal?.classList.add('open');
  }

  function closeContactModal() {
    cmOverlay?.classList.remove('open');
    contactModal?.classList.remove('open');
  }

  // FAB "Bli kontaktad" button
  fabContactBtn?.addEventListener('click', () => openContactModal());
  cmOverlay?.addEventListener('click', closeContactModal);
  cmClose?.addEventListener('click', closeContactModal);

  // Listen for open-contact-modal events from CarCard + detail page
  window.addEventListener('open-contact-modal', ((e: CustomEvent) => {
    const { carName, carSlug } = e.detail || {};
    openContactModal(carName, carSlug);
  }) as EventListener);

  // Sell Modal
  const smOverlay = document.getElementById('smOverlay');
  const sellModal = document.getElementById('sellModal');
  const smClose = document.getElementById('smClose');
  const fabSellBtn = document.getElementById('fabSellBtn');

  function openSellModal() {
    fabMenu?.classList.remove('open');
    fabBtn?.classList.remove('active');
    smOverlay?.classList.add('open');
    sellModal?.classList.add('open');
  }

  function closeSellModal() {
    smOverlay?.classList.remove('open');
    sellModal?.classList.remove('open');
  }

  fabSellBtn?.addEventListener('click', openSellModal);
  smOverlay?.addEventListener('click', closeSellModal);
  smClose?.addEventListener('click', closeSellModal);

  // Contact form submit
  const cmForm = document.getElementById('cmForm') as HTMLFormElement;
  cmForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(cmForm);
    const data = Object.fromEntries(formData.entries());

    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...data, source: 'kontakt-footer' }),
      });
    } catch {}

    const cmBody = document.getElementById('cmBody');
    if (cmBody) {
      cmBody.innerHTML = `
        <div class="cm-success">
          <div class="cm-success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h4>Tack!</h4>
          <p>Vi återkommer till dig så snart som möjligt.</p>
        </div>
      `;
    }
  });

  // Sell form submit
  const smForm = document.getElementById('smForm') as HTMLFormElement;
  smForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(smForm);
    const data = Object.fromEntries(formData.entries());

    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: 'Sälj bil (footer)',
          email: data.email || 'ej angiven',
          phone: data.phone || '',
          message: `[SÄLJ BIL - FOOTER]\nReg: ${data.regNumber || '-'}\nTelefon: ${data.phone || '-'}`,
          source: 'salj-bil-footer',
        }),
      });
    } catch {}

    const smBody = document.getElementById('smBody');
    if (smBody) {
      smBody.innerHTML = `
        <div class="cm-success">
          <div class="cm-success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h4>Tack!</h4>
          <p>Vi återkommer med en värdering inom 24 timmar.</p>
        </div>
      `;
    }
  });

  // Bevakning Modal
  const bmOverlay = document.getElementById('bmOverlay');
  const bevakningModal = document.getElementById('bevakningModal');
  const bmClose = document.getElementById('bmClose');

  function openBevakningModal() {
    bmOverlay?.classList.add('open');
    bevakningModal?.classList.add('open');
  }

  function closeBevakningModal() {
    bmOverlay?.classList.remove('open');
    bevakningModal?.classList.remove('open');
  }

  bmOverlay?.addEventListener('click', closeBevakningModal);
  bmClose?.addEventListener('click', closeBevakningModal);

  window.addEventListener('open-bevakning-modal', ((e: CustomEvent) => {
    const { carName, carSlug, regNo } = e.detail;
    const bmCarLabel = document.getElementById('bmCarLabel');
    const bmCarName = document.getElementById('bmCarName') as HTMLInputElement;
    const bmCarSlug = document.getElementById('bmCarSlug') as HTMLInputElement;
    const bmRegNo = document.getElementById('bmRegNo') as HTMLInputElement;

    if (bmCarLabel) bmCarLabel.textContent = carName;
    if (bmCarName) bmCarName.value = carName;
    if (bmCarSlug) bmCarSlug.value = carSlug;
    if (bmRegNo) bmRegNo.value = regNo;

    openBevakningModal();
  }) as EventListener);

  // Bevakning form submit
  const bmForm = document.getElementById('bmForm') as HTMLFormElement;
  bmForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(bmForm);
    const data = Object.fromEntries(formData.entries());

    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: 'Bevakning',
          email: data.email || 'ej angiven',
          phone: data.phone || '',
          message: `[BEVAKNING]\nBil: ${data.carName || '-'}\nReg: ${data.regNo || '-'}\nE-post: ${data.email || '-'}\nTelefon: ${data.phone || '-'}`,
          carName: data.carName || '',
          carSlug: data.carSlug || '',
          source: 'bevakning',
        }),
      });
    } catch {}

    const bmBody = document.getElementById('bmBody');
    if (bmBody) {
      bmBody.innerHTML = `
        <div class="cm-success">
          <div class="cm-success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h4>Tack!</h4>
          <p>Du bevakar nu ${data.carName}!</p>
        </div>
      `;
    }
  });

  // Newsletter bar form submit
  const nlBarForm = document.getElementById('nlBarForm') as HTMLFormElement;
  nlBarForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (nlBarForm.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    if (email) {
      try {
        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: 'Prenumerant',
            email: email,
            message: `[NEWSLETTER] Ny prenumerant: ${email}`,
            source: 'newsletter-footer',
          }),
        });
      } catch {}

      const formParent = nlBarForm.parentElement;
      if (formParent) {
        nlBarForm.outerHTML = `<div class="subscribe-success" style="padding:14px 20px;background:rgba(230,46,45,0.1);border-radius:8px;color:#fff;font-size:15px;font-weight:500;display:flex;align-items:center;gap:8px;">Tack! Du är nu prenumerant.</div>`;
      }
    }
  });
</script>
