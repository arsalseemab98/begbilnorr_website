      <form id="cmForm">
        <input type="hidden" name="carName" id="cmCarName" />
        <input type="hidden" name="carSlug" id="cmCarSlug" />
        <input type="text" class="cm-input" name="name" placeholder="Ditt namn" required />
        <input type="email" class="cm-input" name="email" placeholder="Din e-postadress" required />
        <input type="tel" class="cm-input" name="phone" placeholder="Telefonnummer (valfritt)" />
