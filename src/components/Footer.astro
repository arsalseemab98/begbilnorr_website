---
const year = new Date().getFullYear();
---

<!-- ========== NEWSLETTER BAR ========== -->
<section class="newsletter-bar">
  <!-- Animated background particles -->
  <div class="nl-particles">
    <span class="nl-particle" style="--x: 5%; --y: 20%; --size: 6px; --delay: 0s; --dur: 6s;"></span>
    <span class="nl-particle" style="--x: 15%; --y: 70%; --size: 4px; --delay: 1s; --dur: 8s;"></span>
    <span class="nl-particle" style="--x: 25%; --y: 40%; --size: 8px; --delay: 2s; --dur: 5s;"></span>
    <span class="nl-particle" style="--x: 40%; --y: 80%; --size: 5px; --delay: 0.5s; --dur: 7s;"></span>
    <span class="nl-particle" style="--x: 55%; --y: 15%; --size: 7px; --delay: 3s; --dur: 6s;"></span>
    <span class="nl-particle" style="--x: 65%; --y: 60%; --size: 4px; --delay: 1.5s; --dur: 9s;"></span>
    <span class="nl-particle" style="--x: 75%; --y: 30%; --size: 6px; --delay: 2.5s; --dur: 5s;"></span>
    <span class="nl-particle" style="--x: 85%; --y: 75%; --size: 5px; --delay: 0.8s; --dur: 7s;"></span>
    <span class="nl-particle" style="--x: 92%; --y: 45%; --size: 8px; --delay: 3.5s; --dur: 6s;"></span>
    <span class="nl-particle" style="--x: 50%; --y: 50%; --size: 3px; --delay: 4s; --dur: 8s;"></span>
  </div>
  <!-- Animated envelope icons floating -->
  <div class="nl-floating-icons">
    <svg class="nl-float-icon" style="--x: 8%; --delay: 0s;" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    <svg class="nl-float-icon" style="--x: 30%; --delay: 2s;" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    <svg class="nl-float-icon" style="--x: 70%; --delay: 1s;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    <svg class="nl-float-icon" style="--x: 90%; --delay: 3s;" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
  </div>
  <div class="container">
    <div class="newsletter-bar-inner nl-animate">
      <div class="newsletter-bar-text">
        <div class="nl-icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="nl-icon-ring"></span>
          <span class="nl-icon-ring nl-ring-2"></span>
        </div>
        <div>
          <h3>Få nya bilar direkt i din inbox</h3>
          <p>Prenumerera och bli först med att se våra senaste bilar, erbjudanden och nyheter.</p>
        </div>
      </div>
      <form class="newsletter-bar-form" id="nlBarForm">
        <input type="email" placeholder="Din e-postadress" required />
        <button type="submit">
          <span>Prenumerera</span>
          <svg class="nl-btn-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<!-- ========== FOOTER ========== -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Col 1: Om oss -->
      <div class="footer-col">
        <img
          src="/images/begbilnorr-logo-nav.webp"
          alt="Begbilnorr — begagnade bilar i Luleå"
          class="footer-logo"
          width="200"
          height="34"
          loading="lazy"
        />
        <p class="footer-desc">Din lokala bilhandlare i Luleå. Vi erbjuder kvalitetskontrollerade begagnade bilar med garanti, finansiering och hemleverans i hela Sverige.</p>
        <div class="social-links">
          <a href="https://facebook.com/begbilnorr" target="_blank" rel="noopener" title="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/begbilnorr" target="_blank" rel="noopener" title="Instagram">
