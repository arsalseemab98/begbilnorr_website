      </div>

      <div class="footer-col">
        <h3>Snabblänkar</h3>
        <a href="/bilar">Alla bilar</a>
        <a href="/salj-bil">Sälj din bil</a>
        <a href="/finansiering">Finansiering</a>
        <a href="/om-oss">Om oss</a>
